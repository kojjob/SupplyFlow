<% content_for :title, "New Customer | SupplyFlow" %>

<div class="max-w-6xl mx-auto px-4 py-8">
  <%# Page Header Section %>
  <div class="mb-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">New Customer</h1>
        <p class="mt-1 text-sm text-gray-500">Create a new customer record in the system</p>
      </div>
      <div class="mt-4 sm:mt-0">
        <%= link_to customers_path, class: "inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" />
          </svg>
          Back to Customers
        <% end %>
      </div>
    </div>
  </div>

  <%# Main Content Section %>
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-4 py-5 sm:p-6">
      <%= form_with(model: @customer, url: customers_path, class: "space-y-6", data: { controller: "form", action: "turbo:submit-end->form#reset" }) do |form| %>
        
        <%# Form Errors %>
        <% if @customer.errors.any? %>
          <div class="rounded-md bg-red-50 p-4 mb-6">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-red-800">There were <%= pluralize(@customer.errors.count, "error") %> with your submission</h3>
                <div class="mt-2 text-sm text-red-700">
                  <ul class="list-disc pl-5 space-y-1">
                    <% @customer.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <%# Form Sections %>
        <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
          
          <%# Basic Information Section %>
          <div class="sm:col-span-6">
            <h2 class="text-lg font-medium text-gray-900 border-b border-gray-200 pb-2 mb-4">Basic Information</h2>
          </div>

          <%# Name Field %>
          <div class="sm:col-span-3">
            <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_field :name, class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "Enter customer name", required: true %>
            </div>
          </div>

          <%# Email Field %>
          <div class="sm:col-span-3">
            <%= form.label :email, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.email_field :email, class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "customer@example.com" %>
            </div>
          </div>

          <%# Contact Person Field %>
          <div class="sm:col-span-3">
            <%= form.label :contact_person, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_field :contact_person, class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "Primary contact person" %>
            </div>
          </div>

          <%# Phone Field %>
          <div class="sm:col-span-3">
            <%= form.label :phone, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.telephone_field :phone, class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "e.g. +233 24 123 4567" %>
            </div>
          </div>

          <%# Address Section %>
          <div class="sm:col-span-6 mt-4">
            <h2 class="text-lg font-medium text-gray-900 border-b border-gray-200 pb-2 mb-4">Address Information</h2>
          </div>

          <%# Address Field %>
          <div class="sm:col-span-6">
            <%= form.label :address, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_area :address, rows: 3, class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "Enter full street address" %>
            </div>
          </div>

          <%# City Field %>
          <div class="sm:col-span-2">
            <%= form.label :city, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_field :city, class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "City" %>
            </div>
          </div>

          <%# State/Region Field %>
          <div class="sm:col-span-2">
            <%= form.label :state, "State/Region", class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_field :state, class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "State or Region" %>
            </div>
          </div>

          <%# Postal Code Field %>
          <div class="sm:col-span-2">
            <%= form.label :postal_code, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_field :postal_code, class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "Postal code" %>
            </div>
          </div>

          <%# Country Field %>
          <div class="sm:col-span-2">
            <%= form.label :country, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_field :country, class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", value: "Ghana", placeholder: "Country" %>
            </div>
            <p class="mt-1 text-xs text-gray-500">Default: Ghana</p>
          </div>

          <%# Additional Information Section %>
          <div class="sm:col-span-6 mt-4">
            <h2 class="text-lg font-medium text-gray-900 border-b border-gray-200 pb-2 mb-4">Additional Information</h2>
          </div>

          <%# Tax ID Field %>
          <div class="sm:col-span-3">
            <%= form.label :tax_id, "Tax ID", class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_field :tax_id, class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "Tax identification number" %>
            </div>
          </div>

          <%# Credit Limit Field %>
          <div class="sm:col-span-3">
            <%= form.label :credit_limit, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1 relative rounded-md shadow-sm">
              <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                <span class="text-gray-500 sm:text-sm">₵</span>
              </div>
              <%= form.number_field :credit_limit, min: 0, step: 0.01, class: "py-3 px-4 block w-full rounded-md border border-gray-300 pl-7 pr-12 focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "0.00" %>
              <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                <span class="text-gray-500 sm:text-sm">GHS</span>
              </div>
            </div>
            <p class="mt-1 text-xs text-gray-500">Leave blank for no credit limit</p>
          </div>

          <%# Active Status %>
          <div class="sm:col-span-3">
            <div class="flex items-start">
              <div class="flex h-5 items-center">
                <%= form.check_box :active, class: "h-6 w-6 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500", checked: true %>
              </div>
              <div class="ml-3 text-sm">
                <%= form.label :active, class: "font-medium text-gray-700" %>
                <p class="text-gray-500">Inactive customers won't appear in default views</p>
              </div>
            </div>
          </div>

          <%# Notes Field %>
          <div class="sm:col-span-6">
            <%= form.label :notes, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_area :notes, rows: 4, class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "Any additional information about this customer" %>
            </div>
          </div>
        </div>

        <%# Form Actions %>
        <div class="flex justify-end space-x-3 pt-5 border-t border-gray-200">
          <%= link_to "Cancel", customers_path, class: "rounded-md border border-gray-300 bg-white py-3 px-4 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
          
          <%= form.button type: "submit", class: "inline-flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2", data: { turbo: true } do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Create Customer
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>