<%# Customer Modal Helper - adds a safety fallback %>
<script>
  // This is a fallback function in case ModalHelpers is not loaded yet
  function showCustomerDetailsModal(customerId) {
    if (window.ModalHelpers && window.ModalHelpers.showCustomerDetailsModal) {
      window.ModalHelpers.showCustomerDetailsModal(customerId);
    } else {
      // Fallback implementation
      const modalId = "customer-details-modal";
      const modal = document.getElementById(modalId);
      const modalContent = document.getElementById('customer-modal-content');
      
      if (!modal || !modalContent) {
        console.error("Customer details modal or content not found");
        return;
      }
      
      // Show loading spinner
      modalContent.innerHTML = `
        <div class="flex justify-center items-center py-12">
          <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-indigo-600"></div>
        </div>
      `;
      
      // Open the modal using Stimulus controller
      const controller = window.Stimulus && 
                         window.Stimulus.getControllerForElementAndIdentifier(modal, 'modal');
      
      if (controller) {
        controller.open();
      } else {
        // Manual fallback
        modal.classList.remove('hidden');
        const container = modal.querySelector('[data-modal-target="container"]');
        const overlay = modal.querySelector('[data-modal-target="overlay"]');
        
        if (container) {
          container.classList.remove('opacity-0');
          container.classList.add('opacity-100');
        }
        
        if (overlay) {
          overlay.classList.remove('opacity-0');
          overlay.classList.add('opacity-100');
        }
      }
      
      // Fetch customer details
      fetch(`/customers/${customerId}?format=html&modal=true`)
        .then(response => {
          if (!response.ok) {
            throw new Error('Network response was not ok');
          }
          return response.text();
        })
        .then(html => {
          modalContent.innerHTML = html;
        })
        .catch(error => {
          modalContent.innerHTML = `
            <div class="bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500 p-4">
              <div class="flex">
                <div class="flex-shrink-0">
                  <i class="fas fa-exclamation-circle text-red-500"></i>
                </div>
                <div class="ml-3">
                  <p class="text-sm text-red-700 dark:text-red-200">
                    Error loading customer details: ${error.message}
                  </p>
                </div>
              </div>
            </div>
          `;
        });
    }
  }
</script>