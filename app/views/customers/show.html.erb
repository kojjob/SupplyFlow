<% content_for :title, @customer.name %>

<% if params[:modal] == 'true' %>
  <%= render 'customer_details' %>
<% else %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <nav class="flex" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-4">
        <li>
          <div>
            <%= link_to customers_path, class: "text-gray-400 hover:text-gray-500 dark:text-gray-500 dark:hover:text-gray-400" do %>
              <i class="fas fa-users flex-shrink-0 h-5 w-5"></i>
              <span class="sr-only">Customers</span>
            <% end %>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <i class="fas fa-chevron-right flex-shrink-0 h-5 w-5 text-gray-400 dark:text-gray-600"></i>
            <span class="ml-4 text-sm font-medium text-gray-500 dark:text-gray-400 truncate"><%= @customer.name %></span>
          </div>
        </li>
      </ol>
    </nav>
  </div>

  <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @customer.name %></h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Customer details and order history</p>
    </div>

    <div class="mt-4 md:mt-0 flex flex-col sm:flex-row gap-3">
      <% if policy(@customer).update? %>
        <%= link_to edit_customer_path(@customer), class: "inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
          <i class="fas fa-edit mr-2"></i> Edit Customer
        <% end %>
      <% end %>

      <% if policy(SalesOrder).create? %>
        <%= link_to new_sales_order_path(customer_id: @customer.id), class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
          <i class="fas fa-plus mr-2"></i> New Sales Order
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Customer Information -->
    <div class="lg:col-span-2">
      <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-lg">
        <div class="px-4 py-5 sm:px-6 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white">Customer Information</h3>
          <p class="mt-1 max-w-2xl text-sm text-gray-500 dark:text-gray-400">Contact details and business information.</p>
        </div>
        <div class="border-t border-gray-200 dark:border-gray-700 px-4 py-5 sm:p-0">
          <dl class="sm:divide-y sm:divide-gray-200 sm:dark:divide-gray-700">
            <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Full name</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white sm:mt-0 sm:col-span-2"><%= @customer.name %></dd>
            </div>
            <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Contact person</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white sm:mt-0 sm:col-span-2"><%= @customer.contact_person.presence || "—" %></dd>
            </div>
            <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Email address</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white sm:mt-0 sm:col-span-2">
                <% if @customer.email.present? %>
                  <a href="mailto:<%= @customer.email %>" class="text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300"><%= @customer.email %></a>
                <% else %>
                  —
                <% end %>
              </dd>
            </div>
            <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Phone number</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white sm:mt-0 sm:col-span-2">
                <% if @customer.phone.present? %>
                  <a href="tel:<%= @customer.phone %>" class="text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300"><%= @customer.phone %></a>
                <% else %>
                  —
                <% end %>
              </dd>
            </div>
            <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Address</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white sm:mt-0 sm:col-span-2">
                <% if @customer.address.present? %>
                  <div><%= @customer.address %></div>
                  <div>
                    <%= [@customer.city, @customer.state, @customer.postal_code].compact.join(", ") %>
                  </div>
                  <div><%= @customer.country %></div>
                <% else %>
                  —
                <% end %>
              </dd>
            </div>
            <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Tax ID</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white sm:mt-0 sm:col-span-2"><%= @customer.tax_id.presence || "—" %></dd>
            </div>
            <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Credit limit</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white sm:mt-0 sm:col-span-2">
                <% if @customer.credit_limit.present? %>
                  <%= number_to_currency(@customer.credit_limit, unit: current_organization&.currency || "GHS") %>
                <% else %>
                  —
                <% end %>
              </dd>
            </div>
            <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Status</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white sm:mt-0 sm:col-span-2">
                <% if @customer.active? %>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                    Active
                  </span>
                <% else %>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200">
                    Inactive
                  </span>
                <% end %>
              </dd>
            </div>
            <% if @customer.notes.present? %>
              <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Notes</dt>
                <dd class="mt-1 text-sm text-gray-900 dark:text-white sm:mt-0 sm:col-span-2 whitespace-pre-line"><%= @customer.notes %></dd>
              </div>
            <% end %>
          </dl>
        </div>
      </div>
    </div>

    <!-- Customer Stats -->
    <div class="lg:col-span-1">
      <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-lg">
        <div class="px-4 py-5 sm:px-6 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center">
          <div>
            <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white">Customer Stats</h3>
            <p class="mt-1 max-w-2xl text-sm text-gray-500 dark:text-gray-400">Key metrics and information.</p>
          </div>
          <button
            onclick="showErrorModal(
              'NameError in Customers#show',
              'undefined local variable or method \'current_organization\' for an instance of #<Class:0x000000017e770b58>',
              '<dt class=\'text-sm font-medium text-green-500 dark:text-green-400 truncate\'>Total Spent</dt>\n<dd class=\'mt-1 text-3xl font-semibold text-green-600 dark:text-green-300\'>\n  <%= number_to_currency(@customer.sales_orders.sum(:total_amount), unit: current_organization.currency) %>\n</dd>',
              'The error occurs because the view is trying to access current_organization which is not defined in the view context. We fixed this by adding a current_organization helper method to ApplicationHelper and using the safe navigation operator (&.) to prevent nil errors.'
            )"
            class="inline-flex items-center px-3 py-1 border border-transparent text-sm leading-4 font-medium rounded-md shadow-sm text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500"
          >
            <i class="fas fa-exclamation-triangle mr-1"></i> Show Error
          </button>
        </div>
        <div class="px-4 py-5 sm:p-6">
          <dl class="grid grid-cols-1 gap-5">
            <div class="bg-indigo-50 dark:bg-indigo-900/20 rounded-lg p-5">
              <dt class="text-sm font-medium text-indigo-500 dark:text-indigo-400 truncate">Total Orders</dt>
              <dd class="mt-1 text-3xl font-semibold text-indigo-600 dark:text-indigo-300"><%= @customer.sales_orders.count %></dd>
            </div>

            <div class="bg-green-50 dark:bg-green-900/20 rounded-lg p-5">
              <dt class="text-sm font-medium text-green-500 dark:text-green-400 truncate">Total Spent</dt>
              <dd class="mt-1 text-3xl font-semibold text-green-600 dark:text-green-300">
                <%= number_to_currency(@customer.sales_orders.sum(:total_amount), unit: current_organization&.currency || "GHS") %>
              </dd>
            </div>

            <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-5">
              <dt class="text-sm font-medium text-blue-500 dark:text-blue-400 truncate">Last Order</dt>
              <dd class="mt-1 text-lg font-semibold text-blue-600 dark:text-blue-300">
                <% last_order = @customer.sales_orders.order(created_at: :desc).first %>
                <% if last_order %>
                  <%= time_ago_in_words(last_order.created_at) %> ago
                <% else %>
                  Never
                <% end %>
              </dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </div>

  <!-- Recent Orders -->
  <div class="mt-6">
    <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-lg">
      <div class="px-4 py-5 sm:px-6 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center">
        <div>
          <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white">Recent Orders</h3>
          <p class="mt-1 max-w-2xl text-sm text-gray-500 dark:text-gray-400">The latest sales orders from this customer.</p>
        </div>

        <% if @sales_orders.any? %>
          <%= link_to sales_orders_path(customer_id: @customer.id), class: "text-sm text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300" do %>
            View All <i class="fas fa-arrow-right ml-1"></i>
          <% end %>
        <% end %>
      </div>

      <% if @sales_orders.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-700">
              <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Order #</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Date</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Payment</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Total</th>
                <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
              <% @sales_orders.each do |order| %>
                <tr>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-indigo-600 dark:text-indigo-400">
                      <%= link_to order.order_number, sales_order_path(order), class: "hover:underline" %>
                    </div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm text-gray-900 dark:text-white"><%= order.order_date&.strftime("%b %d, %Y") || order.created_at.strftime("%b %d, %Y") %></div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% case order.status %>
                    <% when 'draft' %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300">
                        Draft
                      </span>
                    <% when 'pending' %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">
                        Pending
                      </span>
                    <% when 'confirmed' %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
                        Confirmed
                      </span>
                    <% when 'processing' %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-indigo-100 text-indigo-800 dark:bg-indigo-900 dark:text-indigo-200">
                        Processing
                      </span>
                    <% when 'shipped' %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200">
                        Shipped
                      </span>
                    <% when 'delivered' %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                        Delivered
                      </span>
                    <% when 'canceled' %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200">
                        Canceled
                      </span>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% case order.payment_status %>
                    <% when 'unpaid' %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200">
                        Unpaid
                      </span>
                    <% when 'partial' %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">
                        Partial
                      </span>
                    <% when 'paid' %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                        Paid
                      </span>
                    <% when 'refunded' %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300">
                        Refunded
                      </span>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm text-gray-900 dark:text-white"><%= number_to_currency(order.total_amount, unit: current_organization.currency) %></div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                    <%= link_to sales_order_path(order), class: "text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300" do %>
                      <i class="fas fa-eye"></i>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="px-4 py-10 text-center text-gray-500 dark:text-gray-400">
          <div class="flex flex-col items-center justify-center">
            <div class="w-16 h-16 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mb-4">
              <i class="fas fa-shopping-cart text-2xl"></i>
            </div>
            <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-1">No orders yet</h3>
            <p class="text-gray-500 dark:text-gray-400 mb-4">This customer hasn't placed any orders yet.</p>

            <% if policy(SalesOrder).create? %>
              <%= link_to new_sales_order_path(customer_id: @customer.id), class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
                <i class="fas fa-plus mr-2"></i> Create Sales Order
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<% end %>
