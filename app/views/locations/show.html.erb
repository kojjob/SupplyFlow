<div class="container mx-auto px-4 py-6">
  <!-- Breadcrumbs -->
  <nav class="mb-4 flex text-sm text-gray-500 dark:text-gray-400" aria-label="Breadcrumb">
    <ol class="inline-flex items-center space-x-1 md:space-x-3">
      <li class="inline-flex items-center">
        <%= link_to root_path, class: "inline-flex items-center hover:text-gray-900 dark:hover:text-white" do %>
          <i class="fas fa-home mr-2"></i>
          Home
        <% end %>
      </li>
      <li>
        <div class="flex items-center">
          <i class="fas fa-chevron-right text-gray-400 mx-2 text-xs"></i>
          <%= link_to "Locations", locations_path, class: "hover:text-gray-900 dark:hover:text-white" %>
        </div>
      </li>
      <li aria-current="page">
        <div class="flex items-center">
          <i class="fas fa-chevron-right text-gray-400 mx-2 text-xs"></i>
          <span class="text-gray-600 dark:text-gray-300">Location Details</span>
        </div>
      </li>
    </ol>
  </nav>

  <!-- Page Header -->
  <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-6">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white flex items-center">
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-indigo-600"><%= @location.name %></span>
        <% if @location.active? %>
          <span class="ml-3 px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300">
            Active
          </span>
        <% else %>
          <span class="ml-3 px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 dark:bg-red-900/40 text-red-800 dark:text-red-300">
            Inactive
          </span>
        <% end %>
      </h1>
      <p class="text-gray-600 dark:text-gray-400 mt-1"><%= @location.location_type.titleize %> Location</p>
    </div>

    <div class="mt-4 md:mt-0 flex space-x-3">
      <%= link_to edit_location_path(@location), class: "flex items-center px-4 py-2 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors duration-200" do %>
        <i class="fas fa-edit text-gray-500 dark:text-gray-400 mr-2"></i>
        <span class="text-gray-700 dark:text-gray-300 text-sm font-medium">Edit</span>
      <% end %>
      <%= button_to location_path(@location), method: :delete, form: { data: { turbo_confirm: "Are you sure you want to delete this location?" } }, class: "flex items-center px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg shadow-sm transition-colors duration-200" do %>
        <i class="fas fa-trash mr-2"></i>
        <span class="text-sm font-medium">Delete</span>
      <% end %>
    </div>
  </div>

  <!-- Location Details -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main Details Card -->
    <div class="lg:col-span-2 bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
      <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-5 py-4">
        <h2 class="text-lg font-semibold text-white flex items-center">
          <i class="fas fa-info-circle mr-2"></i> Location Details
        </h2>
      </div>
      <div class="p-5">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <div class="mb-4">
              <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">Name</h3>
              <p class="mt-1 text-lg text-gray-900 dark:text-white"><%= @location.name %></p>
            </div>
            <div class="mb-4">
              <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">Location Type</h3>
              <p class="mt-1 text-lg text-gray-900 dark:text-white"><%= @location.location_type.titleize %></p>
            </div>
            <div class="mb-4">
              <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">Parent Location</h3>
              <% if @location.parent_location.present? %>
                <%= link_to @location.parent_location.name, location_path(@location.parent_location), class: "mt-1 text-lg text-blue-600 dark:text-blue-400 hover:underline" %>
              <% else %>
                <p class="mt-1 text-lg text-gray-500 dark:text-gray-400">None</p>
              <% end %>
            </div>
          </div>
          <div>
            <div class="mb-4">
              <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">Phone</h3>
              <p class="mt-1 text-lg text-gray-900 dark:text-white"><%= @location.phone.present? ? @location.phone : "N/A" %></p>
            </div>
            <div class="mb-4">
              <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">Email</h3>
              <p class="mt-1 text-lg text-gray-900 dark:text-white"><%= @location.email.present? ? @location.email : "N/A" %></p>
            </div>
            <div class="mb-4">
              <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">Status</h3>
              <p class="mt-1">
                <% if @location.active? %>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300">
                    Active
                  </span>
                <% else %>
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 dark:bg-red-900/40 text-red-800 dark:text-red-300">
                    Inactive
                  </span>
                <% end %>
              </p>
            </div>
          </div>
        </div>

        <hr class="my-5 border-gray-200 dark:border-gray-700">

        <div class="mb-4">
          <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">Full Address</h3>
          <p class="mt-1 text-gray-900 dark:text-white">
            <%= [
              @location.address,
              @location.city,
              @location.state,
              @location.postal_code,
              @location.country
            ].reject(&:blank?).join(", ") %>
          </p>
        </div>

        <% if @location.notes.present? %>
          <div class="mt-4">
            <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">Notes</h3>
            <div class="mt-1 bg-gray-50 dark:bg-gray-700/50 rounded-lg p-3 text-gray-800 dark:text-gray-200">
              <%= simple_format(@location.notes) %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Sidebar Cards -->
    <div class="space-y-6">
      <!-- Child Locations Card -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
        <div class="bg-gradient-to-r from-indigo-600 to-indigo-700 px-5 py-4 flex justify-between items-center">
          <h2 class="text-lg font-semibold text-white flex items-center">
            <i class="fas fa-sitemap mr-2"></i> Child Locations
          </h2>
          <%= link_to new_location_path(parent_id: @location.id), class: "text-white bg-white/20 hover:bg-white/30 rounded-lg px-2 py-1 text-xs font-medium transition-colors duration-200" do %>
            <i class="fas fa-plus mr-1"></i> Add
          <% end %>
        </div>
        <div class="p-5">
          <% if @location.child_locations.any? %>
            <ul class="divide-y divide-gray-200 dark:divide-gray-700">
              <% @location.child_locations.each do |child| %>
                <li class="py-3 flex items-center justify-between">
                  <div class="flex items-center">
                    <% if child.location_type == "warehouse" %>
                      <div class="h-8 w-8 rounded-lg bg-blue-100 dark:bg-blue-900/40 flex items-center justify-center text-blue-600 dark:text-blue-400 text-sm">
                        <i class="fas fa-warehouse"></i>
                      </div>
                    <% elsif child.location_type == "store" %>
                      <div class="h-8 w-8 rounded-lg bg-green-100 dark:bg-green-900/40 flex items-center justify-center text-green-600 dark:text-green-400 text-sm">
                        <i class="fas fa-store"></i>
                      </div>
                    <% elsif child.location_type == "shelf" %>
                      <div class="h-8 w-8 rounded-lg bg-purple-100 dark:bg-purple-900/40 flex items-center justify-center text-purple-600 dark:text-purple-400 text-sm">
                        <i class="fas fa-th-large"></i>
                      </div>
                    <% else %>
                      <div class="h-8 w-8 rounded-lg bg-gray-100 dark:bg-gray-700 flex items-center justify-center text-gray-600 dark:text-gray-400 text-sm">
                        <i class="fas fa-map-marker-alt"></i>
                      </div>
                    <% end %>
                    <div class="ml-3">
                      <p class="text-sm font-medium text-gray-900 dark:text-white">
                        <%= link_to child.name, location_path(child), class: "hover:text-blue-600 dark:hover:text-blue-400" %>
                      </p>
                      <p class="text-xs text-gray-500 dark:text-gray-400">
                        <%= child.location_type.titleize %>
                      </p>
                    </div>
                  </div>
                  <div>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                      <%= child.active? ? 'bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300' : 'bg-red-100 dark:bg-red-900/40 text-red-800 dark:text-red-300' %>">
                      <%= child.active? ? 'Active' : 'Inactive' %>
                    </span>
                  </div>
                </li>
              <% end %>
            </ul>
          <% else %>
            <div class="text-center py-4">
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-indigo-100 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 mb-3">
                <i class="fas fa-sitemap"></i>
              </div>
              <p class="text-gray-500 dark:text-gray-400 text-sm mb-3">No child locations found</p>
              <%= link_to new_location_path(parent_id: @location.id), class: "inline-flex items-center text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 text-sm font-medium" do %>
                <i class="fas fa-plus mr-1"></i> Add Child Location
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Quick Facts Card -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
        <div class="bg-gradient-to-r from-green-600 to-green-700 px-5 py-4">
          <h2 class="text-lg font-semibold text-white flex items-center">
            <i class="fas fa-chart-pie mr-2"></i> Quick Facts
          </h2>
        </div>
        <div class="p-5 space-y-4">
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500 dark:text-gray-400">Created</span>
            <span class="text-sm font-medium text-gray-900 dark:text-white"><%= @location.created_at.strftime("%b %d, %Y") %></span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500 dark:text-gray-400">Last Updated</span>
            <span class="text-sm font-medium text-gray-900 dark:text-white"><%= @location.updated_at.strftime("%b %d, %Y") %></span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500 dark:text-gray-400">Child Locations</span>
            <span class="text-sm font-medium text-gray-900 dark:text-white"><%= @location.child_locations.count %></span>
          </div>
          <!-- This will be filled when we implement inventory -->
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500 dark:text-gray-400">Inventory Items</span>
            <span class="text-sm font-medium text-gray-900 dark:text-white">0</span>
          </div>
        </div>
      </div>

      <!-- Actions Card -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
        <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-5 py-4">
          <h2 class="text-lg font-semibold text-white flex items-center">
            <i class="fas fa-bolt mr-2"></i> Quick Actions
          </h2>
        </div>
        <div class="p-5 grid grid-cols-1 gap-3">
          <%= link_to edit_location_path(@location), class: "w-full flex items-center p-3 bg-gray-50 dark:bg-gray-700 rounded-lg hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors duration-150" do %>
            <div class="h-8 w-8 rounded-full bg-blue-100 dark:bg-blue-900/40 flex items-center justify-center text-blue-600 dark:text-blue-400 mr-3">
              <i class="fas fa-edit"></i>
            </div>
            <span class="text-sm font-medium text-gray-900 dark:text-white">Edit Location</span>
          <% end %>
          <%= link_to new_location_path(parent_id: @location.id), class: "w-full flex items-center p-3 bg-gray-50 dark:bg-gray-700 rounded-lg hover:bg-indigo-50 dark:hover:bg-indigo-900/20 transition-colors duration-150" do %>
            <div class="h-8 w-8 rounded-full bg-indigo-100 dark:bg-indigo-900/40 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mr-3">
              <i class="fas fa-plus"></i>
            </div>
            <span class="text-sm font-medium text-gray-900 dark:text-white">Add Child Location</span>
          <% end %>
          <!-- These links will be implemented with inventory functionality -->
          <button disabled class="w-full flex items-center p-3 bg-gray-50 dark:bg-gray-700 rounded-lg opacity-50 cursor-not-allowed">
            <div class="h-8 w-8 rounded-full bg-green-100 dark:bg-green-900/40 flex items-center justify-center text-green-600 dark:text-green-400 mr-3">
              <i class="fas fa-box"></i>
            </div>
            <span class="text-sm font-medium text-gray-900 dark:text-white">Add Inventory (Coming Soon)</span>
          </button>
          <button disabled class="w-full flex items-center p-3 bg-gray-50 dark:bg-gray-700 rounded-lg opacity-50 cursor-not-allowed">
            <div class="h-8 w-8 rounded-full bg-amber-100 dark:bg-amber-900/40 flex items-center justify-center text-amber-600 dark:text-amber-400 mr-3">
              <i class="fas fa-exchange-alt"></i>
            </div>
            <span class="text-sm font-medium text-gray-900 dark:text-white">Transfer Stock (Coming Soon)</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>