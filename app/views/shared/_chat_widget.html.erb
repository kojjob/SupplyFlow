<%# Chat Widget Partial %>
<div data-controller="chat-widget" class="fixed inset-0 z-[1000] bg-black/50 backdrop-blur-sm hidden" data-chat-widget-target="overlay">
  <%# Mobile Chat Container %>
  <div class="md:hidden absolute bottom-0 left-0 right-0 w-full bg-white dark:bg-gray-800 rounded-t-xl shadow-2xl overflow-hidden flex flex-col transition-all duration-300 transform translate-y-full" data-chat-widget-target="mobileContainer">
    <%# Chat Header %>
    <div class="bg-gradient-to-r from-[#0055A4] to-[#00A86B] p-4 flex items-center justify-between text-white">
      <div class="flex items-center">
        <div class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center mr-3">
          <i class="fas fa-headset text-lg"></i>
        </div>
        <div>
          <h3 class="font-bold">SupplyFlow Support</h3>
          <p class="text-xs text-white/80">We typically reply within minutes</p>
        </div>
      </div>
      <button data-action="chat-widget#close" class="w-8 h-8 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors duration-200">
        <i class="fas fa-times"></i>
      </button>
    </div>

    <%# Chat Messages %>
    <div class="flex-1 p-4 overflow-y-auto max-h-96" data-chat-widget-target="messages">
      <%# Welcome Message %>
      <div class="flex mb-4">
        <div class="w-8 h-8 rounded-full bg-[#0055A4] flex items-center justify-center text-white mr-2 flex-shrink-0">
          <i class="fas fa-headset text-sm"></i>
        </div>
        <div class="bg-gray-100 dark:bg-gray-700 rounded-lg p-3 max-w-[80%]">
          <p class="text-gray-800 dark:text-white text-sm">Hello! 👋 Welcome to SupplyFlow support. How can we help you today?</p>
          <span class="text-xs text-gray-500 dark:text-gray-400 mt-1 block">Just now</span>
        </div>
      </div>

      <%# Quick Reply Options %>
      <div class="flex flex-wrap gap-2 mb-4 ml-10">
        <button data-action="chat-widget#sendQuickReply" data-message="I need help with inventory management" class="bg-gray-100 dark:bg-gray-700 hover:bg-[#0055A4]/10 dark:hover:bg-[#0055A4]/20 text-gray-800 dark:text-white text-sm py-2 px-3 rounded-full transition-colors duration-200">
          Inventory Management
        </button>
        <button data-action="chat-widget#sendQuickReply" data-message="I have a billing question" class="bg-gray-100 dark:bg-gray-700 hover:bg-[#0055A4]/10 dark:hover:bg-[#0055A4]/20 text-gray-800 dark:text-white text-sm py-2 px-3 rounded-full transition-colors duration-200">
          Billing Question
        </button>
        <button data-action="chat-widget#sendQuickReply" data-message="I need technical support" class="bg-gray-100 dark:bg-gray-700 hover:bg-[#0055A4]/10 dark:hover:bg-[#0055A4]/20 text-gray-800 dark:text-white text-sm py-2 px-3 rounded-full transition-colors duration-200">
          Technical Support
        </button>
      </div>
    </div>

    <%# Chat Input %>
    <div class="p-4 border-t border-gray-200 dark:border-gray-700">
      <form data-action="submit->chat-widget#sendMessage" class="flex items-center">
        <input
          type="text"
          placeholder="Type your message..."
          class="flex-1 bg-gray-100 dark:bg-gray-700 border-none rounded-full py-2 px-4 text-gray-800 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-[#0055A4]"
          data-chat-widget-target="input"
        >
        <button type="submit" class="ml-2 w-10 h-10 rounded-full bg-[#00A86B] hover:bg-[#00965F] flex items-center justify-center text-white transition-colors duration-200">
          <i class="fas fa-paper-plane"></i>
        </button>
      </form>
      <div class="text-xs text-gray-500 dark:text-gray-400 mt-2 text-center">
        Our support team is available Monday-Friday, 8AM-5PM Ghana time
      </div>
    </div>
  </div>

  <%# Desktop Chat Container %>
  <div class="hidden md:flex absolute bottom-6 right-6 w-96 bg-white dark:bg-gray-800 rounded-xl shadow-2xl overflow-hidden flex-col transition-all duration-300 transform scale-0 opacity-0 origin-bottom-right" data-chat-widget-target="desktopContainer">
    <%# Chat Header %>
    <div class="bg-gradient-to-r from-[#0055A4] to-[#00A86B] p-4 flex items-center justify-between text-white">
