                <i class="fas fa-envelope mr-2 text-teal-400"></i>
                <span>Contact Us</span>
              </a>
              <a href="/support" class="block text-white/80 hover:text-white py-2 transition-all duration-200 hover:translate-x-2 flex items-center">
                <i class="fas fa-headset mr-2 text-teal-400"></i>
                <span>Support</span>
              </a>
              <a href="/documentation" class="block text-white/80 hover:text-white py-2 transition-all duration-200 hover:translate-x-2 flex items-center">
                <i class="fas fa-book mr-2 text-teal-400"></i>
                <span>Documentation</span>
              </a>
            </div>
          </div>
        </div>

        <div class="border-t border-white/10 my-4"></div>

        <%# Mobile Quick Actions with improved visual feedback %>
        <% if user_signed_in? %>
          <div data-controller="accordion">
            <button
              data-action="click->accordion#toggle"
              class="w-full text-white px-4 py-3 rounded-lg hover:bg-white/10 transition-all duration-200 flex items-center justify-between relative overflow-hidden group"
            >
              <div class="absolute inset-0 bg-white/0 group-hover:bg-white/10 rounded-lg transition-all duration-300"></div>
              <div class="flex items-center relative z-10">
                <i class="fas fa-bolt mr-3 w-6 text-center text-white/80 group-hover:text-white"></i>
                <span class="text-lg group-hover:translate-x-1 transition-transform duration-200">Quick Actions</span>
              </div>
              <i class="fas fa-chevron-down transition-transform duration-300 text-white/80 group-hover:text-white relative z-10" data-accordion-target="arrow"></i>
            </button>

            <div data-accordion-target="content" class="overflow-hidden max-h-0 transition-all duration-300">
              <div class="pl-12 pr-4 py-2">
                <!-- Inventory Section -->
                <p class="text-white/60 text-sm uppercase tracking-wider py-1">Inventory</p>
                <div class="space-y-2 mb-3">
                  <button
                    onclick="window.ModalHelpers.showProductModal()"
                    class="block text-blue-400 hover:text-blue-300 py-3 transition-all duration-200 w-full text-left group"
                  >
                    <div class="flex items-center">
                      <div class="w-8 h-8 rounded-full bg-blue-900/30 flex items-center justify-center text-blue-400 mr-3 group-hover:scale-110 transition-transform duration-200">
                        <i class="fas fa-box-open"></i>
                      </div>
                      <span class="group-hover:translate-x-1 transition-transform duration-200">New Product</span>
                    </div>
                  </button>

                  <button
                    onclick="window.ModalHelpers.showInventoryModal()"
                    class="block text-blue-400 hover:text-blue-300 py-3 transition-all duration-200 w-full text-left group"
                  >
                    <div class="flex items-center">
                      <div class="w-8 h-8 rounded-full bg-blue-900/30 flex items-center justify-center text-blue-400 mr-3 group-hover:scale-110 transition-transform duration-200">
                        <i class="fas fa-exchange-alt"></i>
                      </div>
                      <span class="group-hover:translate-x-1 transition-transform duration-200">Transfer Inventory</span>
                    </div>
                  </button>

                  <button
                    onclick="window.ModalHelpers.showLocationModal()"
                    class="block text-blue-400 hover:text-blue-300 py-3 transition-all duration-200 w-full text-left group"
                  >
                    <div class="flex items-center">
                      <div class="w-8 h-8 rounded-full bg-blue-900/30 flex items-center justify-center text-blue-400 mr-3 group-hover:scale-110 transition-transform duration-200">
                        <i class="fas fa-map-marker-alt"></i>
                      </div>
                      <span class="group-hover:translate-x-1 transition-transform duration-200">New Location</span>
                    </div>
                  </button>
                </div>

                <!-- Orders Section -->
                <p class="text-white/60 text-sm uppercase tracking-wider py-1">Orders</p>
                <div class="space-y-2">
                  <%= link_to new_supplier_path, class: "block text-green-400 hover:text-green-300 py-3 transition-all duration-200 group" do %>
                    <div class="flex items-center">
                      <div class="w-8 h-8 rounded-full bg-green-900/30 flex items-center justify-center text-green-400 mr-3 group-hover:scale-110 transition-transform duration-200">
                        <i class="fas fa-building"></i>
                      </div>
                      <span class="group-hover:translate-x-1 transition-transform duration-200">New Supplier</span>
                    </div>
                  <% end %>

                  <%= link_to new_customer_path, class: "block text-green-400 hover:text-green-300 py-3 transition-all duration-200 group" do %>
                    <div class="flex items-center">
                      <div class="w-8 h-8 rounded-full bg-green-900/30 flex items-center justify-center text-green-400 mr-3 group-hover:scale-110 transition-transform duration-200">
                        <i class="fas fa-users"></i>
                      </div>
                      <span class="group-hover:translate-x-1 transition-transform duration-200">New Customer</span>
                    </div>
                  <% end %>

                  <%= link_to new_purchase_order_path, class: "block text-green-400 hover:text-green-300 py-3 transition-all duration-200 group" do %>
                    <div class="flex items-center">
                      <div class="w-8 h-8 rounded-full bg-green-900/30 flex items-center justify-center text-green-400 mr-3 group-hover:scale-110 transition-transform duration-200">
                        <i class="fas fa-shopping-cart"></i>
                      </div>
                      <span class="group-hover:translate-x-1 transition-transform duration-200">New Purchase Order</span>
                    </div>
                  <% end %>

                  <%= link_to new_sales_order_path, class: "block text-green-400 hover:text-green-300 py-3 transition-all duration-200 group" do %>
                    <div class="flex items-center">
                      <div class="w-8 h-8 rounded-full bg-green-900/30 flex items-center justify-center text-green-400 mr-3 group-hover:scale-110 transition-transform duration-200">
                        <i class="fas fa-file-invoice-dollar"></i>
                      </div>
                      <span class="group-hover:translate-x-1 transition-transform duration-200">New Sales Order</span>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>

          <%# Profile link for logged in users with enhanced transitions %>
          <%= link_to settings_profile_path, class: "text-white px-4 py-3 rounded-lg hover:bg-white/10 transition-all duration-200 flex items-center relative overflow-hidden group" do %>
            <div class="absolute inset-0 bg-white/0 group-hover:bg-white/10 rounded-lg transition-all duration-300"></div>
            <i class="fas fa-user mr-3 w-6 text-center text-white/80 group-hover:text-white relative z-10"></i>
            <span class="text-lg relative z-10 group-hover:translate-x-1 transition-transform duration-200">Your Profile</span>
          <% end %>

          <a href="#" class="text-white px-4 py-3 rounded-lg hover:bg-white/10 transition-all duration-200 flex items-center relative overflow-hidden group">
            <div class="absolute inset-0 bg-white/0 group-hover:bg-white/10 rounded-lg transition-all duration-300"></div>
            <i class="fas fa-bell mr-3 w-6 text-center text-white/80 group-hover:text-white relative z-10"></i>
            <span class="text-lg relative z-10 group-hover:translate-x-1 transition-transform duration-200">Notifications</span>
            <span class="ml-auto bg-orange-500 text-white text-xs px-2 py-1 rounded-full relative z-10 animate-pulse-slow">3</span>
          </a>

          <%# Logout link for mobile with enhanced transitions %>
          <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "text-white px-4 py-3 rounded-lg hover:bg-red-500/20 transition-all duration-200 flex items-center relative overflow-hidden group" do %>
            <div class="absolute inset-0 bg-red-500/0 group-hover:bg-red-500/10 rounded-lg transition-all duration-300"></div>
            <i class="fas fa-sign-out-alt mr-3 w-6 text-center text-red-300 relative z-10"></i>
            <span class="text-lg relative z-10 group-hover:translate-x-1 transition-transform duration-200">Sign Out</span>
          <% end %>
        <% else %>
          <%# Login/Register links for logged out users with enhanced transitions %>
          <%= link_to new_user_session_path, class: "text-white px-4 py-3 rounded-lg hover:bg-white/10 transition-all duration-200 flex items-center relative overflow-hidden group" do %>
            <div class="absolute inset-0 bg-white/0 group-hover:bg-white/10 rounded-lg transition-all duration-300"></div>
            <i class="fas fa-sign-in-alt mr-3 w-6 text-center text-white/80 group-hover:text-white relative z-10"></i>
            <span class="text-lg relative z-10 group-hover:translate-x-1 transition-transform duration-200">Login</span>
          <% end %>

          <%= link_to new_user_registration_path, class: "text-white px-4 py-3 rounded-lg hover:bg-white/10 transition-all duration-200 flex items-center relative overflow-hidden group" do %>
            <div class="absolute inset-0 bg-white/0 group-hover:bg-white/10 rounded-lg transition-all duration-300"></div>
            <i class="fas fa-user-plus mr-3 w-6 text-center text-white/80 group-hover:text-white relative z-10"></i>
            <span class="text-lg relative z-10 group-hover:translate-x-1 transition-transform duration-200">Sign Up</span>
          <% end %>
        <% end %>

        <div class="border-t border-white/10 my-4"></div>

        <%# Mobile Theme Toggle with enhanced visual feedback %>
        <div class="px-4 py-3">
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <i class="fas fa-adjust mr-3 w-6 text-center text-white"></i>
              <span class="text-lg text-white">Theme</span>
            </div>

            <button
              data-action="click->theme#toggle"
              class="relative w-14 h-7 bg-white/10 rounded-full p-1 transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-white/20 overflow-hidden group"
            >
              <div class="absolute inset-0 bg-gradient-to-r from-amber-300/0 to-blue-500/0 group-hover:from-amber-300/20 group-hover:to-blue-500/20 transition-colors duration-300"></div>
              <div class="absolute left-1 top-1 w-5 h-5 rounded-full transition-all duration-300 transform flex items-center justify-center">
                <i
                  data-theme-target="mobileSunIcon"
                  class="fas fa-sun text-xs text-amber-400 group-hover:rotate-45 transition-transform duration-300"
                  aria-hidden="true"
                ></i>
                <i
                  data-theme-target="mobileMoonIcon"
                  class="fas fa-moon text-xs text-blue-200 hidden group-hover:scale-110 transition-transform duration-300"
                  aria-hidden="true"
                ></i>
              </div>

              <div class="dark:bg-blue-600 bg-amber-400 absolute inset-0 rounded-full transition-opacity duration-300 opacity-0 dark:opacity-100"></div>
              <div class="dark:translate-x-7 translate-x-0 absolute left-1 top-1 w-5 h-5 bg-white rounded-full transition-all duration-300 transform shadow-md flex items-center justify-center"></div>
            </button>
          </div>

          <div class="mt-2 text-white/60 text-sm pl-9">
            <span class="dark:hidden">Light mode active</span>
            <span class="hidden dark:inline">Dark mode active</span>
          </div>
        </div>

        <div class="border-t border-white/10 my-4"></div>

        <%# Mobile CTA or Dashboard Button with enhanced transitions %>
        <% if user_signed_in? %>
          <a href="/dashboard" class="relative overflow-hidden px-4 py-4 rounded-lg bg-gradient-to-r from-indigo-500 to-purple-600 hover:from-indigo-400 hover:to-purple-500 text-white shadow-lg hover:shadow-xl transition-all duration-300 flex items-center justify-center group">
            <div class="absolute inset-0 bg-white/0 group-hover:bg-white/10 rounded-lg transition-all duration-300"></div>
            <div class="absolute inset-0 overflow-hidden opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="absolute top-1 left-4 w-px h-1 bg-white animate-pulse"></div>
              <div class="absolute bottom-2 right-20 w-1 h-px bg-white animate-pulse-slow"></div>
              <div class="absolute top-5 right-10 w-px h-2 bg-white animate-pulse-slow"></div>
            </div>
            <i class="fas fa-th-large mr-2 relative z-10 group-hover:rotate-12 transition-transform duration-300"></i>
            <span class="text-lg relative z-10">Go to Dashboard</span>
          </a>
        <% else %>
          <%= link_to new_user_registration_path, class: "relative overflow-hidden px-4 py-4 rounded-lg bg-gradient-to-r from-indigo-500 to-purple-600 hover:from-indigo-400 hover:to-purple-500 text-white shadow-lg hover:shadow-xl transition-all duration-300 flex items-center justify-center group" do %>
            <div class="absolute inset-0 bg-white/0 group-hover:bg-white/10 rounded-lg transition-all duration-300"></div>
            <div class="absolute inset-0 overflow-hidden opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="absolute top-1 left-4 w-px h-1 bg-white animate-pulse"></div>
              <div class="absolute bottom-2 right-20 w-1 h-px bg-white animate-pulse-slow"></div>
              <div class="absolute top-5 right-10 w-px h-2 bg-white animate-pulse-slow"></div>
            </div>
            <i class="fas fa-rocket mr-2 relative z-10 group-hover:translate-x-1 group-hover:translate-y-[-2px] transition-transform duration-300"></i>
            <span class="text-lg relative z-10">Get Started</span>
          <% end %>
        <% end %>
      </nav>
    </div>
  </div>
</div>

<%# Spacer to prevent content from being hidden under fixed navbar %>
<div class="h-16"></div>

<%# Swipe right indicator with enhanced visibility - only visible on mobile %>
<div class="fixed left-0 top-1/2 -translate-y-1/2 z-30 lg:hidden">
  <div class="bg-gradient-to-r from-indigo-600 to-indigo-500/80 text-white py-2 px-3 rounded-r-lg shadow-lg transform -translate-x-full hover:translate-x-0 transition-all duration-300 group">
    <div class="flex items-center">
      <i class="fas fa-chevron-right mr-2 group-hover:animate-pulse"></i>
      <span class="text-xs whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity duration-300">Swipe right to open menu</span>
    </div>
  </div>
</div>

<%# Mobile Bottom Navigation Bar - Keep the mobile nav component but with enhanced styling %>
<div data-controller="swipe-gesture" class="fixed bottom-0 left-0 right-0 z-40 lg:hidden">
  <div class="bg-gradient-to-r from-indigo-600 to-blue-600 dark:from-gray-900 dark:to-indigo-900 shadow-lg border-t border-indigo-700/50 dark:border-gray-800 backdrop-blur-lg bg-opacity-95 dark:bg-opacity-95">
    <div class="grid grid-cols-5 h-16">
      <%# Home with enhanced animations %>
      <a href="/" class="flex flex-col items-center justify-center text-center px-2 py-1 <%= active_link?('/', exact: true) ? 'text-white font-medium' : 'text-white/80 dark:text-gray-300' %> group">
        <div class="<%= active_link?('/', exact: true) ? 'bg-white/20 dark:bg-indigo-800/40' : 'bg-white/10 dark:bg-gray-800/80' %> w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300 group-hover:scale-110 group-hover:shadow-md">
          <i class="fas fa-home text-lg text-white"></i>
        </div>
        <span class="text-xs mt-1 font-medium transition-all duration-200 group-hover:scale-105">Home</span>
      </a>

      <%# Search with enhanced animations %>
      <button
        data-action="click->search#toggle"
        class="flex flex-col items-center justify-center text-center px-2 py-1 text-white/80 hover:text-white dark:text-gray-300 group"
      >
        <div class="w-10 h-10 rounded-full flex items-center justify-center bg-white/10 dark:bg-gray-800/80 transition-all duration-300 group-hover:scale-110 group-hover:shadow-md group-hover:bg-white/20 dark:group-hover:bg-gray-700">
          <i class="fas fa-search text-lg text-white"></i>
        </div>
        <span class="text-xs mt-1 font-medium transition-all duration-200 group-hover:scale-105">Search</span>
      </button>

      <%# Main Action - Orders with enhanced animations %>
      <a href="<%= suppliers_path %>" class="flex flex-col items-center justify-center text-center px-2 py-1 group">
        <div class="bg-white w-12 h-12 rounded-full flex items-center justify-center shadow-lg -mt-5 text-primary relative overflow-hidden group-hover:scale-110 transition-all duration-300 group-hover:shadow-xl">
          <div class="absolute inset-0 bg-gradient-to-br from-white to-white/80 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <i class="fas fa-shopping-cart text-lg relative z-10"></i>
        </div>
        <span class="text-xs mt-1 font-medium text-white dark:text-gray-300 transition-all duration-200 group-hover:scale-105">Orders</span>
      </a>

      <%# Notifications with enhanced animations %>
      <div data-controller="notification" class="relative">
        <button
          data-action="click->notification#toggle"
          class="flex flex-col items-center justify-center text-center px-2 py-1 text-white/80 hover:text-white dark:text-gray-300 relative group"
        >
          <div class="w-10 h-10 rounded-full flex items-center justify-center bg-white/10 dark:bg-gray-800/80 transition-all duration-300 group-hover:scale-110 group-hover:shadow-md group-hover:bg-white/20 dark:group-hover:bg-gray-700">
            <i class="fas fa-bell text-lg text-white"></i>
            <span class="absolute top-1 right-1 bg-orange-500 text-white text-xs w-4 h-4 flex items-center justify-center rounded-full shadow-md animate-pulse-slow">3</span>
          </div>
          <span class="text-xs mt-1 font-medium transition-all duration-200 group-hover:scale-105">Alerts</span>
        </button>

        <!-- Mobile Notification Dropdown with enhanced visual effects -->
        <div
          data-notification-target="dropdown"
          class="absolute bottom-24 right-0 w-80 bg-white dark:bg-gray-800 rounded-xl shadow-lg z-50 scale-0 opacity-0 origin-bottom-right transition-all duration-300 ease-in-out transform border-2 border-indigo-600/30 dark:border-indigo-700/50 overflow-hidden"
          style="transform: scale(0);"
        >
          <!-- Notification Header with animation -->
          <div class="relative overflow-hidden">
            <!-- Background Animation -->
            <div class="absolute inset-0 bg-gradient-to-r from-blue-600 to-indigo-600 opacity-90"></div>
            <div class="absolute inset-0 bg-pattern opacity-20"></div>
            <div class="absolute inset-0 bg-gradient-to-r from-blue-600/0 via-indigo-500/30 to-blue-600/0 opacity-30 animate-pulse-slow"></div>

            <!-- Header Content -->
            <div class="relative p-4">
              <div class="flex justify-between items-center">
                <div class="flex items-center">
                  <div class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center text-white mr-3 shadow-md">
                    <i class="fas fa-bell text-xl"></i>
                  </div>
                  <h3 class="text-xl font-bold text-white">Notifications</h3>
                </div>
                <div class="flex items-center space-x-2">
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-white text-indigo-700 shadow-sm">
                    3 new
                  </span>
                  <button
                    class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center text-white hover:bg-white/30 transition-colors duration-200 hover:rotate-90 transform transition-transform"
                    data-action="click->notification#close"
                  >
                    <i class="fas fa-times"></i>
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Notification Tabs with enhanced transitions -->
          <div class="flex border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
            <button class="flex-1 py-3 px-4 text-center text-sm font-medium text-indigo-600 dark:text-indigo-400 border-b-2 border-indigo-600 dark:border-indigo-400 relative overflow-hidden group">
              <div class="absolute inset-0 bg-indigo-500/0 group-hover:bg-indigo-500/5 transition-colors duration-300"></div>
              <span class="relative z-10">All</span>
            </button>
            <button class="flex-1 py-3 px-4 text-center text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 relative overflow-hidden group">
              <div class="absolute inset-0 bg-indigo-500/0 group-hover:bg-indigo-500/5 transition-colors duration-300"></div>
              <span class="relative z-10">Unread</span>
            </button>
            <button class="flex-1 py-3 px-4 text-center text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 relative overflow-hidden group">
              <div class="absolute inset-0 bg-indigo-500/0 group-hover:bg-indigo-500/5 transition-colors duration-300"></div>
              <span class="relative z-10">Important</span>
            </button>
          </div>

          <!-- Notification List with enhanced hover effects -->
          <div class="max-h-96 overflow-y-auto">
            <!-- Today Section -->
            <div class="px-4 py-2 bg-gray-50 dark:bg-gray-700/30 text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              Today
            </div>

            <!-- Notification Item 1 with enhanced transitions -->
            <div class="p-4 border-b border-gray-100 dark:border-gray-700 hover:bg-blue-50 dark:hover:bg-blue-900/10 transition-all duration-200 relative overflow-hidden group">
              <div class="absolute inset-0 bg-blue-500/0 group-hover:bg-blue-500/5 transition-colors duration-300"></div>
              <div class="flex relative z-10">
                <div class="flex-shrink-0 mr-4">
                  <div class="w-12 h-12 rounded-full bg-blue-500 flex items-center justify-center text-white shadow-md group-hover:scale-110 transition-transform duration-300">
                    <i class="fas fa-box text-lg"></i>
                  </div>
                </div>
                <div class="flex-1">
                  <div class="flex justify-between items-start">
                    <p class="font-medium text-gray-800 dark:text-gray-200 group-hover:translate-x-1 transition-transform duration-200">New shipment created</p>
                    <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300">
                      New
                    </span>
                  </div>
                  <p class="text-sm text-gray-600 dark:text-gray-400 mt-1 group-hover:translate-x-1 transition-transform duration-200">Your order #12345 has been shipped and is on its way to you.</p>
                  <div class="mt-2 flex justify-between items-center">
                    <p class="text-xs text-gray-500 dark:text-gray-500">5 minutes ago</p>
                    <button class="text-xs text-gray-400 hover:text-gray-500 dark:text-gray-500 dark:hover:text-gray-400 hover:scale-125 transition-transform duration-200">
                      <i class="fas fa-times"></i>
                    </button>
                  </div>
                </div>
              </div>
            </div>

            <!-- Notification Item 2 with enhanced transitions -->
            <div class="p-4 border-b border-gray-100 dark:border-gray-700 hover:bg-green-50 dark:hover:bg-green-900/10 transition-all duration-200 relative overflow-hidden group">
              <div class="absolute inset-0 bg-green-500/0 group-hover:bg-green-500/5 transition-colors duration-300"></div>
              <div class="flex relative z-10">
                <div class="flex-shrink-0 mr-4">
                  <div class="w-12 h-12 rounded-full bg-green-500 flex items-center justify-center text-white shadow-md group-hover:scale-110 transition-transform duration-300">
                    <i class="fas fa-check text-lg"></i>
                  </div>
                </div>
                <div class="flex-1">
                  <div class="flex justify-between items-start">
                    <p class="font-medium text-gray-800 dark:text-gray-200 group-hover:translate-x-1 transition-transform duration-200">Inventory updated</p>
                    <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/50 dark:text-green-300">
                      Success
                    </span>
                  </div>
                  <p class="text-sm text-gray-600 dark:text-gray-400 mt-1 group-hover:translate-x-1 transition-transform duration-200">Inventory levels have been updated successfully across all warehouses.</p>
                  <div class="mt-2 flex justify-between items-center">
                    <p class="text-xs text-gray-500 dark:text-gray-500">1 hour ago</p>
                    <button class="text-xs text-gray-400 hover:text-gray-500 dark:text-gray-500 dark:hover:text-gray-400 hover:scale-125 transition-transform duration-200">
                      <i class="fas fa-times"></i>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Footer with enhanced transitions -->
          <div class="p-4 bg-gradient-to-r from-gray-50 to-gray-100 dark:from-gray-800 dark:to-gray-900 border-t border-gray-200 dark:border-gray-700 relative overflow-hidden">
            <div class="absolute inset-0 bg-pattern opacity-5"></div>
            <div class="relative flex justify-between items-center">
              <a href="#" class="text-indigo-600 hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300 text-sm font-medium transition-all duration-200 hover:translate-x-1">
                View all notifications
              </a>
              <button class="px-3 py-1 bg-indigo-100 hover:bg-indigo-200 dark:bg-indigo-900/30 dark:hover:bg-indigo-800/40 text-indigo-600 dark:text-indigo-400 text-xs font-medium rounded-lg transition-all duration-200 hover:shadow-md">
                Mark all as read
              </button>
            </div>
          </div>
        </div>
      </div>

      <%# Account with enhanced animations - Shows image if available, otherwise shows initials %>
      <% if user_signed_in? %>
        <%= link_to settings_profile_path, class: "flex flex-col items-center justify-center text-center px-2 py-1 text-white/80 hover:text-white dark:text-gray-300 group" do %>
          <div class="w-10 h-10 rounded-full flex items-center justify-center overflow-hidden border-2 border-white/30 dark:border-gray-700 group-hover:border-white/60 dark:group-hover:border-gray-500 transition-all duration-300 bg-gradient-to-br from-indigo-600 to-purple-600 group-hover:scale-110 group-hover:shadow-md">
            <% if current_user.has_avatar? %>
              <%= image_tag current_user.avatar_url, alt: current_user.name, class: "w-full h-full object-cover" %>
            <% else %>
              <span class="text-white font-bold text-sm"><%= current_user.name.first(2).upcase %></span>
            <% end %>
          </div>
          <span class="text-xs mt-1 font-medium transition-all duration-200 group-hover:scale-105">Account</span>
        <% end %>
      <% else %>
        <%= link_to new_user_session_path, class: "flex flex-col items-center justify-center text-center px-2 py-1 text-white/80 hover:text-white dark:text-gray-300 group" do %>
          <div class="w-10 h-10 rounded-full flex items-center justify-center overflow-hidden border-2 border-white/30 dark:border-gray-700 group-hover:border-white/60 dark:group-hover:border-gray-500 transition-all duration-300 bg-gradient-to-br from-indigo-600 to-purple-600 group-hover:scale-110 group-hover:shadow-md">
            <span class="text-white font-bold text-sm">SU</span>
          </div>
          <span class="text-xs mt-1 font-medium transition-all duration-200 group-hover:scale-105">Sign In</span>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<%# Spacer to prevent content from being hidden under fixed bottom navbar %>
<div class="h-16 lg:h-0"></div>