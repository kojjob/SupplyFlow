<div data-controller="navbar swipe-gesture" class="relative">
  <%# Desktop & Mobile Navigation %>
  <header class="bg-gradient-to-r from-indigo-600 to-sky-700 dark:from-gray-900 dark:to-indigo-900 fixed top-0 left-0 right-0 z-50 backdrop-blur-lg shadow-lg transition-colors duration-300" role="banner">
    <div class="container mx-auto px-4">
      <nav class="py-3" aria-label="Main Navigation">
        <div class="flex items-center justify-between">
          <%# Logo with enhanced animation %>
          <div class="flex items-center">
            <a href="/" class="text-2xl font-bold flex items-center group" aria-label="SupplyFlow Home">
              <div class="relative overflow-hidden bg-white text-primary rounded-full w-10 h-10 flex items-center justify-center mr-3 shadow-lg group-hover:scale-110 transition-all duration-300">
                <i class="fas fa-box-open text-xl z-10 relative"></i>
                <div class="absolute inset-0 bg-gradient-to-r from-indigo-100 to-blue-100 dark:from-indigo-200 dark:to-blue-200 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              </div>
              <div class="relative overflow-hidden">
                <span class="text-white font-bold group-hover:translate-y-[-100%] inline-block transition-transform duration-300">SupplyFlow</span>
                <span class="text-white font-bold absolute top-0 left-0 translate-y-[100%] group-hover:translate-y-0 transition-transform duration-300">SupplyFlow</span>
              </div>
            </a>
          </div>

          <%# Desktop Navigation - Hidden on mobile %>
          <div class="hidden lg:flex items-center space-x-1">
            <%# Regular Nav Items %>
            <a href="/" class="<%= active_link_class('/', exact: true, active_class: 'bg-white/20 text-white font-medium', inactive_class: 'text-white/90 hover:text-white hover:bg-white/10') %> px-3 py-2 rounded-lg transition-all duration-200 flex items-center relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-r from-white/0 to-white/0 hover:from-white/5 hover:to-white/10 transition-all duration-300"></div>
              <i class="fas fa-home mr-2 relative z-10" aria-hidden="true"></i>
              <span class="relative z-10">Home</span>
              <% if active_link?('/', exact: true) %>
                <span class="ml-2 w-1.5 h-1.5 rounded-full bg-white relative z-10"></span>
              <% end %>
            </a>

            <%# Dashboard Dropdown with enhanced styling %>
            <div data-controller="dropdown" class="relative">
              <button
                data-action="click->dropdown#toggle click@window->dropdown#hide keydown->dropdown#handleKeydown"
                data-dropdown-target="button"
                class="<%= active_link_class(['/dashboard', '/products', '/inventory', '/locations', '/reports', '/suppliers', '/customers', '/purchase_orders', '/sales_orders', '/payments'], active_class: 'bg-white/20 text-white font-medium', inactive_class: 'text-white/90 hover:text-white hover:bg-white/10') %> px-3 py-2 rounded-lg transition-all duration-200 flex items-center relative overflow-hidden"
                aria-expanded="false"
                aria-haspopup="true"
                aria-controls="dashboard-dropdown-menu"
              >
                <div class="absolute inset-0 bg-gradient-to-r from-white/0 to-white/0 hover:from-white/5 hover:to-white/10 transition-all duration-300"></div>
                <i class="fas fa-th-large mr-2 relative z-10" aria-hidden="true"></i>
                <span class="relative z-10">Dashboard</span>
                <i class="fas fa-chevron-down ml-2 text-xs transition-transform duration-200 relative z-10" data-dropdown-target="arrow" aria-hidden="true"></i>
                <% if active_link?(['/dashboard', '/products', '/inventory', '/locations', '/reports', '/suppliers', '/customers', '/purchase_orders', '/sales_orders', '/payments']) %>
                  <span class="ml-2 w-1.5 h-1.5 rounded-full bg-white relative z-10"></span>
                <% end %>
              </button>

              <div
                id="dashboard-dropdown-menu"
                data-dropdown-target="menu"
                class="absolute left-0 mt-3 w-80 rounded-xl shadow-2xl bg-white dark:bg-gray-800 ring-1 ring-black ring-opacity-5 overflow-hidden z-50 transform origin-top-left transition-all duration-200 scale-95 opacity-0 invisible"
                role="menu"
                aria-orientation="vertical"
                aria-labelledby="dashboard-dropdown-button"
              >
                <!-- Header with updated animation -->
                <div class="relative overflow-hidden">
                  <!-- Background Pattern with animation -->
                  <div class="absolute inset-0 bg-gradient-to-r from-indigo-600 to-blue-600 opacity-90"></div>
                  <div class="absolute inset-0 bg-pattern opacity-20"></div>
                  <div class="absolute inset-0 bg-gradient-to-r from-indigo-600/0 via-blue-500/30 to-indigo-600/0 opacity-30 animate-pulse-slow"></div>

                  <!-- Header Content -->
                  <div class="relative p-4">
                    <div class="flex items-center justify-between">
                      <div class="flex items-center">
                        <div class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center text-white mr-3 shadow-md">
                          <i class="fas fa-th-large text-xl"></i>
                        </div>
                        <div>
                          <h3 class="text-xl font-bold text-white">Dashboard</h3>
                          <p class="text-xs text-blue-100">Manage your business</p>
                        </div>
                      </div>
                      <% if user_signed_in? && current_user.organization.present? %>
                        <div class="bg-white/20 px-3 py-1 rounded-lg backdrop-blur-sm">
                          <span class="text-xs font-medium text-white"><%= current_user.organization.name %></span>
                        </div>
                      <% end %>
                    </div>
                  </div>
                </div>

                <!-- Menu Items with enhanced visual feedback -->
                <div class="py-2 px-1">
                  <!-- Inventory Section -->
                  <div class="px-4 py-2">
                    <h4 class="text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wider mb-2">Inventory</h4>
                    <div class="grid grid-cols-2 gap-2">
                      <%= link_to products_path, class: "flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg transition-all duration-200 group relative overflow-hidden" do %>
                        <div class="absolute inset-0 bg-blue-500/0 group-hover:bg-blue-500/5 transition-colors duration-300"></div>
                        <div class="w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center text-blue-600 dark:text-blue-400 mr-2 group-hover:bg-blue-200 dark:group-hover:bg-blue-800/50 transition-colors duration-200 relative">
                          <i class="fas fa-cubes text-sm"></i>
                        </div>
                        <span class="font-medium text-sm relative z-10">Products</span>
                      <% end %>
                      
                      <%= link_to inventory_path, class: "flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg transition-all duration-200 group relative overflow-hidden" do %>
                        <div class="absolute inset-0 bg-blue-500/0 group-hover:bg-blue-500/5 transition-colors duration-300"></div>
                        <div class="w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center text-blue-600 dark:text-blue-400 mr-2 group-hover:bg-blue-200 dark:group-hover:bg-blue-800/50 transition-colors duration-200 relative">
                          <i class="fas fa-exchange-alt text-sm"></i>
                        </div>
                        <span class="font-medium text-sm relative z-10">Inventory</span>
                      <% end %>
                      
                      <%= link_to locations_path, class: "flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg transition-all duration-200 group relative overflow-hidden" do %>
                        <div class="absolute inset-0 bg-blue-500/0 group-hover:bg-blue-500/5 transition-colors duration-300"></div>
                        <div class="w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center text-blue-600 dark:text-blue-400 mr-2 group-hover:bg-blue-200 dark:group-hover:bg-blue-800/50 transition-colors duration-200 relative">
                          <i class="fas fa-map-marker-alt text-sm"></i>
                        </div>
                        <span class="font-medium text-sm relative z-10">Locations</span>
                      <% end %>
                    </div>
                  </div>

                  <!-- Order Management Section -->
                  <div class="px-4 py-2 mt-4">
                    <h4 class="text-xs font-semibold text-green-600 dark:text-green-400 uppercase tracking-wider mb-2">Order Management</h4>
                    <div class="grid grid-cols-2 gap-2">
                      <%= link_to suppliers_path, class: "flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-green-50 dark:hover:bg-green-900/20 rounded-lg transition-all duration-200 group relative overflow-hidden" do %>
                        <div class="absolute inset-0 bg-green-500/0 group-hover:bg-green-500/5 transition-colors duration-300"></div>
                        <div class="w-8 h-8 rounded-full bg-green-100 dark:bg-green-900/50 flex items-center justify-center text-green-600 dark:text-green-400 mr-2 group-hover:bg-green-200 dark:group-hover:bg-green-800/50 transition-colors duration-200 relative">
                          <i class="fas fa-building text-sm"></i>
                        </div>
                        <span class="font-medium text-sm relative z-10">Suppliers</span>
                      <% end %>

                      <%= link_to customers_path, class: "flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-green-50 dark:hover:bg-green-900/20 rounded-lg transition-all duration-200 group relative overflow-hidden" do %>
                        <div class="absolute inset-0 bg-green-500/0 group-hover:bg-green-500/5 transition-colors duration-300"></div>
                        <div class="w-8 h-8 rounded-full bg-green-100 dark:bg-green-900/50 flex items-center justify-center text-green-600 dark:text-green-400 mr-2 group-hover:bg-green-200 dark:group-hover:bg-green-800/50 transition-colors duration-200 relative">
                          <i class="fas fa-users text-sm"></i>
                        </div>
                        <span class="font-medium text-sm relative z-10">Customers</span>
                      <% end %>

                      <%= link_to purchase_orders_path, class: "flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-green-50 dark:hover:bg-green-900/20 rounded-lg transition-all duration-200 group relative overflow-hidden" do %>
                        <div class="absolute inset-0 bg-green-500/0 group-hover:bg-green-500/5 transition-colors duration-300"></div>
                        <div class="w-8 h-8 rounded-full bg-green-100 dark:bg-green-900/50 flex items-center justify-center text-green-600 dark:text-green-400 mr-2 group-hover:bg-green-200 dark:group-hover:bg-green-800/50 transition-colors duration-200 relative">
                          <i class="fas fa-shopping-cart text-sm"></i>
                        </div>
                        <span class="font-medium text-sm relative z-10">Purchase Orders</span>
                      <% end %>

                      <%= link_to sales_orders_path, class: "flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-green-50 dark:hover:bg-green-900/20 rounded-lg transition-all duration-200 group relative overflow-hidden" do %>
                        <div class="absolute inset-0 bg-green-500/0 group-hover:bg-green-500/5 transition-colors duration-300"></div>
                        <div class="w-8 h-8 rounded-full bg-green-100 dark:bg-green-900/50 flex items-center justify-center text-green-600 dark:text-green-400 mr-2 group-hover:bg-green-200 dark:group-hover:bg-green-800/50 transition-colors duration-200 relative">
                          <i class="fas fa-file-invoice-dollar text-sm"></i>
                        </div>
                        <span class="font-medium text-sm relative z-10">Sales Orders</span>
                      <% end %>
                    </div>
                  </div>

                  <!-- Supply Chain Section with enhanced animation -->
                  <div class="px-4 py-2 border-t border-gray-100 dark:border-gray-700">
                    <h4 class="text-xs font-semibold text-purple-600 dark:text-purple-400 uppercase tracking-wider mb-2">Supply Chain</h4>
                    <div class="grid grid-cols-2 gap-2">
                      <a href="/inventory/transactions" class="flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-purple-50 dark:hover:bg-purple-900/20 rounded-lg transition-all duration-200 group relative overflow-hidden">
                        <div class="absolute inset-0 bg-purple-500/0 group-hover:bg-purple-500/5 transition-colors duration-300"></div>
                        <div class="w-8 h-8 rounded-full bg-purple-100 dark:bg-purple-900/50 flex items-center justify-center text-purple-600 dark:text-purple-400 mr-2 group-hover:bg-purple-200 dark:group-hover:bg-purple-800/50 transition-colors duration-200 relative">
                          <i class="fas fa-exchange-alt text-sm"></i>
                        </div>
                        <span class="font-medium text-sm relative z-10">Transactions</span>
                      </a>
                      
                      <a href="/inventory/stock_levels" class="flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-purple-50 dark:hover:bg-purple-900/20 rounded-lg transition-all duration-200 group relative overflow-hidden">
                        <div class="absolute inset-0 bg-purple-500/0 group-hover:bg-purple-500/5 transition-colors duration-300"></div>
                        <div class="w-8 h-8 rounded-full bg-purple-100 dark:bg-purple-900/50 flex items-center justify-center text-purple-600 dark:text-purple-400 mr-2 group-hover:bg-purple-200 dark:group-hover:bg-purple-800/50 transition-colors duration-200 relative">
                          <i class="fas fa-boxes text-sm"></i>
                        </div>
                        <span class="font-medium text-sm relative z-10">Stock Levels</span>
                      </a>
                      
                      <a href="/shipments" class="flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-purple-50 dark:hover:bg-purple-900/20 rounded-lg transition-all duration-200 group relative overflow-hidden">
                        <div class="absolute inset-0 bg-purple-500/0 group-hover:bg-purple-500/5 transition-colors duration-300"></div>
                        <div class="w-8 h-8 rounded-full bg-purple-100 dark:bg-purple-900/50 flex items-center justify-center text-purple-600 dark:text-purple-400 mr-2 group-hover:bg-purple-200 dark:group-hover:bg-purple-800/50 transition-colors duration-200 relative">
                          <i class="fas fa-truck text-sm"></i>
                        </div>
                        <span class="font-medium text-sm relative z-10">Shipments</span>
                      </a>
                      
                      <a href="/logistics" class="flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-purple-50 dark:hover:bg-purple-900/20 rounded-lg transition-all duration-200 group relative overflow-hidden">
                        <div class="absolute inset-0 bg-purple-500/0 group-hover:bg-purple-500/5 transition-colors duration-300"></div>
                        <div class="w-8 h-8 rounded-full bg-purple-100 dark:bg-purple-900/50 flex items-center justify-center text-purple-600 dark:text-purple-400 mr-2 group-hover:bg-purple-200 dark:group-hover:bg-purple-800/50 transition-colors duration-200 relative">
                          <i class="fas fa-route text-sm"></i>
                        </div>
                        <span class="font-medium text-sm relative z-10">Logistics</span>
                      </a>
                    </div>
                  </div>

                  <!-- Reports Section -->
                  <div class="px-4 py-2 border-t border-gray-100 dark:border-gray-700">
                    <h4 class="text-xs font-semibold text-teal-600 dark:text-teal-400 uppercase tracking-wider mb-2">Reports</h4>
                    <div class="grid grid-cols-2 gap-2">
                      <a href="/reports/analytics" class="flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-teal-50 dark:hover:bg-teal-900/20 rounded-lg transition-all duration-200 group relative overflow-hidden">
                        <div class="absolute inset-0 bg-teal-500/0 group-hover:bg-teal-500/5 transition-colors duration-300"></div>
                        <div class="w-8 h-8 rounded-full bg-teal-100 dark:bg-teal-900/50 flex items-center justify-center text-teal-600 dark:text-teal-400 mr-2 group-hover:bg-teal-200 dark:group-hover:bg-teal-800/50 transition-colors duration-200 relative">
                          <i class="fas fa-chart-line text-sm"></i>
                        </div>
                        <span class="font-medium text-sm relative z-10">Analytics</span>
                      </a>
                      
                      <a href="/reports/finances" class="flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-teal-50 dark:hover:bg-teal-900/20 rounded-lg transition-all duration-200 group relative overflow-hidden">
                        <div class="absolute inset-0 bg-teal-500/0 group-hover:bg-teal-500/5 transition-colors duration-300"></div>
                        <div class="w-8 h-8 rounded-full bg-teal-100 dark:bg-teal-900/50 flex items-center justify-center text-teal-600 dark:text-teal-400 mr-2 group-hover:bg-teal-200 dark:group-hover:bg-teal-800/50 transition-colors duration-200 relative">
                          <i class="fas fa-file-invoice-dollar text-sm"></i>
                        </div>
                        <span class="font-medium text-sm relative z-10">Finances</span>
                      </a>
                      
                      <a href="/reports/inventory" class="flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-teal-50 dark:hover:bg-teal-900/20 rounded-lg transition-all duration-200 group relative overflow-hidden">
                        <div class="absolute inset-0 bg-teal-500/0 group-hover:bg-teal-500/5 transition-colors duration-300"></div>
                        <div class="w-8 h-8 rounded-full bg-teal-100 dark:bg-teal-900/50 flex items-center justify-center text-teal-600 dark:text-teal-400 mr-2 group-hover:bg-teal-200 dark:group-hover:bg-teal-800/50 transition-colors duration-200 relative">
                          <i class="fas fa-boxes text-sm"></i>
                        </div>
                        <span class="font-medium text-sm relative z-10">Inventory</span>
                      </a>
                      
                      <a href="/reports/sales" class="flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-teal-50 dark:hover:bg-teal-900/20 rounded-lg transition-all duration-200 group relative overflow-hidden">
                        <div class="absolute inset-0 bg-teal-500/0 group-hover:bg-teal-500/5 transition-colors duration-300"></div>
                        <div class="w-8 h-8 rounded-full bg-teal-100 dark:bg-teal-900/50 flex items-center justify-center text-teal-600 dark:text-teal-400 mr-2 group-hover:bg-teal-200 dark:group-hover:bg-teal-800/50 transition-colors duration-200 relative">
                          <i class="fas fa-chart-bar text-sm"></i>
                        </div>
                        <span class="font-medium text-sm relative z-10">Sales</span>
                      </a>
                    </div>
                  </div>

                  <!-- Settings & Tools Section -->
                  <div class="px-4 py-2 border-t border-gray-100 dark:border-gray-700">
                    <h4 class="text-xs font-semibold text-indigo-600 dark:text-indigo-400 uppercase tracking-wider mb-2">Settings & Tools</h4>
                    <div class="grid grid-cols-2 gap-2">
                      <a href="/settings/account" class="flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-indigo-50 dark:hover:bg-indigo-900/20 rounded-lg transition-all duration-200 group relative overflow-hidden">
                        <div class="absolute inset-0 bg-indigo-500/0 group-hover:bg-indigo-500/5 transition-colors duration-300"></div>
                        <div class="w-8 h-8 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mr-2 group-hover:bg-indigo-200 dark:group-hover:bg-indigo-800/50 transition-colors duration-200 relative">
                          <i class="fas fa-user-cog text-sm"></i>
                        </div>
                        <span class="font-medium text-sm relative z-10">Account</span>
                      </a>
                      
                      <a href="/settings/organization" class="flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-indigo-50 dark:hover:bg-indigo-900/20 rounded-lg transition-all duration-200 group relative overflow-hidden">
                        <div class="absolute inset-0 bg-indigo-500/0 group-hover:bg-indigo-500/5 transition-colors duration-300"></div>
                        <div class="w-8 h-8 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mr-2 group-hover:bg-indigo-200 dark:group-hover:bg-indigo-800/50 transition-colors duration-200 relative">
                          <i class="fas fa-building text-sm"></i>
                        </div>
                        <span class="font-medium text-sm relative z-10">Organization</span>
                      </a>
                      
                      <% if policy(User).index? %>
                        <%= link_to users_path, class: "flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-indigo-50 dark:hover:bg-indigo-900/20 rounded-lg transition-all duration-200 group relative overflow-hidden" do %>
                          <div class="absolute inset-0 bg-indigo-500/0 group-hover:bg-indigo-500/5 transition-colors duration-300"></div>
                          <div class="w-8 h-8 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mr-2 group-hover:bg-indigo-200 dark:group-hover:bg-indigo-800/50 transition-colors duration-200 relative">
                            <i class="fas fa-users text-sm"></i>
                          </div>
                          <span class="font-medium text-sm relative z-10">Team Members</span>
                        <% end %>
                      <% end %>
                      
                      <a href="/settings/integrations" class="flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-indigo-50 dark:hover:bg-indigo-900/20 rounded-lg transition-all duration-200 group relative overflow-hidden">
                        <div class="absolute inset-0 bg-indigo-500/0 group-hover:bg-indigo-500/5 transition-colors duration-300"></div>
                        <div class="w-8 h-8 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mr-2 group-hover:bg-indigo-200 dark:group-hover:bg-indigo-800/50 transition-colors duration-200 relative">
                          <i class="fas fa-plug text-sm"></i>
                        </div>
                        <span class="font-medium text-sm relative z-10">Integrations</span>
                      </a>
                    </div>
                  </div>
                </div>

                <!-- Animated Footer -->
                <div class="p-3 bg-gradient-to-r from-gray-50 to-gray-100 dark:from-gray-800 dark:to-gray-900 border-t border-gray-200 dark:border-gray-700 relative overflow-hidden">
                  <div class="absolute inset-0 bg-pattern opacity-5"></div>
                  <div class="relative flex justify-between items-center">
                    <a href="/dashboard" class="text-indigo-600 hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300 text-sm font-medium flex items-center transition-all duration-200 hover:translate-x-1">
                      <i class="fas fa-th-large mr-1"></i> Main Dashboard
                    </a>
                    <a href="/dashboard/settings" class="text-indigo-600 hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300 text-sm font-medium flex items-center transition-all duration-200 hover:translate-x-[-4px]">
                      <i class="fas fa-cog mr-1"></i> Customize
                    </a>
                  </div>
                </div>
              </div>
            </div>

            <%# Help Dropdown with enhanced animations %>
            <div data-controller="dropdown" class="relative">
              <button
                data-action="click->dropdown#toggle click@window->dropdown#hide"
                data-dropdown-target="button"
                class="text-white/90 hover:text-white hover:bg-white/10 px-3 py-2 rounded-lg transition-all duration-200 flex items-center relative overflow-hidden"
                aria-expanded="false"
                aria-haspopup="true"
                aria-controls="help-dropdown-menu"
              >
                <div class="absolute inset-0 bg-gradient-to-r from-white/0 to-white/0 hover:from-white/5 hover:to-white/10 transition-all duration-300"></div>
                <i class="fas fa-question-circle mr-2 relative z-10" aria-hidden="true"></i>
                <span class="relative z-10">Help</span>
                <i class="fas fa-chevron-down ml-2 text-xs transition-transform duration-200 relative z-10" data-dropdown-target="arrow" aria-hidden="true"></i>
              </button>

              <div
                id="help-dropdown-menu"
                data-dropdown-target="menu"
                class="absolute left-0 mt-3 w-56 rounded-xl shadow-2xl bg-white dark:bg-gray-800 ring-1 ring-black ring-opacity-5 overflow-hidden z-50 transform origin-top-left transition-all duration-200 scale-95 opacity-0 invisible"
                role="menu"
                aria-orientation="vertical"
                aria-labelledby="help-dropdown-button"
              >
                <!-- Header with enhanced animation -->
                <div class="relative overflow-hidden">
                  <!-- Background Pattern with animation -->
                  <div class="absolute inset-0 bg-gradient-to-r from-green-500 to-teal-500 opacity-90"></div>
                  <div class="absolute inset-0 bg-pattern opacity-20"></div>
                  <div class="absolute inset-0 bg-gradient-to-r from-green-500/0 via-teal-400/30 to-green-500/0 opacity-30 animate-pulse-slow"></div>

                  <!-- Header Content -->
                  <div class="relative p-4">
                    <div class="flex items-center">
                      <div class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center text-white mr-3 shadow-md">
                        <i class="fas fa-question-circle text-xl"></i>
                      </div>
                      <h3 class="text-xl font-bold text-white">Help & Support</h3>
                    </div>
                  </div>
