<div data-controller="navbar swipe-gesture" class="relative">
  <%# Desktop & Mobile Navigation %>
  <header class="bg-sky-700 dark:bg-gray-900 fixed top-0 left-0 right-0 z-50 backdrop-blur-lg shadow-lg" role="banner">
    <div class="container mx-auto px-4">
      <nav class="py-3" aria-label="Main Navigation">
        <div class="flex items-center justify-between">
          <%# Logo %>
          <div class="flex items-center">
            <a href="/" class="text-2xl font-bold flex items-center group" aria-label="SupplyFlow Home">
              <div class="bg-white text-primary rounded-full w-10 h-10 flex items-center justify-center mr-3 shadow-lg" aria-hidden="true">
                <i class="fas fa-box-open"></i>
              </div>
              <span class="text-white group-hover:scale-105 transition-transform duration-300 inline-block">SupplyFlow</span>
            </a>
          </div>

          <%# Desktop Navigation - Hidden on mobile %>
          <div class="hidden lg:flex items-center space-x-1">
            <%# Regular Nav Items %>
            <a href="/" class="<%= active_link_class('/', exact: true, active_class: 'bg-white/20 text-white font-medium', inactive_class: 'text-white/80 hover:text-white hover:bg-white/10') %> px-3 py-2 rounded-lg transition-colors duration-200 flex items-center">
              <i class="fas fa-home mr-2" aria-hidden="true"></i>
              <span>Home</span>
              <% if active_link?('/', exact: true) %>
                <span class="ml-2 w-1.5 h-1.5 rounded-full bg-white"></span>
              <% end %>
            </a>

            <%# Dashboard Dropdown %>
            <div data-controller="dropdown" class="relative">
              <button
                data-action="click->dropdown#toggle click@window->dropdown#hide keydown->dropdown#handleKeydown"
                data-dropdown-target="button"
                class="text-white/80 hover:text-white hover:bg-white/10 px-3 py-2 rounded-lg transition-colors duration-200 flex items-center"
                aria-expanded="false"
                aria-haspopup="true"
                aria-controls="dashboard-dropdown-menu"
              >
                <i class="fas fa-th-large mr-2" aria-hidden="true"></i>
                <span>Dashboard</span>
                <i class="fas fa-chevron-down ml-2 text-xs transition-transform duration-200" data-dropdown-target="arrow" aria-hidden="true"></i>
              </button>

              <div
                id="dashboard-dropdown-menu"
                data-dropdown-target="menu"
                class="absolute left-0 mt-3 w-80 rounded-xl shadow-2xl bg-white dark:bg-gray-800 ring-1 ring-black ring-opacity-5 overflow-hidden z-50 transform origin-top-left transition-all duration-200 scale-95 opacity-0 invisible"
                role="menu"
                aria-orientation="vertical"
                aria-labelledby="dashboard-dropdown-button"
              >
                <!-- Header -->
                <div class="relative">
                  <!-- Background Pattern -->
                  <div class="absolute inset-0 bg-gradient-to-r from-blue-600 to-indigo-600 opacity-90"></div>
                  <div class="absolute inset-0 bg-pattern opacity-10"></div>

                  <!-- Header Content -->
                  <div class="relative p-4">
                    <div class="flex items-center">
                      <div class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center text-white mr-3">
                        <i class="fas fa-th-large text-xl"></i>
                      </div>
                      <h3 class="text-xl font-bold text-white">Dashboard</h3>
                    </div>
                  </div>
                </div>

                <!-- Menu Items -->
                <div class="py-2 px-1">
                  <!-- Inventory Section -->
                  <div class="px-4 py-2">
                    <h4 class="text-xs font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wider mb-2">Inventory</h4>
                    <div class="grid grid-cols-2 gap-2">
                      <a href="#" class="flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg transition-colors duration-200 group">
                        <div class="w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center text-blue-600 dark:text-blue-400 mr-2 group-hover:bg-blue-200 dark:group-hover:bg-blue-800/50 transition-colors duration-200">
                          <i class="fas fa-cubes text-sm"></i>
                        </div>
                        <span class="font-medium text-sm">Products</span>
                      </a>
                      <a href="#" class="flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg transition-colors duration-200 group">
                        <div class="w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center text-blue-600 dark:text-blue-400 mr-2 group-hover:bg-blue-200 dark:group-hover:bg-blue-800/50 transition-colors duration-200">
                          <i class="fas fa-exchange-alt text-sm"></i>
                        </div>
                        <span class="font-medium text-sm">Stock</span>
                      </a>
                      <%= link_to locations_path, class: "flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-lg transition-colors duration-200 group" do %>
                        <div class="w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center text-blue-600 dark:text-blue-400 mr-2 group-hover:bg-blue-200 dark:group-hover:bg-blue-800/50 transition-colors duration-200">
                          <i class="fas fa-map-marker-alt text-sm"></i>
                        </div>
                        <span class="font-medium text-sm">Locations</span>
                      <% end %>
                    </div>
                  </div>

                  <!-- Supply Chain Section -->
                  <div class="px-4 py-2 border-t border-gray-100 dark:border-gray-700">
                    <h4 class="text-xs font-semibold text-purple-600 dark:text-purple-400 uppercase tracking-wider mb-2">Supply Chain</h4>
                    <div class="grid grid-cols-2 gap-2">
                      <a href="#" class="flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-purple-50 dark:hover:bg-purple-900/20 rounded-lg transition-colors duration-200 group">
                        <div class="w-8 h-8 rounded-full bg-purple-100 dark:bg-purple-900/50 flex items-center justify-center text-purple-600 dark:text-purple-400 mr-2 group-hover:bg-purple-200 dark:group-hover:bg-purple-800/50 transition-colors duration-200">
                          <i class="fas fa-users text-sm"></i>
                        </div>
                        <span class="font-medium text-sm">Suppliers</span>
                      </a>
                      <a href="#" class="flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-purple-50 dark:hover:bg-purple-900/20 rounded-lg transition-colors duration-200 group">
                        <div class="w-8 h-8 rounded-full bg-purple-100 dark:bg-purple-900/50 flex items-center justify-center text-purple-600 dark:text-purple-400 mr-2 group-hover:bg-purple-200 dark:group-hover:bg-purple-800/50 transition-colors duration-200">
                          <i class="fas fa-file-invoice text-sm"></i>
                        </div>
                        <span class="font-medium text-sm">Orders</span>
                      </a>
                    </div>
                  </div>

                  <!-- Reports Section -->
                  <div class="px-4 py-2 border-t border-gray-100 dark:border-gray-700">
                    <h4 class="text-xs font-semibold text-teal-600 dark:text-teal-400 uppercase tracking-wider mb-2">Reports</h4>
                    <div class="grid grid-cols-2 gap-2">
                      <a href="#" class="flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-teal-50 dark:hover:bg-teal-900/20 rounded-lg transition-colors duration-200 group">
                        <div class="w-8 h-8 rounded-full bg-teal-100 dark:bg-teal-900/50 flex items-center justify-center text-teal-600 dark:text-teal-400 mr-2 group-hover:bg-teal-200 dark:group-hover:bg-teal-800/50 transition-colors duration-200">
                          <i class="fas fa-chart-line text-sm"></i>
                        </div>
                        <span class="font-medium text-sm">Analytics</span>
                      </a>
                      <a href="#" class="flex items-center p-2 text-gray-700 dark:text-gray-200 hover:bg-teal-50 dark:hover:bg-teal-900/20 rounded-lg transition-colors duration-200 group">
                        <div class="w-8 h-8 rounded-full bg-teal-100 dark:bg-teal-900/50 flex items-center justify-center text-teal-600 dark:text-teal-400 mr-2 group-hover:bg-teal-200 dark:group-hover:bg-teal-800/50 transition-colors duration-200">
                          <i class="fas fa-file-invoice-dollar text-sm"></i>
                        </div>
                        <span class="font-medium text-sm">Finances</span>
                      </a>
                    </div>
                  </div>
                </div>

                <!-- Footer -->
                <div class="p-3 bg-gray-50 dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700 text-center">
                  <a href="#" class="text-indigo-600 hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300 text-sm font-medium">
                    <i class="fas fa-cog mr-1"></i> Customize Dashboard
                  </a>
                </div>
              </div>
            </div>

            <%# Help Dropdown %>
            <div data-controller="dropdown" class="relative">
              <button
                data-action="click->dropdown#toggle click@window->dropdown#hide"
                data-dropdown-target="button"
                class="text-white/80 hover:text-white hover:bg-white/10 px-3 py-2 rounded-lg transition-colors duration-200 flex items-center"
                aria-expanded="false"
                aria-haspopup="true"
                aria-controls="help-dropdown-menu"
              >
                <i class="fas fa-question-circle mr-2" aria-hidden="true"></i>
                <span>Help</span>
                <i class="fas fa-chevron-down ml-2 text-xs transition-transform duration-200" data-dropdown-target="arrow" aria-hidden="true"></i>
              </button>

              <div
                id="help-dropdown-menu"
                data-dropdown-target="menu"
                class="absolute left-0 mt-3 w-56 rounded-xl shadow-2xl bg-white dark:bg-gray-800 ring-1 ring-black ring-opacity-5 overflow-hidden z-50 transform origin-top-left transition-all duration-200 scale-95 opacity-0 invisible"
                role="menu"
                aria-orientation="vertical"
                aria-labelledby="help-dropdown-button"
              >
                <!-- Header -->
                <div class="relative">
                  <!-- Background Pattern -->
                  <div class="absolute inset-0 bg-gradient-to-r from-green-500 to-teal-500 opacity-90"></div>
                  <div class="absolute inset-0 bg-pattern opacity-10"></div>

                  <!-- Header Content -->
                  <div class="relative p-4">
                    <div class="flex items-center">
                      <div class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center text-white mr-3">
                        <i class="fas fa-question-circle text-xl"></i>
                      </div>
                      <h3 class="text-xl font-bold text-white">Help & Support</h3>
                    </div>
                  </div>
                </div>

                <!-- Menu Items -->
                <div class="py-2 px-1">
                  <a
                    href="/about"
                    class="flex items-center px-4 py-3 text-gray-700 dark:text-gray-200 hover:bg-green-50 dark:hover:bg-green-900/20 rounded-lg mx-1 transition-colors duration-200 group"
                    role="menuitem"
                  >
                    <div class="w-8 h-8 rounded-full bg-green-100 dark:bg-green-900/50 flex items-center justify-center text-green-600 dark:text-green-400 mr-3 group-hover:bg-green-200 dark:group-hover:bg-green-800/50 transition-colors duration-200">
                      <i class="fas fa-info-circle"></i>
                    </div>
                    <span class="font-medium">About Us</span>
                  </a>

                  <a
                    href="/contact"
                    class="flex items-center px-4 py-3 text-gray-700 dark:text-gray-200 hover:bg-green-50 dark:hover:bg-green-900/20 rounded-lg mx-1 transition-colors duration-200 group"
                    role="menuitem"
                  >
                    <div class="w-8 h-8 rounded-full bg-green-100 dark:bg-green-900/50 flex items-center justify-center text-green-600 dark:text-green-400 mr-3 group-hover:bg-green-200 dark:group-hover:bg-green-800/50 transition-colors duration-200">
                      <i class="fas fa-envelope"></i>
                    </div>
                    <span class="font-medium">Contact Us</span>
                  </a>

                  <a
                    href="/support"
                    class="flex items-center px-4 py-3 text-gray-700 dark:text-gray-200 hover:bg-green-50 dark:hover:bg-green-900/20 rounded-lg mx-1 transition-colors duration-200 group"
                    role="menuitem"
                  >
                    <div class="w-8 h-8 rounded-full bg-green-100 dark:bg-green-900/50 flex items-center justify-center text-green-600 dark:text-green-400 mr-3 group-hover:bg-green-200 dark:group-hover:bg-green-800/50 transition-colors duration-200">
                      <i class="fas fa-headset"></i>
                    </div>
                    <span class="font-medium">Support</span>
                  </a>

                  <a
                    href="#"
                    class="flex items-center px-4 py-3 text-gray-700 dark:text-gray-200 hover:bg-green-50 dark:hover:bg-green-900/20 rounded-lg mx-1 transition-colors duration-200 group"
                    role="menuitem"
                  >
                    <div class="w-8 h-8 rounded-full bg-green-100 dark:bg-green-900/50 flex items-center justify-center text-green-600 dark:text-green-400 mr-3 group-hover:bg-green-200 dark:group-hover:bg-green-800/50 transition-colors duration-200">
                      <i class="fas fa-book"></i>
                    </div>
                    <span class="font-medium">Documentation</span>
                  </a>
                </div>
              </div>
            </div>


          </div>

          <%# Right Side - Auth & Actions %>
          <div class="hidden lg:flex items-center space-x-3">
            <%# Notification Dropdown %>
            <div data-controller="dropdown" class="relative">
              <button
                data-action="click->dropdown#toggle click@window->dropdown#hide"
                data-dropdown-target="button"
                class="text-white/80 hover:text-white hover:bg-white/10 p-2 rounded-lg transition-colors duration-200 relative"
              >
                <i class="fas fa-bell text-lg"></i>
                <span class="absolute -top-1 -right-1 bg-orange-500 text-white text-xs w-5 h-5 flex items-center justify-center rounded-full shadow-md animate-pulse-slow">3</span>
              </button>

              <div
                data-dropdown-target="menu"
                class="absolute right-0 mt-3 w-96 rounded-xl shadow-2xl bg-white dark:bg-gray-800 ring-1 ring-black ring-opacity-5 overflow-hidden z-50 transform origin-top-right transition-all duration-200 scale-95 opacity-0 invisible"
              >
                <!-- Notification Header -->
                <div class="relative">
                  <!-- Background Pattern -->
                  <div class="absolute inset-0 bg-gradient-to-r from-blue-600 to-indigo-600 opacity-90"></div>
                  <div class="absolute inset-0 bg-pattern opacity-10"></div>

                  <!-- Header Content -->
                  <div class="relative p-4">
                    <div class="flex justify-between items-center">
                      <div class="flex items-center">
                        <div class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center text-white mr-3">
                          <i class="fas fa-bell text-xl"></i>
                        </div>
                        <h3 class="text-xl font-bold text-white">Notifications</h3>
                      </div>
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-white text-indigo-700 shadow-sm">
                        3 new
                      </span>
                    </div>
                  </div>
                </div>

                <!-- Notification Tabs -->
                <div class="flex border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
                  <button class="flex-1 py-3 px-4 text-center text-sm font-medium text-indigo-600 dark:text-indigo-400 border-b-2 border-indigo-600 dark:border-indigo-400">
                    All
                  </button>
                  <button class="flex-1 py-3 px-4 text-center text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400">
                    Unread
                  </button>
                  <button class="flex-1 py-3 px-4 text-center text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400">
                    Important
                  </button>
                </div>

                <!-- Notification List -->
                <div class="max-h-96 overflow-y-auto">
                  <!-- Today Section -->
                  <div class="px-4 py-2 bg-gray-50 dark:bg-gray-700/30 text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                    Today
                  </div>

                  <!-- Notification Item 1 -->
                  <div class="p-4 border-b border-gray-100 dark:border-gray-700 hover:bg-blue-50 dark:hover:bg-blue-900/10 transition-colors duration-200">
                    <div class="flex">
                      <div class="flex-shrink-0 mr-4">
                        <div class="w-12 h-12 rounded-full bg-blue-500 flex items-center justify-center text-white shadow-md">
                          <i class="fas fa-box text-lg"></i>
                        </div>
                      </div>
                      <div class="flex-1">
                        <div class="flex justify-between items-start">
                          <p class="font-medium text-gray-800 dark:text-gray-200">New shipment created</p>
                          <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/50 dark:text-blue-300">
                            New
                          </span>
                        </div>
                        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Your order #12345 has been shipped and is on its way to you.</p>
                        <div class="mt-2 flex justify-between items-center">
                          <p class="text-xs text-gray-500 dark:text-gray-500">5 minutes ago</p>
                          <button class="text-xs text-gray-400 hover:text-gray-500 dark:text-gray-500 dark:hover:text-gray-400">
                            <i class="fas fa-times"></i>
                          </button>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- Notification Item 2 -->
                  <div class="p-4 border-b border-gray-100 dark:border-gray-700 hover:bg-green-50 dark:hover:bg-green-900/10 transition-colors duration-200">
                    <div class="flex">
                      <div class="flex-shrink-0 mr-4">
                        <div class="w-12 h-12 rounded-full bg-green-500 flex items-center justify-center text-white shadow-md">
                          <i class="fas fa-check text-lg"></i>
                        </div>
                      </div>
                      <div class="flex-1">
                        <div class="flex justify-between items-start">
                          <p class="font-medium text-gray-800 dark:text-gray-200">Inventory updated</p>
                          <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/50 dark:text-green-300">
                            Success
                          </span>
                        </div>
                        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Inventory levels have been updated successfully across all warehouses.</p>
                        <div class="mt-2 flex justify-between items-center">
                          <p class="text-xs text-gray-500 dark:text-gray-500">1 hour ago</p>
                          <button class="text-xs text-gray-400 hover:text-gray-500 dark:text-gray-500 dark:hover:text-gray-400">
                            <i class="fas fa-times"></i>
                          </button>
                        </div>
                      </div>
                    </div>
                  </div>

                  <!-- Yesterday Section -->
                  <div class="px-4 py-2 bg-gray-50 dark:bg-gray-700/30 text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                    Yesterday
                  </div>

                  <!-- Notification Item 3 -->
                  <div class="p-4 hover:bg-amber-50 dark:hover:bg-amber-900/10 transition-colors duration-200">
                    <div class="flex">
                      <div class="flex-shrink-0 mr-4">
                        <div class="w-12 h-12 rounded-full bg-amber-500 flex items-center justify-center text-white shadow-md">
                          <i class="fas fa-exclamation-triangle text-lg"></i>
                        </div>
                      </div>
                      <div class="flex-1">
                        <div class="flex justify-between items-start">
                          <p class="font-medium text-gray-800 dark:text-gray-200">Low stock alert</p>
                          <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-800 dark:bg-amber-900/50 dark:text-amber-300">
                            Warning
                          </span>
                        </div>
                        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Product SKU-789 is running low. Consider restocking soon to avoid stockouts.</p>
                        <div class="mt-2 flex justify-between items-center">
                          <p class="text-xs text-gray-500 dark:text-gray-500">Yesterday at 2:45 PM</p>
                          <button class="text-xs text-gray-400 hover:text-gray-500 dark:text-gray-500 dark:hover:text-gray-400">
                            <i class="fas fa-times"></i>
                          </button>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Footer -->
                <div class="p-4 bg-gray-50 dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700 flex justify-between items-center">
                  <a href="#" class="text-indigo-600 hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300 text-sm font-medium">
                    View all notifications
                  </a>
                  <button class="px-3 py-1 bg-indigo-100 hover:bg-indigo-200 dark:bg-indigo-900/30 dark:hover:bg-indigo-800/40 text-indigo-600 dark:text-indigo-400 text-xs font-medium rounded-lg transition-colors duration-200">
                    Mark all as read
                  </button>
                </div>
              </div>
            </div>

            <%# Language Selector %>
            <div data-controller="language-selector" class="relative">
              <button
                data-language-selector-target="button"
                data-action="click->language-selector#toggle click@window->language-selector#hide"
                class="text-white/80 hover:text-white hover:bg-white/10 px-3 py-2 rounded-lg transition-colors duration-200 flex items-center"
                aria-expanded="false"
                aria-haspopup="true"
                aria-controls="language-dropdown"
              >
                <i class="fas fa-globe mr-2" aria-hidden="true"></i>
                <span data-language-selector-target="selected">English</span>
                <i class="fas fa-chevron-down ml-2 text-xs"></i>
              </button>

              <div
                id="language-dropdown"
                data-language-selector-target="dropdown"
                class="absolute right-0 mt-3 w-64 rounded-xl shadow-2xl bg-white dark:bg-gray-800 ring-1 ring-black ring-opacity-5 overflow-hidden z-50 transform origin-top-right transition-all duration-200 scale-95 opacity-0 invisible"
                role="menu"
                aria-orientation="vertical"
                aria-labelledby="language-button"
              >
                <!-- Language Header -->
                <div class="relative">
                  <!-- Background Pattern -->
                  <div class="absolute inset-0 bg-gradient-to-r from-purple-600 to-pink-600 opacity-90"></div>
                  <div class="absolute inset-0 bg-pattern opacity-10"></div>

                  <!-- Header Content -->
                  <div class="relative p-4">
                    <div class="flex items-center">
                      <div class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center text-white mr-3">
                        <i class="fas fa-globe text-xl"></i>
                      </div>
                      <h3 class="text-xl font-bold text-white">Select Language</h3>
                    </div>
                  </div>
                </div>

                <!-- Language Options -->
                <div class="py-2 px-1">
                  <a
                    href="#"
                    class="flex items-center px-4 py-3 text-gray-700 dark:text-gray-200 hover:bg-purple-50 dark:hover:bg-purple-900/20 rounded-lg mx-1 transition-colors duration-200 group"
                    role="menuitem"
                    data-action="click->language-selector#selectLanguage"
                    data-language="en"
                  >
                    <div class="w-10 h-10 rounded-full bg-gray-100 dark:bg-gray-700 flex items-center justify-center mr-3 overflow-hidden border-2 border-gray-200 dark:border-gray-600 group-hover:border-purple-300 dark:group-hover:border-purple-500 transition-colors duration-200">
                      <span class="fi fi-us text-2xl"></span>
                    </div>
                    <div>
                      <span class="font-medium block">English</span>
                      <span class="text-xs text-gray-500 dark:text-gray-400">United States</span>
                    </div>
                    <div class="ml-auto">
                      <span class="w-2 h-2 rounded-full bg-green-500 block"></span>
                    </div>
                  </a>

                  <a
                    href="#"
                    class="flex items-center px-4 py-3 text-gray-700 dark:text-gray-200 hover:bg-purple-50 dark:hover:bg-purple-900/20 rounded-lg mx-1 transition-colors duration-200 group"
                    role="menuitem"
                    data-action="click->language-selector#selectLanguage"
                    data-language="es"
                  >
                    <div class="w-10 h-10 rounded-full bg-gray-100 dark:bg-gray-700 flex items-center justify-center mr-3 overflow-hidden border-2 border-gray-200 dark:border-gray-600 group-hover:border-purple-300 dark:group-hover:border-purple-500 transition-colors duration-200">
                      <span class="fi fi-es text-2xl"></span>
                    </div>
                    <div>
