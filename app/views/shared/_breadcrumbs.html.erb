<%# Breadcrumbs Navigation %>
<% if defined?(breadcrumbs) && breadcrumbs.any? %>
  <nav aria-label="Breadcrumb" class="py-3 px-4 bg-gray-50 dark:bg-gray-800 rounded-lg mb-6">
    <ol class="flex flex-wrap items-center text-sm">
      <%# Home link is always first %>
      <li class="flex items-center">
        <a href="/" class="text-gray-500 dark:text-gray-400 hover:text-primary dark:hover:text-primary-light transition-colors duration-200">
          <i class="fas fa-home" aria-hidden="true"></i>
          <span class="sr-only">Home</span>
        </a>
        <svg class="mx-2 h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
        </svg>
      </li>
      
      <%# Iterate through breadcrumbs %>
      <% breadcrumbs.each_with_index do |breadcrumb, index| %>
        <li class="flex items-center <%= 'text-gray-900 dark:text-white font-medium' if index == breadcrumbs.size - 1 %>">
          <% if index == breadcrumbs.size - 1 %>
            <%# Last item is current page (not a link) %>
            <span aria-current="page"><%= breadcrumb[:title] %></span>
          <% else %>
            <%# Other items are links %>
            <a href="<%= breadcrumb[:url] %>" class="text-gray-500 dark:text-gray-400 hover:text-primary dark:hover:text-primary-light transition-colors duration-200">
              <%= breadcrumb[:title] %>
            </a>
            <svg class="mx-2 h-4 w-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
          <% end %>
        </li>
      <% end %>
    </ol>
  </nav>
<% end %>
