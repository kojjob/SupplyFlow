<%# Newsletter Subscription JavaScript %>
<script type="text/javascript">
  // Using Stimulus controller for newsletter subscription
  (() => {
    window.Stimulus = window.Stimulus || {};
    window.Stimulus.register = window.Stimulus.register || {};
    window.Stimulus.register.controllers = window.Stimulus.register.controllers || {};

    window.Stimulus.register.controllers.newsletter = class extends window.Stimulus.Controller {
      static targets = ["email", "success"];

      subscribe(event) {
        event.preventDefault();

        // In a real implementation, this would send the data to a server
        // For now, we'll just show the success message
        if (this.emailTarget.value) {
          this.successTarget.classList.remove("hidden");
          this.emailTarget.value = "";

          // Hide the success message after 3 seconds
          setTimeout(() => {
            this.successTarget.classList.add("hidden");
          }, 3000);
        }
      }
    };
  })();
</script>
