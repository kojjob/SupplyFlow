<%# Contact Form Partial %>
<div data-controller="contact-form" class="fixed inset-0 z-[1000] bg-black/50 backdrop-blur-sm hidden" data-contact-form-target="overlay">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md bg-white dark:bg-gray-800 rounded-xl shadow-2xl overflow-hidden transition-all duration-300 transform scale-0 opacity-0" data-contact-form-target="container">
    <%# Form Header %>
    <div class="bg-gradient-to-r from-[#0055A4] to-[#00A86B] p-4 text-white relative">
      <button data-action="contact-form#close" class="absolute right-4 top-4 w-8 h-8 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors duration-200">
        <i class="fas fa-times"></i>
      </button>
      <h3 class="text-xl font-bold mb-1">Contact Us</h3>
      <p class="text-sm text-white/80">We'll get back to you within 24 hours</p>
    </div>
    
    <%# Form Body %>
    <div class="p-6">
      <form data-action="submit->contact-form#submit">
        <div class="space-y-4">
          <%# Name Field %>
          <div>
            <label for="contact-name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Your Name</label>
            <input 
              type="text" 
              id="contact-name" 
              name="name" 
              class="w-full px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-800 dark:text-white focus:outline-none focus:ring-2 focus:ring-[#0055A4] dark:focus:ring-[#1A6FBF]"
              placeholder="John Doe"
              required
              data-contact-form-target="name"
            >
          </div>
          
          <%# Email Field %>
          <div>
            <label for="contact-email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Email Address</label>
            <input 
              type="email" 
              id="contact-email" 
              name="email" 
              class="w-full px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-800 dark:text-white focus:outline-none focus:ring-2 focus:ring-[#0055A4] dark:focus:ring-[#1A6FBF]"
              placeholder="john@example.com"
              required
              data-contact-form-target="email"
            >
          </div>
          
          <%# Subject Field %>
          <div>
            <label for="contact-subject" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Subject</label>
            <select 
              id="contact-subject" 
              name="subject" 
              class="w-full px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-800 dark:text-white focus:outline-none focus:ring-2 focus:ring-[#0055A4] dark:focus:ring-[#1A6FBF]"
              required
              data-contact-form-target="subject"
            >
              <option value="">Select a subject</option>
              <option value="General Inquiry">General Inquiry</option>
              <option value="Technical Support">Technical Support</option>
              <option value="Billing Question">Billing Question</option>
              <option value="Feature Request">Feature Request</option>
              <option value="Partnership Opportunity">Partnership Opportunity</option>
            </select>
          </div>
          
          <%# Message Field %>
          <div>
            <label for="contact-message" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Message</label>
            <textarea 
              id="contact-message" 
              name="message" 
              rows="4" 
              class="w-full px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-800 dark:text-white focus:outline-none focus:ring-2 focus:ring-[#0055A4] dark:focus:ring-[#1A6FBF]"
              placeholder="How can we help you?"
              required
              data-contact-form-target="message"
            ></textarea>
          </div>
          
          <%# Submit Button %>
          <div>
            <button 
              type="submit" 
              class="w-full py-2 px-4 bg-[#00A86B] hover:bg-[#00965F] text-white font-medium rounded-lg transition-colors duration-200 flex items-center justify-center"
              data-contact-form-target="submitButton"
            >
              <i class="fas fa-paper-plane mr-2"></i>
              Send Message
            </button>
          </div>
        </div>
      </form>
      
      <%# Alternative Contact Methods %>
      <div class="mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
        <h4 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Alternative Ways to Reach Us</h4>
        <div class="space-y-2">
          <div class="flex items-center text-sm text-gray-600 dark:text-gray-400">
            <i class="fas fa-phone-alt w-5 text-[#0055A4] dark:text-[#1A6FBF]"></i>
            <span>+233 30 273 4567</span>
          </div>
          <div class="flex items-center text-sm text-gray-600 dark:text-gray-400">
            <i class="fab fa-whatsapp w-5 text-[#0055A4] dark:text-[#1A6FBF]"></i>
            <span>+233 55 123 4567</span>
          </div>
          <div class="flex items-center text-sm text-gray-600 dark:text-gray-400">
            <i class="fas fa-envelope w-5 text-[#0055A4] dark:text-[#1A6FBF]"></i>
            <span>support@supplyflow.com</span>
          </div>
        </div>
      </div>
    </div>
    
    <%# Success Message (hidden by default) %>
    <div class="absolute inset-0 bg-white dark:bg-gray-800 flex flex-col items-center justify-center p-6 hidden" data-contact-form-target="success">
      <div class="w-16 h-16 rounded-full bg-[#00A86B]/20 flex items-center justify-center mb-4">
        <i class="fas fa-check-circle text-3xl text-[#00A86B]"></i>
      </div>
      <h3 class="text-xl font-bold text-gray-800 dark:text-white mb-2">Message Sent!</h3>
      <p class="text-gray-600 dark:text-gray-400 text-center mb-6">Thank you for reaching out. We'll get back to you within 24 hours.</p>
      <button 
        data-action="contact-form#close" 
        class="py-2 px-4 bg-[#0055A4] hover:bg-[#004080] text-white font-medium rounded-lg transition-colors duration-200"
      >
        Close
      </button>
    </div>
  </div>
</div>
