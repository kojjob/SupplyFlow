<%= form_with(model: product, local: true, class: "space-y-6") do |form| %>
  <% if product.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-lg p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <i class="fas fa-exclamation-circle text-red-600 dark:text-red-400 text-lg"></i>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800 dark:text-red-300">
            <%= pluralize(product.errors.count, "error") %> prohibited this product from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700 dark:text-red-300">
            <ul class="list-disc pl-5 space-y-1">
              <% product.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Basic Information -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-5 py-4">
      <h2 class="text-lg font-semibold text-white flex items-center">
        <i class="fas fa-info-circle mr-2"></i> Basic Information
      </h2>
    </div>
    <div class="p-5">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="col-span-1 md:col-span-2">
          <%= render partial: "shared/form_input", locals: {
            form: form,
            field: :name,
            label: "Product Name",
            placeholder: "Enter product name",
            required: true,
            wrapper_class: ""
          } %>
        </div>

        <div>
          <%= render partial: "shared/form_input", locals: {
            form: form,
            field: :sku,
            label: "SKU",
            placeholder: "Enter SKU",
            required: true,
            wrapper_class: ""
          } %>
        </div>

        <div>
          <%= render partial: "shared/form_input", locals: {
            form: form,
            field: :barcode,
            label: "Barcode",
            placeholder: "Enter barcode",
            wrapper_class: ""
          } %>
        </div>

        <div>
          <div class="form-group">
            <%= form.label :category, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
            <%= form.text_field :category, list: "categories", class: "w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-[#00A86B]", placeholder: "Select or enter category" %>
            <datalist id="categories">
              <% Product.categories.each do |category| %>
                <option value="<%= category %>">
              <% end %>
            </datalist>
          </div>
        </div>

        <div>
          <div class="form-group">
            <%= form.label :brand, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
            <%= form.text_field :brand, list: "brands", class: "w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-[#00A86B]", placeholder: "Select or enter brand" %>
            <datalist id="brands">
              <% Product.brands.each do |brand| %>
                <option value="<%= brand %>">
              <% end %>
            </datalist>
          </div>
        </div>

        <div>
          <%= render partial: "shared/form_input", locals: {
            form: form,
            field: :model,
            label: "Model",
            placeholder: "Enter model number",
            wrapper_class: ""
          } %>
        </div>

        <div>
          <%= render partial: "shared/form_select", locals: {
            form: form,
            field: :unit_of_measure,
            label: "Unit of Measure",
            options: [
              ["Unit", "unit"],
              ["Piece", "piece"],
              ["Kilogram", "kg"],
              ["Gram", "g"],
              ["Liter", "l"],
              ["Milliliter", "ml"],
              ["Meter", "m"],
              ["Centimeter", "cm"],
              ["Box", "box"],
              ["Dozen", "dozen"],
              ["Pair", "pair"]
            ],
            include_blank: "Select unit of measure",
            wrapper_class: ""
          } %>
        </div>

        <div class="col-span-1 md:col-span-2">
          <%= form.label :gallery_images, "Product Images", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= form.file_field :gallery_images, multiple: true, class: "block w-full text-sm text-gray-900 dark:text-gray-200 border border-gray-300 dark:border-gray-600 rounded-lg cursor-pointer bg-gray-50 dark:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-600 file:mr-4 file:py-3 file:px-4 file:rounded-l-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 dark:file:bg-gray-600 file:text-blue-700 dark:file:text-gray-300 hover:file:bg-blue-100 dark:hover:file:bg-gray-500" %>
          <% if product.gallery_images.attached? %>
            <div class="mt-4">
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-2">Current images:</p>
              <div class="flex flex-wrap gap-2">
                <% product.gallery_images.each do |image| %>
                  <%= image_tag image.variant(resize_to_limit: [100, 100]), class: "rounded-md border border-gray-200 dark:border-gray-700 h-24 w-24 object-cover" %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <div class="col-span-1 md:col-span-2">
          <%= render partial: "shared/form_textarea", locals: {
            form: form,
            field: :description,
            label: "Description",
            placeholder: "Enter product description",
            rows: 3,
            wrapper_class: ""
          } %>
        </div>

        <div>
          <%= render partial: "shared/form_checkbox", locals: {
            form: form,
            field: :active,
            label: "Active",
            hint: "Inactive products won't appear in inventory reports",
            wrapper_class: ""
          } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Pricing Information -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="bg-gradient-to-r from-green-600 to-green-700 px-5 py-4">
      <h2 class="text-lg font-semibold text-white flex items-center">
        <i class="fas fa-tag mr-2"></i> Pricing
      </h2>
    </div>
    <div class="p-5">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= render partial: "shared/form_input", locals: {
            form: form,
            field: :cost_price,
            label: "Cost Price (₵)",
            type: "number",
            placeholder: "0.00",
            min: "0",
            step: "0.01",
            wrapper_class: ""
          } %>
        </div>

        <div>
          <%= render partial: "shared/form_input", locals: {
            form: form,
            field: :selling_price,
            label: "Selling Price (₵)",
            type: "number",
            placeholder: "0.00",
            min: "0",
            step: "0.01",
            wrapper_class: ""
          } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Inventory Settings -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="bg-gradient-to-r from-indigo-600 to-indigo-700 px-5 py-4">
      <h2 class="text-lg font-semibold text-white flex items-center">
        <i class="fas fa-warehouse mr-2"></i> Inventory Settings
      </h2>
    </div>
    <div class="p-5">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= render partial: "shared/form_input", locals: {
            form: form,
            field: :minimum_stock_level,
            label: "Minimum Stock Level",
            type: "number",
            placeholder: "0",
            min: "0",
            hint: "Alert when stock falls below this level",
            wrapper_class: ""
          } %>
        </div>

        <div>
          <%= render partial: "shared/form_input", locals: {
            form: form,
            field: :reorder_point,
            label: "Reorder Point",
            type: "number",
            placeholder: "0",
            min: "0",
            hint: "Stock level at which to reorder",
            wrapper_class: ""
          } %>
        </div>

        <div>
          <%= render partial: "shared/form_checkbox", locals: {
            form: form,
            field: :perishable,
            label: "Perishable Product",
            hint: "Product has an expiration date",
            wrapper_class: ""
          } %>
        </div>

        <div>
          <%= render partial: "shared/form_input", locals: {
            form: form,
            field: :expiry_date,
            label: "Expiry Date",
            type: "date",
            wrapper_class: ""
          } %>
        </div>
      </div>

      <% if product.new_record? %>
        <div class="mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Initial Inventory</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
            Add initial stock quantities for each location. Leave empty if no initial stock.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <% Location.order(name: :asc).each do |location| %>
              <div class="mb-4">
                <label for="initial_inventory_<%= location.id %>" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                  <%= location.name %> (<%= location.location_type.capitalize %>)
                </label>
                <input
                  type="number"
                  name="initial_inventory[<%= location.id %>]"
                  id="initial_inventory_<%= location.id %>"
                  min="0"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-[#00A86B]"
                  placeholder="0"
                >
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Physical Properties -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="bg-gradient-to-r from-amber-600 to-amber-700 px-5 py-4">
      <h2 class="text-lg font-semibold text-white flex items-center">
        <i class="fas fa-ruler-combined mr-2"></i> Physical Properties
      </h2>
    </div>
    <div class="p-5">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div>
          <%= render partial: "shared/form_input", locals: {
            form: form,
            field: :weight,
            label: "Weight (kg)",
            type: "number",
            placeholder: "0.00",
            min: "0",
            step: "0.01",
            wrapper_class: ""
          } %>
        </div>

        <div>
          <%= render partial: "shared/form_input", locals: {
            form: form,
            field: :length,
            label: "Length (cm)",
            type: "number",
            placeholder: "0.00",
            min: "0",
            step: "0.01",
            wrapper_class: ""
          } %>
        </div>

        <div>
          <%= render partial: "shared/form_input", locals: {
            form: form,
            field: :width,
            label: "Width (cm)",
            type: "number",
            placeholder: "0.00",
            min: "0",
            step: "0.01",
            wrapper_class: ""
          } %>
        </div>

        <div>
          <%= render partial: "shared/form_input", locals: {
            form: form,
            field: :height,
            label: "Height (cm)",
            type: "number",
            placeholder: "0.00",
            min: "0",
            step: "0.01",
            wrapper_class: ""
          } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Submit -->
  <div class="flex justify-between">
    <%= link_to "Cancel", product.persisted? ? product_path(product) : products_path, class: "inline-flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 shadow-sm text-sm font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>

    <%= form.submit class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
  </div>
<% end %>
