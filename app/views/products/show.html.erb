<div class="container mx-auto px-4 py-6">
  <!-- Breadcrumbs -->
  <nav class="mb-4 flex text-sm text-gray-500 dark:text-gray-400" aria-label="Breadcrumb">
    <ol class="inline-flex items-center space-x-1 md:space-x-3">
      <li class="inline-flex items-center">
        <%= link_to root_path, class: "inline-flex items-center hover:text-gray-900 dark:hover:text-white" do %>
          <i class="fas fa-home mr-2"></i>
          Home
        <% end %>
      </li>
      <li>
        <div class="flex items-center">
          <i class="fas fa-chevron-right text-gray-400 mx-2 text-xs"></i>
          <%= link_to "Products", products_path, class: "hover:text-gray-900 dark:hover:text-white" %>
        </div>
      </li>
      <li aria-current="page">
        <div class="flex items-center">
          <i class="fas fa-chevron-right text-gray-400 mx-2 text-xs"></i>
          <span class="text-gray-600 dark:text-gray-300">Product Details</span>
        </div>
      </li>
    </ol>
  </nav>

  <!-- Page Header -->
  <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-6">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white flex items-center">
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-indigo-600"><%= @product.name %></span>
        <% if @product.active? %>
          <span class="ml-3 px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300">
            Active
          </span>
        <% else %>
          <span class="ml-3 px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 dark:bg-red-900/40 text-red-800 dark:text-red-300">
            Inactive
          </span>
        <% end %>
      </h1>
      <p class="text-gray-600 dark:text-gray-400 mt-1">SKU: <%= @product.sku %></p>
    </div>

    <div class="mt-4 md:mt-0 flex space-x-3">
      <% if policy(@product).update? %>
        <%= link_to edit_product_path(@product), class: "flex items-center px-4 py-2 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors duration-200" do %>
          <i class="fas fa-edit text-gray-500 dark:text-gray-400 mr-2"></i>
          <span class="text-gray-700 dark:text-gray-300 text-sm font-medium">Edit</span>
        <% end %>
      <% end %>
      
      <% if policy(@product).destroy? %>
        <%= button_to product_path(@product), method: :delete, form: { data: { turbo_confirm: "Are you sure you want to delete this product?" } }, class: "flex items-center px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg shadow-sm transition-colors duration-200" do %>
          <i class="fas fa-trash mr-2"></i>
          <span class="text-sm font-medium">Delete</span>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Product Details -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main Details Card -->
    <div class="lg:col-span-2 bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
      <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-5 py-4">
        <h2 class="text-lg font-semibold text-white flex items-center">
          <i class="fas fa-info-circle mr-2"></i> Product Details
        </h2>
      </div>
      <div class="p-5">
        <% if @product.gallery_images.attached? %>
          <div class="mb-6 pb-6 border-b border-gray-200 dark:border-gray-700">
            <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400 mb-2">Product Images</h3>
            <div class="flex flex-wrap gap-4 mt-2 justify-center">
              <% @product.gallery_images.each do |image| %>
                <%= image_tag image.variant(resize_to_limit: [200, 200]), class: "rounded-lg shadow-md object-cover h-48 w-48" %>
              <% end %>
            </div>
          </div>
        <% end %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <div class="mb-4">
              <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">Name</h3>
              <p class="mt-1 text-lg text-gray-900 dark:text-white"><%= @product.name %></p>
            </div>
            <div class="mb-4">
              <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">SKU</h3>
              <p class="mt-1 text-lg text-gray-900 dark:text-white"><%= @product.sku %></p>
            </div>
            <div class="mb-4">
              <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">Barcode</h3>
              <p class="mt-1 text-lg text-gray-900 dark:text-white"><%= @product.barcode.present? ? @product.barcode : "N/A" %></p>
            </div>
          </div>
          <div>
            <div class="mb-4">
              <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">Category</h3>
              <p class="mt-1 text-lg text-gray-900 dark:text-white"><%= @product.category.present? ? @product.category : "N/A" %></p>
            </div>
            <div class="mb-4">
              <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">Brand</h3>
              <p class="mt-1 text-lg text-gray-900 dark:text-white"><%= @product.brand.present? ? @product.brand : "N/A" %></p>
            </div>
            <div class="mb-4">
              <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">Model</h3>
              <p class="mt-1 text-lg text-gray-900 dark:text-white"><%= @product.model.present? ? @product.model : "N/A" %></p>
            </div>
          </div>
        </div>

        <hr class="my-5 border-gray-200 dark:border-gray-700">

        <div class="mb-4">
          <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">Description</h3>
          <div class="mt-1 bg-gray-50 dark:bg-gray-700/50 rounded-lg p-3 text-gray-800 dark:text-gray-200">
            <%= @product.description.present? ? simple_format(@product.description) : "No description provided" %>
          </div>
        </div>

        <hr class="my-5 border-gray-200 dark:border-gray-700">

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-3 text-center">
            <p class="text-xs text-gray-500 dark:text-gray-400">Cost Price</p>
            <p class="text-xl font-bold text-blue-600 dark:text-blue-400">₵<%= number_with_precision(@product.cost_price, precision: 2) || "N/A" %></p>
          </div>
          <div class="bg-green-50 dark:bg-green-900/20 rounded-lg p-3 text-center">
            <p class="text-xs text-gray-500 dark:text-gray-400">Selling Price</p>
            <p class="text-xl font-bold text-green-600 dark:text-green-400">₵<%= number_with_precision(@product.selling_price, precision: 2) || "N/A" %></p>
          </div>
          <div class="bg-purple-50 dark:bg-purple-900/20 rounded-lg p-3 text-center">
            <p class="text-xs text-gray-500 dark:text-gray-400">Profit Margin</p>
            <p class="text-xl font-bold text-purple-600 dark:text-purple-400"><%= @product.profit_margin ? "#{@product.profit_margin}%" : "N/A" %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Sidebar Cards -->
    <div class="space-y-6">
      <!-- Inventory Summary Card -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
        <div class="bg-gradient-to-r from-indigo-600 to-indigo-700 px-5 py-4 flex justify-between items-center">
          <h2 class="text-lg font-semibold text-white flex items-center">
            <i class="fas fa-boxes mr-2"></i> Inventory Summary
          </h2>
        </div>
        <div class="p-5">
          <div class="flex items-center justify-between mb-6">
            <div>
              <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">Total Stock</h3>
              <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= @product.total_quantity %> <%= @product.unit_of_measure.pluralize(@product.total_quantity) %></p>
            </div>
            <div>
              <% if @product.low_stock? && @product.total_quantity > 0 %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 dark:bg-yellow-900/40 text-yellow-800 dark:text-yellow-300">
                  Low Stock
                </span>
              <% elsif @product.out_of_stock? %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 dark:bg-red-900/40 text-red-800 dark:text-red-300">
                  Out of Stock
                </span>
              <% else %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300">
                  In Stock
                </span>
              <% end %>
            </div>
          </div>

          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-500 dark:text-gray-400">Available</span>
              <span class="text-sm font-medium text-gray-900 dark:text-white"><%= @product.available_quantity %> <%= @product.unit_of_measure.pluralize(@product.available_quantity) %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-500 dark:text-gray-400">Reserved</span>
              <span class="text-sm font-medium text-gray-900 dark:text-white"><%= @product.reserved_quantity %> <%= @product.unit_of_measure.pluralize(@product.reserved_quantity) %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-500 dark:text-gray-400">Reorder Point</span>
              <span class="text-sm font-medium text-gray-900 dark:text-white"><%= @product.reorder_point %> <%= @product.unit_of_measure.pluralize(@product.reorder_point) %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-500 dark:text-gray-400">Minimum Stock</span>
              <span class="text-sm font-medium text-gray-900 dark:text-white"><%= @product.minimum_stock_level %> <%= @product.unit_of_measure.pluralize(@product.minimum_stock_level) %></span>
            </div>
          </div>

          <div class="mt-5 pt-5 border-t border-gray-200 dark:border-gray-700">
            <div class="flex space-x-2">
              <%= link_to inventory_path(product_id: @product.id), class: "flex-1 text-center py-2 px-3 bg-indigo-100 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 rounded-lg hover:bg-indigo-200 dark:hover:bg-indigo-800/30 transition-colors duration-200 text-sm font-medium" do %>
                View Inventory
              <% end %>
              <%= link_to inventory_transactions_path(product_id: @product.id), class: "flex-1 text-center py-2 px-3 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded-lg hover:bg-blue-200 dark:hover:bg-blue-800/30 transition-colors duration-200 text-sm font-medium" do %>
                Transactions
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Physical Properties Card -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
        <div class="bg-gradient-to-r from-amber-600 to-amber-700 px-5 py-4">
          <h2 class="text-lg font-semibold text-white flex items-center">
            <i class="fas fa-ruler-combined mr-2"></i> Physical Properties
          </h2>
        </div>
        <div class="p-5 space-y-4">
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500 dark:text-gray-400">Weight</span>
            <span class="text-sm font-medium text-gray-900 dark:text-white">
              <%= @product.weight ? "#{@product.weight} kg" : "Not specified" %>
            </span>
          </div>

          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500 dark:text-gray-400">Dimensions</span>
            <span class="text-sm font-medium text-gray-900 dark:text-white">
              <%= @product.format_dimensions %>
            </span>
          </div>

          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500 dark:text-gray-400">Unit of Measure</span>
            <span class="text-sm font-medium text-gray-900 dark:text-white"><%= @product.unit_of_measure %></span>
          </div>

          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500 dark:text-gray-400">Perishable</span>
            <span class="text-sm font-medium text-gray-900 dark:text-white">
              <%= @product.perishable? ? "Yes" : "No" %>
            </span>
          </div>

          <% if @product.perishable? && @product.expiry_date.present? %>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-500 dark:text-gray-400">Expiry Date</span>
              <span class="text-sm font-medium text-gray-900 dark:text-white">
                <%= @product.expiry_date.strftime("%b %d, %Y") %>
              </span>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Actions Card -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
        <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-5 py-4">
          <h2 class="text-lg font-semibold text-white flex items-center">
            <i class="fas fa-cog mr-2"></i> Actions
          </h2>
        </div>
        <div class="p-5">
          <div class="space-y-3">
            <% if policy(InventoryItem).adjust? %>
              <button type="button" data-action="click->modal#open" data-modal-target="add-stock-modal" class="w-full flex items-center p-3 bg-green-50 dark:bg-green-900/20 rounded-lg hover:bg-green-100 dark:hover:bg-green-900/30 transition-colors duration-150">
                <div class="h-8 w-8 rounded-full bg-green-100 dark:bg-green-900/40 flex items-center justify-center text-green-600 dark:text-green-400 mr-3">
                  <i class="fas fa-plus"></i>
                </div>
                <span class="text-sm font-medium text-gray-900 dark:text-white">Add Stock</span>
              </button>
              
              <button type="button" data-action="click->modal#open" data-modal-target="remove-stock-modal" class="w-full flex items-center p-3 bg-red-50 dark:bg-red-900/20 rounded-lg hover:bg-red-100 dark:hover:bg-red-900/30 transition-colors duration-150">
                <div class="h-8 w-8 rounded-full bg-red-100 dark:bg-red-900/40 flex items-center justify-center text-red-600 dark:text-red-400 mr-3">
                  <i class="fas fa-minus"></i>
                </div>
                <span class="text-sm font-medium text-gray-900 dark:text-white">Remove Stock</span>
              </button>
            <% end %>
            
            <% if policy(InventoryItem).transfer? %>
              <button type="button" data-action="click->modal#open" data-modal-target="transfer-stock-modal" class="w-full flex items-center p-3 bg-blue-50 dark:bg-blue-900/20 rounded-lg hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors duration-150">
                <div class="h-8 w-8 rounded-full bg-blue-100 dark:bg-blue-900/40 flex items-center justify-center text-blue-600 dark:text-blue-400 mr-3">
                  <i class="fas fa-exchange-alt"></i>
                </div>
                <span class="text-sm font-medium text-gray-900 dark:text-white">Transfer Stock</span>
              </button>
            <% end %>
            
            <% if @product.barcode.present? %>
              <div class="w-full flex items-center p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
                <div class="h-8 w-8 rounded-full bg-gray-100 dark:bg-gray-600 flex items-center justify-center text-gray-600 dark:text-gray-400 mr-3">
                  <i class="fas fa-barcode"></i>
                </div>
                <span class="text-sm font-medium text-gray-900 dark:text-white">Print Barcode</span>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Inventory by Location -->
  <div class="mt-6 bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="bg-gradient-to-r from-purple-600 to-purple-700 px-5 py-4">
      <h2 class="text-lg font-semibold text-white flex items-center">
        <i class="fas fa-map-marker-alt mr-2"></i> Inventory by Location
      </h2>
    </div>
    <div class="p-5">
      <% if @inventory_items.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-700">
              <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Location</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Type</th>
                <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Available</th>
                <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Reserved</th>
                <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Total</th>
                <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
              <% @inventory_items.each do |item| %>
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors duration-150">
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white">
                    <%= link_to item.location.name, location_path(item.location), class: "hover:text-blue-600 dark:hover:text-blue-400" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                    <%= item.location.location_type.capitalize %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-900 dark:text-white">
                    <%= item.available_quantity %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-900 dark:text-white">
                    <%= item.reserved_quantity %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-900 dark:text-white font-medium">
                    <%= item.quantity %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-right">
                    <% if item.quantity == 0 %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 dark:bg-red-900/40 text-red-800 dark:text-red-300">
                        Out of Stock
                      </span>
                    <% elsif item.quantity <= @product.reorder_point %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 dark:bg-yellow-900/40 text-yellow-800 dark:text-yellow-300">
                        Low Stock
                      </span>
                    <% else %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300">
                        In Stock
                      </span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-8">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-purple-100 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400 mb-4">
            <i class="fas fa-box-open text-xl"></i>
          </div>
          <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No Inventory Found</h3>
          <p class="text-gray-500 dark:text-gray-400 mb-4">This product has no inventory records yet.</p>
          <% if policy(InventoryItem).adjust? %>
            <button type="button" data-action="click->modal#open" data-modal-target="add-stock-modal" class="inline-flex items-center px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg shadow-sm transition-colors duration-200">
              <i class="fas fa-plus mr-2"></i> Add Initial Stock
            </button>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Recent Transactions -->
  <div class="mt-6 bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="bg-gradient-to-r from-green-600 to-green-700 px-5 py-4 flex justify-between items-center">
      <h2 class="text-lg font-semibold text-white flex items-center">
        <i class="fas fa-history mr-2"></i> Recent Transactions
      </h2>
      <%= link_to inventory_transactions_path(product_id: @product.id), class: "text-white bg-white/20 hover:bg-white/30 rounded-lg px-2 py-1 text-xs font-medium transition-colors duration-200" do %>
        View All
      <% end %>
    </div>
    <div class="p-5">
      <% if @recent_transactions.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-700">
              <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Date</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Type</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Locations</th>
                <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Quantity</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">User</th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
              <% @recent_transactions.each do |transaction| %>
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors duration-150">
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                    <%= transaction.created_at.strftime("%b %d, %Y %H:%M") %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% color_class = 
                      case transaction.transaction_type
                      when 'purchase', 'receipt', 'return', 'stock_addition'
                        'bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300'
                      when 'sale', 'shipment', 'damage', 'expiry', 'stock_removal'
                        'bg-red-100 dark:bg-red-900/40 text-red-800 dark:text-red-300'
                      when 'transfer'
                        'bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300'
                      else
                        'bg-gray-100 dark:bg-gray-900/40 text-gray-800 dark:text-gray-300'
                      end
                    %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= color_class %>">
                      <%= transaction.transaction_type.titleize %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
                    <%= transaction.location_summary %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-right font-medium <%= transaction.quantity.positive? ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
                    <%= transaction.quantity.positive? ? "+#{transaction.quantity}" : transaction.quantity %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                    <%= transaction.user.name %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-6">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400 mb-3">
            <i class="fas fa-history"></i>
          </div>
          <p class="text-gray-500 dark:text-gray-400">No transaction history found</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Stock Adjustment Modals would be included here in a real implementation -->
