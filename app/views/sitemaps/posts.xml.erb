<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:news="http://www.google.com/schemas/sitemap-news/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml"
        xmlns:mobile="http://www.google.com/schemas/sitemap-mobile/1.0"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1"
        xmlns:video="http://www.google.com/schemas/sitemap-video/1.1">

  <% @posts.find_each do |post| %>
    <url>
      <loc><%= post_url(post) %></loc>
      <lastmod><%= post.updated_at.iso8601 %></lastmod>
      <changefreq>monthly</changefreq>
      <priority><%= post.media_type == 'article' ? '0.8' : '0.9' %></priority>
      
      <%# Image information %>
      <% if post.featured_image.attached? %>
        <image:image>
          <image:loc><%= url_for(post.featured_image) %></image:loc>
          <image:caption><%= post.title %></image:caption>
          <image:title><%= post.meta_title.presence || post.title %></image:title>
        </image:image>
      <% end %>
      
      <%# Video information %>
      <% if post.media_type == 'video' && post.has_media? %>
        <video:video>
          <video:thumbnail_loc><%= post.thumbnail_url || (post.featured_image.attached? ? url_for(post.featured_image) : '') %></video:thumbnail_loc>
          <video:title><%= post.title %></video:title>
          <video:description><%= post.excerpt || post.meta_description || post.content.to_plain_text.truncate(160) %></video:description>
          <% if post.primary_media_url.present? %>
            <video:content_loc><%= post.primary_media_url %></video:content_loc>
          <% end %>
          <% if post.media_duration.present? %>
            <video:duration><%= post.media_duration %></video:duration>
          <% end %>
          <video:publication_date><%= post.published_at.iso8601 %></video:publication_date>
          <% post.categories.each do |category| %>
            <video:category><%= category.name %></video:category>
          <% end %>
          <% post.tags.limit(5).each do |tag| %>
            <video:tag><%= tag.name %></video:tag>
          <% end %>
        </video:video>
      <% end %>
      
      <%# News information for recent posts %>
      <% if post.published_at > 2.days.ago %>
        <news:news>
          <news:publication>
            <news:name>SupplyFlow Blog</news:name>
            <news:language>en</news:language>
          </news:publication>
          <news:publication_date><%= post.published_at.iso8601 %></news:publication_date>
          <news:title><%= post.title %></news:title>
          <% if post.keywords.present? %>
            <news:keywords><%= post.keywords %></news:keywords>
          <% end %>
        </news:news>
      <% end %>
    </url>
  <% end %>
</urlset>