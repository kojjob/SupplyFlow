<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml"
        xmlns:mobile="http://www.google.com/schemas/sitemap-mobile/1.0">

  <%# Homepage %>
  <url>
    <loc><%= root_url %></loc>
    <lastmod><%= Date.current.iso8601 %></lastmod>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  
  <%# Blog index page %>
  <url>
    <loc><%= posts_url %></loc>
    <lastmod><%= @posts.maximum(:updated_at)&.iso8601 || Date.current.iso8601 %></lastmod>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>
  
  <%# Dashboard (if publicly accessible) %>
  <url>
    <loc><%= dashboard_index_url %></loc>
    <lastmod><%= Date.current.iso8601 %></lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.6</priority>
  </url>
  
  <%# Add other static/important pages %>
  <%# You can add more static pages here like About, Contact, etc. %>
</urlset>