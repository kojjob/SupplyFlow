<div class="container mx-auto px-4 py-6">
  <!-- Page Header -->
  <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-6">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-indigo-600">Inventory</span>
      </h1>
      <p class="text-gray-600 dark:text-gray-400 mt-1">Manage your stock levels across all locations</p>
    </div>

    <div class="mt-4 md:mt-0 flex space-x-3">
      <%= link_to inventory_transactions_path, class: "flex items-center px-4 py-2 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors duration-200" do %>
        <i class="fas fa-history text-gray-500 dark:text-gray-400 mr-2"></i>
        <span class="text-gray-700 dark:text-gray-300 text-sm font-medium">Transactions</span>
      <% end %>
      
      <%= link_to inventory_report_path, class: "flex items-center px-4 py-2 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors duration-200" do %>
        <i class="fas fa-chart-bar text-gray-500 dark:text-gray-400 mr-2"></i>
        <span class="text-gray-700 dark:text-gray-300 text-sm font-medium">Reports</span>
      <% end %>
    </div>
  </div>

  <!-- Search and Filters -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700 mb-6">
    <div class="p-5">
      <%= form_with url: inventory_path, method: :get, class: "space-y-4" do |form| %>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div>
            <label for="query" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Search</label>
            <%= form.text_field :query, value: params[:query], placeholder: "Product name or SKU", class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-700 shadow-sm focus:border-blue-500 focus:ring focus:ring-blue-500 focus:ring-opacity-50 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100" %>
          </div>
          
          <div>
            <label for="location_id" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Location</label>
            <%= form.select :location_id, 
                options_for_select([["All Locations", ""]] + Location.order(:name).map { |l| [l.name, l.id] }, params[:location_id]), 
                {}, 
                { class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-700 shadow-sm focus:border-blue-500 focus:ring focus:ring-blue-500 focus:ring-opacity-50 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100" } %>
          </div>
          
          <div>
            <label for="status" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Stock Status</label>
            <%= form.select :status, 
                options_for_select([
                  ["All", ""], 
                  ["Available", "available"], 
                  ["Reserved", "reserved"],
                  ["Damaged", "damaged"],
                  ["Expired", "expired"]
                ], params[:status]), 
                {}, 
                { class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-700 shadow-sm focus:border-blue-500 focus:ring focus:ring-blue-500 focus:ring-opacity-50 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100" } %>
          </div>
          
          <div class="flex items-end">
            <%= form.submit "Apply Filters", class: "block w-full py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors duration-200" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Inventory List -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-5 py-4 flex justify-between items-center">
      <h2 class="text-lg font-semibold text-white flex items-center">
        <i class="fas fa-boxes mr-2"></i> Current Stock
      </h2>
      <% if @location.present? %>
        <span class="text-white bg-white/20 rounded-lg px-2 py-1 text-xs font-medium">
          Location: <%= @location.name %>
        </span>
      <% end %>
    </div>

    <% if @inventory_items.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
          <thead class="bg-gray-50 dark:bg-gray-700">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Product</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Location</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Available</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Reserved</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Total</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
            <% @inventory_items.each do |item| %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors duration-150">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="h-10 w-10 flex-shrink-0">
                      <div class="h-10 w-10 rounded-lg bg-gray-100 dark:bg-gray-700 flex items-center justify-center text-gray-500 dark:text-gray-400">
                        <i class="fas fa-box"></i>
                      </div>
                    </div>
                    <div class="ml-4">
                      <div class="text-sm font-medium text-gray-900 dark:text-white">
                        <%= link_to item.product.name, product_path(item.product), class: "hover:text-blue-600 dark:hover:text-blue-400" %>
                      </div>
                      <div class="text-sm text-gray-500 dark:text-gray-400">
                        <%= item.product.sku %>
                      </div>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-gray-900 dark:text-white">
                    <%= link_to item.location.name, location_path(item.location), class: "hover:text-blue-600 dark:hover:text-blue-400" %>
                  </div>
                  <div class="text-sm text-gray-500 dark:text-gray-400">
                    <%= item.location.location_type.capitalize %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-900 dark:text-white">
                  <%= item.available_quantity %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-900 dark:text-white">
                  <%= item.reserved_quantity %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-right font-medium text-gray-900 dark:text-white">
                  <%= item.quantity %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right">
                  <% if item.quantity == 0 %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 dark:bg-red-900/40 text-red-800 dark:text-red-300">
                      Out of Stock
                    </span>
                  <% elsif item.product.reorder_point.present? && item.quantity <= item.product.reorder_point %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 dark:bg-yellow-900/40 text-yellow-800 dark:text-yellow-300">
                      Low Stock
                    </span>
                  <% else %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300">
                      In Stock
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <div class="flex items-center justify-end space-x-2">
                    <% if policy(item).adjust? %>
                      <button type="button" class="text-green-600 dark:text-green-400 hover:text-green-900 dark:hover:text-green-300" data-action="click->modal#open" data-modal-target="adjust-stock-modal-<%= item.id %>">
                        <i class="fas fa-plus-minus"></i>
                      </button>
                    <% end %>
                    
                    <% if policy(item).transfer? && item.quantity > 0 %>
                      <button type="button" class="text-blue-600 dark:text-blue-400 hover:text-blue-900 dark:hover:text-blue-300" data-action="click->modal#open" data-modal-target="transfer-stock-modal-<%= item.id %>">
                        <i class="fas fa-exchange-alt"></i>
                      </button>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      
      <div class="p-4 border-t border-gray-200 dark:border-gray-700">
        <%# Pagination goes here if you have a pagination gem installed %>
      </div>
    <% else %>
      <div class="p-6 text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 mb-4">
          <i class="fas fa-boxes text-xl"></i>
        </div>
        <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No Inventory Found</h3>
        <p class="text-gray-500 dark:text-gray-400 mb-4">
          <% if params[:query].present? || params[:location_id].present? || params[:status].present? %>
            No inventory items match your search criteria. Try adjusting your filters.
          <% else %>
            Get started by adding products and stock to your inventory.
          <% end %>
        </p>
        
        <% if !params[:query].present? && !params[:location_id].present? && !params[:status].present? %>
          <%= link_to new_product_path, class: "inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg shadow-sm transition-colors duration-200" do %>
            <i class="fas fa-plus mr-2"></i> Add Products
          <% end %>
        <% else %>
          <%= link_to inventory_path, class: "inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg shadow-sm transition-colors duration-200" do %>
            <i class="fas fa-times mr-2"></i> Clear Filters
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Stock Level Overview -->
  <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- Low Stock Card -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
      <div class="bg-gradient-to-r from-yellow-500 to-yellow-600 px-5 py-4">
        <h2 class="text-lg font-semibold text-white flex items-center">
          <i class="fas fa-exclamation-triangle mr-2"></i> Low Stock Items
        </h2>
      </div>
      <div class="p-5">
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center">
            <div class="h-12 w-12 rounded-full bg-yellow-100 dark:bg-yellow-900/30 flex items-center justify-center text-yellow-600 dark:text-yellow-400 mr-3">
              <i class="fas fa-chart-line text-xl"></i>
            </div>
            <div>
              <p class="text-gray-500 dark:text-gray-400 text-sm">Products Below Reorder Point</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">
                <%= policy_scope(Product).low_stock.count %>
              </p>
            </div>
          </div>
        </div>
        
        <%= link_to products_path(stock_status: "low_stock"), class: "w-full text-center block py-2 px-4 bg-yellow-50 dark:bg-yellow-900/20 text-yellow-700 dark:text-yellow-300 rounded-lg hover:bg-yellow-100 dark:hover:bg-yellow-900/30 transition-colors duration-200 text-sm font-medium" do %>
          View Low Stock Items
        <% end %>
      </div>
    </div>

    <!-- Out of Stock Card -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
      <div class="bg-gradient-to-r from-red-500 to-red-600 px-5 py-4">
        <h2 class="text-lg font-semibold text-white flex items-center">
          <i class="fas fa-times-circle mr-2"></i> Out of Stock Items
        </h2>
      </div>
      <div class="p-5">
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center">
            <div class="h-12 w-12 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center text-red-600 dark:text-red-400 mr-3">
              <i class="fas fa-box-open text-xl"></i>
            </div>
            <div>
              <p class="text-gray-500 dark:text-gray-400 text-sm">Products With Zero Stock</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">
                <%= policy_scope(Product).out_of_stock.count %>
              </p>
            </div>
          </div>
        </div>
        
        <%= link_to products_path(stock_status: "out_of_stock"), class: "w-full text-center block py-2 px-4 bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-300 rounded-lg hover:bg-red-100 dark:hover:bg-red-900/30 transition-colors duration-200 text-sm font-medium" do %>
          View Out of Stock Items
        <% end %>
      </div>
    </div>

    <!-- Total Value Card -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
      <div class="bg-gradient-to-r from-green-500 to-green-600 px-5 py-4">
        <h2 class="text-lg font-semibold text-white flex items-center">
          <i class="fas fa-money-bill-wave mr-2"></i> Inventory Value
        </h2>
      </div>
      <div class="p-5">
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center">
            <div class="h-12 w-12 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center text-green-600 dark:text-green-400 mr-3">
              <i class="fas fa-dollar-sign text-xl"></i>
            </div>
            <div>
              <p class="text-gray-500 dark:text-gray-400 text-sm">Total Stock Value</p>
              <p class="text-2xl font-bold text-gray-900 dark:text-white">
                ₵<%= number_with_precision(policy_scope(InventoryItem).joins(:product).sum('inventory_items.quantity * products.cost_price'), precision: 2) %>
              </p>
            </div>
          </div>
        </div>
        
        <%= link_to inventory_report_path, class: "w-full text-center block py-2 px-4 bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 rounded-lg hover:bg-green-100 dark:hover:bg-green-900/30 transition-colors duration-200 text-sm font-medium" do %>
          View Inventory Reports
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Stock adjustment and transfer modals would be included here in a real implementation -->