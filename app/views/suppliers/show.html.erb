<div class="container mx-auto px-4 py-6">
  <!-- Page Header with Breadcrumbs -->
  <div class="mb-6">
    <nav class="flex mb-3" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <%= link_to root_path, class: "inline-flex items-center text-sm font-medium text-gray-700 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white" do %>
            <i class="fas fa-home mr-2"></i>
            Home
          <% end %>
        </li>
        <li>
          <div class="flex items-center">
            <i class="fas fa-chevron-right text-gray-400 mx-2 text-xs"></i>
            <%= link_to suppliers_path, class: "text-sm font-medium text-gray-700 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white" do %>
              Suppliers
            <% end %>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <i class="fas fa-chevron-right text-gray-400 mx-2 text-xs"></i>
            <span class="text-sm font-medium text-gray-500 dark:text-gray-400"><%= @supplier.name %></span>
          </div>
        </li>
      </ol>
    </nav>
    
    <div class="flex flex-col md:flex-row md:items-center justify-between">
      <div class="flex items-center">
        <div class="h-16 w-16 bg-blue-100 dark:bg-blue-900/30 rounded-full flex items-center justify-center mr-4">
          <i class="fas fa-building text-blue-600 dark:text-blue-400 text-2xl"></i>
        </div>
        <div>
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white flex items-center">
            <%= @supplier.name %>
            <% if @supplier.active? %>
              <span class="ml-3 px-2 py-1 text-xs font-semibold rounded-full bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300">
                Active
              </span>
            <% else %>
              <span class="ml-3 px-2 py-1 text-xs font-semibold rounded-full bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-300">
                Inactive
              </span>
            <% end %>
          </h1>
          <p class="text-gray-600 dark:text-gray-400 mt-1">
            <% if @supplier.city.present? && @supplier.country.present? %>
              <i class="fas fa-map-marker-alt mr-1"></i> <%= @supplier.city %>, <%= @supplier.country %>
            <% end %>
          </p>
        </div>
      </div>
      
      <div class="mt-4 md:mt-0 flex flex-wrap gap-3">
        <% if policy(@supplier).update? %>
          <%= link_to edit_supplier_path(@supplier), class: "flex items-center px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg shadow-sm transition-colors duration-200" do %>
            <i class="fas fa-edit mr-2"></i>
            <span class="text-sm font-medium">Edit</span>
          <% end %>
        <% end %>
        
        <% if policy(PurchaseOrder).create? %>
          <%= link_to new_purchase_order_path(supplier_id: @supplier.id), class: "flex items-center px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg shadow-sm transition-colors duration-200" do %>
            <i class="fas fa-file-invoice mr-2"></i>
            <span class="text-sm font-medium">Create Purchase Order</span>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Supplier Details -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <!-- Contact Information -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
      <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-5 py-4">
        <h2 class="text-lg font-semibold text-white flex items-center">
          <i class="fas fa-address-card mr-2"></i> Contact Information
        </h2>
      </div>
      <div class="p-5">
        <dl class="grid grid-cols-1 gap-y-4">
          <% if @supplier.contact_person.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Contact Person</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= @supplier.contact_person %></dd>
            </div>
          <% end %>
          
          <% if @supplier.email.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Email</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white">
                <a href="mailto:<%= @supplier.email %>" class="text-blue-600 dark:text-blue-400 hover:underline">
                  <%= @supplier.email %>
                </a>
              </dd>
            </div>
          <% end %>
          
          <% if @supplier.phone.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Phone</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white">
                <a href="tel:<%= @supplier.phone %>" class="text-blue-600 dark:text-blue-400 hover:underline">
                  <%= @supplier.phone %>
                </a>
              </dd>
            </div>
          <% end %>
          
          <% if @supplier.address.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Address</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white">
                <%= @supplier.address %>
                <% if @supplier.city.present? || @supplier.state.present? || @supplier.postal_code.present? %>
                  <br>
                  <%= [@supplier.city, @supplier.state, @supplier.postal_code].compact.join(', ') %>
                <% end %>
                <% if @supplier.country.present? %>
                  <br>
                  <%= @supplier.country %>
                <% end %>
              </dd>
            </div>
          <% end %>
        </dl>
      </div>
    </div>

    <!-- Business Information -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
      <div class="bg-gradient-to-r from-indigo-600 to-indigo-700 px-5 py-4">
        <h2 class="text-lg font-semibold text-white flex items-center">
          <i class="fas fa-briefcase mr-2"></i> Business Information
        </h2>
      </div>
      <div class="p-5">
        <dl class="grid grid-cols-1 gap-y-4">
          <% if @supplier.tax_id.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Tax ID</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= @supplier.tax_id %></dd>
            </div>
          <% end %>
          
          <% if @supplier.registration_number.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Registration Number</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= @supplier.registration_number %></dd>
            </div>
          <% end %>
          
          <% if @supplier.payment_terms.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Payment Terms</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white"><%= @supplier.payment_terms %></dd>
            </div>
          <% end %>
          
          <% if @supplier.credit_limit.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Credit Limit</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white">₵<%= number_with_precision(@supplier.credit_limit, precision: 2) %></dd>
            </div>
          <% end %>
        </dl>
      </div>
    </div>

    <!-- Notes -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
      <div class="bg-gradient-to-r from-purple-600 to-purple-700 px-5 py-4">
        <h2 class="text-lg font-semibold text-white flex items-center">
          <i class="fas fa-sticky-note mr-2"></i> Notes
        </h2>
      </div>
      <div class="p-5">
        <% if @supplier.notes.present? %>
          <div class="text-sm text-gray-900 dark:text-white whitespace-pre-line"><%= @supplier.notes %></div>
        <% else %>
          <div class="text-sm text-gray-500 dark:text-gray-400 italic">No notes available</div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Purchase Orders -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl overflow-hidden border border-gray-200 dark:border-gray-700 mb-6">
    <div class="bg-gradient-to-r from-green-600 to-green-700 px-5 py-4 flex justify-between items-center">
      <h2 class="text-lg font-semibold text-white flex items-center">
        <i class="fas fa-file-invoice mr-2"></i> Recent Purchase Orders
      </h2>
      <% if policy(PurchaseOrder).create? %>
        <%= link_to new_purchase_order_path(supplier_id: @supplier.id), class: "text-white bg-white/20 hover:bg-white/30 rounded-lg px-3 py-1 text-xs font-medium transition-colors duration-200" do %>
          <i class="fas fa-plus mr-1"></i> New Order
        <% end %>
      <% end %>
    </div>

    <% if @purchase_orders.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
          <thead class="bg-gray-50 dark:bg-gray-700">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Order #</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Date</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Total</th>
              <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
            <% @purchase_orders.each do |order| %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors duration-150">
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white">
                  <%= link_to order.order_number, purchase_order_path(order), class: "text-blue-600 dark:text-blue-400 hover:underline" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                  <%= order.order_date&.strftime("%b %d, %Y") || order.created_at.strftime("%b %d, %Y") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-900 dark:text-white">
                  ₵<%= number_with_precision(order.total_amount, precision: 2) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-center">
                  <% case order.status %>
                  <% when 'draft' %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-300">
                      Draft
                    </span>
                  <% when 'pending' %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 dark:bg-yellow-900/40 text-yellow-800 dark:text-yellow-300">
                      Pending
                    </span>
                  <% when 'approved' %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300">
                      Approved
                    </span>
                  <% when 'received' %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300">
                      Received
                    </span>
                  <% when 'canceled' %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 dark:bg-red-900/40 text-red-800 dark:text-red-300">
                      Canceled
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <%= link_to purchase_order_path(order), class: "text-blue-600 dark:text-blue-400 hover:text-blue-900 dark:hover:text-blue-300 mx-1" do %>
                    <i class="fas fa-eye"></i>
                  <% end %>
                  
                  <% if policy(order).update? && order.status == 'draft' %>
                    <%= link_to edit_purchase_order_path(order), class: "text-indigo-600 dark:text-indigo-400 hover:text-indigo-900 dark:hover:text-indigo-300 mx-1" do %>
                      <i class="fas fa-edit"></i>
                    <% end %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      
      <div class="p-4 border-t border-gray-200 dark:border-gray-700 text-center">
        <%= link_to purchase_orders_path(supplier_id: @supplier.id), class: "text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 text-sm font-medium" do %>
          View All Purchase Orders <i class="fas fa-arrow-right ml-1"></i>
        <% end %>
      </div>
    <% else %>
      <div class="p-6 text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400 mb-4">
          <i class="fas fa-file-invoice text-xl"></i>
        </div>
        <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No Purchase Orders Yet</h3>
        <p class="text-gray-500 dark:text-gray-400 mb-4">
          You haven't created any purchase orders with this supplier yet.
        </p>
        
        <% if policy(PurchaseOrder).create? %>
          <%= link_to new_purchase_order_path(supplier_id: @supplier.id), class: "inline-flex items-center px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg shadow-sm transition-colors duration-200" do %>
            <i class="fas fa-plus mr-2"></i> Create Purchase Order
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
