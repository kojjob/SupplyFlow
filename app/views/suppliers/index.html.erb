<div class="container mx-auto px-4 py-6">
  <!-- Page Header -->
  <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-6">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-indigo-600">Suppliers</span>
      </h1>
      <p class="text-gray-600 dark:text-gray-400 mt-1">Manage your supplier relationships</p>
    </div>
    
    <div class="mt-4 md:mt-0 flex flex-wrap gap-3">
      <% if policy(Supplier).create? %>
        <%= link_to new_supplier_path, class: "flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg shadow-sm transition-colors duration-200" do %>
          <i class="fas fa-plus mr-2"></i>
          <span class="text-sm font-medium">Add Supplier</span>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Search and Filters -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700 mb-6">
    <div class="p-5">
      <%= form_with url: suppliers_path, method: :get, class: "space-y-4" do |form| %>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <label for="query" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Search</label>
            <%= form.text_field :query, value: params[:query], placeholder: "Supplier name, email or phone", class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-700 shadow-sm focus:border-blue-500 focus:ring focus:ring-blue-500 focus:ring-opacity-50 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100" %>
          </div>
          
          <div>
            <label for="active" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Status</label>
            <%= form.select :active, 
                options_for_select([
                  ["All", ""], 
                  ["Active", "true"], 
                  ["Inactive", "false"]
                ], params[:active]), 
                {}, 
                { class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-700 shadow-sm focus:border-blue-500 focus:ring focus:ring-blue-500 focus:ring-opacity-50 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100" } %>
          </div>
          
          <div class="flex items-end">
            <%= form.submit "Search", class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg shadow-sm transition-colors duration-200" %>
            
            <% if params[:query].present? || params[:active].present? %>
              <%= link_to suppliers_path, class: "ml-2 px-4 py-2 bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-200 rounded-lg shadow-sm transition-colors duration-200" do %>
                <i class="fas fa-times mr-1"></i> Clear
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Suppliers List -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-5 py-4">
      <h2 class="text-lg font-semibold text-white flex items-center">
        <i class="fas fa-building mr-2"></i> Suppliers Directory
      </h2>
    </div>

    <% if @suppliers.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
          <thead class="bg-gray-50 dark:bg-gray-700">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Name</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Contact</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Location</th>
              <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
            <% @suppliers.each do |supplier| %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors duration-150">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="flex-shrink-0 h-10 w-10 bg-blue-100 dark:bg-blue-900/30 rounded-full flex items-center justify-center">
                      <i class="fas fa-building text-blue-600 dark:text-blue-400"></i>
                    </div>
                    <div class="ml-4">
                      <div class="text-sm font-medium text-gray-900 dark:text-white">
                        <%= link_to supplier.name, supplier_path(supplier), class: "hover:text-blue-600 dark:hover:text-blue-400" %>
                      </div>
                      <% if supplier.tax_id.present? %>
                        <div class="text-xs text-gray-500 dark:text-gray-400">
                          Tax ID: <%= supplier.tax_id %>
                        </div>
                      <% end %>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-gray-900 dark:text-white"><%= supplier.contact_person %></div>
                  <div class="text-xs text-gray-500 dark:text-gray-400">
                    <% if supplier.email.present? %>
                      <div><i class="fas fa-envelope mr-1"></i> <%= supplier.email %></div>
                    <% end %>
                    <% if supplier.phone.present? %>
                      <div><i class="fas fa-phone mr-1"></i> <%= supplier.phone %></div>
                    <% end %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-gray-900 dark:text-white"><%= supplier.city %></div>
                  <div class="text-xs text-gray-500 dark:text-gray-400"><%= supplier.country %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-center">
                  <% if supplier.active? %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300">
                      Active
                    </span>
                  <% else %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-300">
                      Inactive
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <%= link_to supplier_path(supplier), class: "text-blue-600 dark:text-blue-400 hover:text-blue-900 dark:hover:text-blue-300 mx-1" do %>
                    <i class="fas fa-eye"></i>
                  <% end %>
                  
                  <% if policy(supplier).update? %>
                    <%= link_to edit_supplier_path(supplier), class: "text-indigo-600 dark:text-indigo-400 hover:text-indigo-900 dark:hover:text-indigo-300 mx-1" do %>
                      <i class="fas fa-edit"></i>
                    <% end %>
                  <% end %>
                  
                  <% if policy(supplier).destroy? && supplier.purchase_orders.none? %>
                    <%= link_to supplier_path(supplier), 
                        data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this supplier?" },
                        class: "text-red-600 dark:text-red-400 hover:text-red-900 dark:hover:text-red-300 mx-1" do %>
                      <i class="fas fa-trash"></i>
                    <% end %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      
      <div class="p-4 border-t border-gray-200 dark:border-gray-700">
        <%= render partial: "shared/pagination", locals: { total_count: @total_count, per_page: 25, current_page: params[:page].to_i || 0 } %>
      </div>
    <% else %>
      <div class="p-6 text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 mb-4">
          <i class="fas fa-building text-xl"></i>
        </div>
        <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No Suppliers Found</h3>
        <p class="text-gray-500 dark:text-gray-400 mb-4">
          <% if params[:query].present? || params[:active].present? %>
            No suppliers match your search criteria. Try adjusting your filters.
          <% else %>
            Get started by adding your first supplier.
          <% end %>
        </p>
        
        <% if policy(Supplier).create? %>
          <%= link_to new_supplier_path, class: "inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg shadow-sm transition-colors duration-200" do %>
            <i class="fas fa-plus mr-2"></i> Add Supplier
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
