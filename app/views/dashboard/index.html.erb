<div class="container mx-auto px-4 py-6">
  <!-- Dashboard Header -->
  <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-6">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-indigo-600">Dashboard</span>
      </h1>
      <p class="text-gray-600 dark:text-gray-400 mt-1">Welcome back, <%= current_user.name.split.first %>! Here's what's happening today.</p>
    </div>

    <div class="mt-4 md:mt-0 flex space-x-3">
      <button class="flex items-center px-4 py-2 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors duration-200">
        <i class="fas fa-download text-gray-500 dark:text-gray-400 mr-2"></i>
        <span class="text-gray-700 dark:text-gray-300 text-sm font-medium">Export</span>
      </button>
      <button class="flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg shadow-sm transition-colors duration-200">
        <i class="fas fa-plus mr-2"></i>
        <span class="text-sm font-medium">New Order</span>
      </button>
    </div>
  </div>

  <!-- Main Content -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl overflow-hidden border border-gray-200 dark:border-gray-700">
    <!-- Welcome Banner -->
    <div class="relative bg-gradient-to-r from-blue-500 to-indigo-600 px-6 py-8 md:py-12">
      <div class="absolute inset-0 opacity-10">
        <svg class="h-full w-full" viewBox="0 0 800 800">
          <path d="M435.5,160.5Q432,321,271.5,321.5Q111,322,110.5,481Q110,640,275,640.5Q440,641,518.5,480.5Q597,320,435.5,160.5Z" fill="white"></path>
        </svg>
      </div>
      <div class="relative z-10 max-w-3xl">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">Welcome to SupplyFlow</h2>
        <p class="text-blue-100 text-lg mb-6">Your comprehensive inventory management solution for growing businesses.</p>
        <div class="flex flex-wrap gap-3">
          <a href="#" class="inline-flex items-center px-4 py-2 bg-white text-blue-600 rounded-lg shadow-md hover:bg-blue-50 transition-colors duration-200 text-sm font-medium">
            <i class="fas fa-play-circle mr-2"></i> Watch Tutorial
          </a>
          <a href="#" class="inline-flex items-center px-4 py-2 bg-blue-700 text-white rounded-lg shadow-md hover:bg-blue-800 transition-colors duration-200 text-sm font-medium">
            <i class="fas fa-rocket mr-2"></i> Quick Setup Guide
          </a>
        </div>
      </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 p-6">
      <!-- Inventory Card -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-shadow duration-300">
        <div class="p-5">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Total Inventory</p>
              <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-1">1,254</h3>
            </div>
            <div class="h-12 w-12 bg-blue-100 dark:bg-blue-900/50 rounded-lg flex items-center justify-center">
              <i class="fas fa-box text-blue-600 dark:text-blue-400 text-xl"></i>
            </div>
          </div>
          <div class="mt-4 flex items-center">
            <span class="text-green-500 dark:text-green-400 flex items-center text-sm font-medium">
              <i class="fas fa-arrow-up mr-1"></i> 12.5%
            </span>
            <span class="text-gray-500 dark:text-gray-400 text-sm ml-2">from last month</span>
          </div>
        </div>
        <div class="bg-gray-50 dark:bg-gray-700/50 px-5 py-2">
          <a href="#" class="text-sm text-blue-600 dark:text-blue-400 font-medium hover:text-blue-800 dark:hover:text-blue-300 flex items-center">
            View Details <i class="fas fa-chevron-right ml-1 text-xs"></i>
          </a>
        </div>
      </div>

      <!-- Orders Card -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-shadow duration-300">
        <div class="p-5">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Pending Orders</p>
              <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-1">25</h3>
            </div>
            <div class="h-12 w-12 bg-purple-100 dark:bg-purple-900/50 rounded-lg flex items-center justify-center">
              <i class="fas fa-shopping-cart text-purple-600 dark:text-purple-400 text-xl"></i>
            </div>
          </div>
          <div class="mt-4 flex items-center">
            <span class="text-red-500 dark:text-red-400 flex items-center text-sm font-medium">
              <i class="fas fa-arrow-down mr-1"></i> 3.2%
            </span>
            <span class="text-gray-500 dark:text-gray-400 text-sm ml-2">from last month</span>
          </div>
        </div>
        <div class="bg-gray-50 dark:bg-gray-700/50 px-5 py-2">
          <a href="#" class="text-sm text-purple-600 dark:text-purple-400 font-medium hover:text-purple-800 dark:hover:text-purple-300 flex items-center">
            View Orders <i class="fas fa-chevron-right ml-1 text-xs"></i>
          </a>
        </div>
      </div>

      <!-- Revenue Card -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-shadow duration-300">
        <div class="p-5">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Monthly Revenue</p>
              <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-1">₵24,500</h3>
            </div>
            <div class="h-12 w-12 bg-green-100 dark:bg-green-900/50 rounded-lg flex items-center justify-center">
              <i class="fas fa-chart-line text-green-600 dark:text-green-400 text-xl"></i>
            </div>
          </div>
          <div class="mt-4 flex items-center">
            <span class="text-green-500 dark:text-green-400 flex items-center text-sm font-medium">
              <i class="fas fa-arrow-up mr-1"></i> 8.1%
            </span>
            <span class="text-gray-500 dark:text-gray-400 text-sm ml-2">from last month</span>
          </div>
        </div>
        <div class="bg-gray-50 dark:bg-gray-700/50 px-5 py-2">
          <a href="#" class="text-sm text-green-600 dark:text-green-400 font-medium hover:text-green-800 dark:hover:text-green-300 flex items-center">
            View Reports <i class="fas fa-chevron-right ml-1 text-xs"></i>
          </a>
        </div>
      </div>

      <!-- User Card -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-shadow duration-300">
        <div class="p-5">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Team Members</p>
              <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-1">8</h3>
            </div>
            <div class="h-12 w-12 bg-amber-100 dark:bg-amber-900/50 rounded-lg flex items-center justify-center">
              <i class="fas fa-users text-amber-600 dark:text-amber-400 text-xl"></i>
            </div>
          </div>
          <div class="mt-4 flex items-center">
            <span class="text-green-500 dark:text-green-400 flex items-center text-sm font-medium">
              <i class="fas fa-plus mr-1"></i> 2 new
            </span>
            <span class="text-gray-500 dark:text-gray-400 text-sm ml-2">this month</span>
          </div>
        </div>
        <div class="bg-gray-50 dark:bg-gray-700/50 px-5 py-2">
          <a href="#" class="text-sm text-amber-600 dark:text-amber-400 font-medium hover:text-amber-800 dark:hover:text-amber-300 flex items-center">
            Manage Team <i class="fas fa-chevron-right ml-1 text-xs"></i>
          </a>
        </div>
      </div>
    </div>

    <!-- Charts Section -->
    <div class="px-6 pb-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Sales Chart -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
          <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-5 py-4 flex justify-between items-center">
            <h2 class="text-lg font-semibold text-white flex items-center">
              <i class="fas fa-chart-line mr-2"></i> Sales Overview
            </h2>
            <div class="flex space-x-2">
              <button class="text-white bg-white/20 hover:bg-white/30 rounded-lg px-2 py-1 text-xs font-medium transition-colors duration-200">
                Weekly
              </button>
              <button class="text-white bg-white/30 hover:bg-white/40 rounded-lg px-2 py-1 text-xs font-medium transition-colors duration-200">
                Monthly
              </button>
              <button class="text-white bg-white/10 hover:bg-white/30 rounded-lg px-2 py-1 text-xs font-medium transition-colors duration-200">
                Yearly
              </button>
            </div>
          </div>
          <div class="p-5">
            <div class="relative h-80">
              <!-- Chart Placeholder - In a real app, you would use a charting library like Chart.js -->
              <div class="absolute inset-0 flex items-center justify-center">
                <svg class="w-full h-64" viewBox="0 0 400 200" xmlns="http://www.w3.org/2000/svg">
                  <!-- Grid Lines -->
                  <line x1="0" y1="40" x2="400" y2="40" stroke="#e5e7eb" stroke-width="1" />
                  <line x1="0" y1="80" x2="400" y2="80" stroke="#e5e7eb" stroke-width="1" />
                  <line x1="0" y1="120" x2="400" y2="120" stroke="#e5e7eb" stroke-width="1" />
                  <line x1="0" y1="160" x2="400" y2="160" stroke="#e5e7eb" stroke-width="1" />

                  <!-- Chart Lines -->
                  <polyline
                    points="20,160 60,140 100,100 140,120 180,80 220,60 260,40 300,60 340,20 380,40"
                    fill="none"
                    stroke="#3b82f6"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />

                  <!-- Area Fill -->
                  <path
                    d="M20,160 L60,140 L100,100 L140,120 L180,80 L220,60 L260,40 L300,60 L340,20 L380,40 L380,200 L20,200 Z"
                    fill="url(#blue-gradient)"
                    opacity="0.2"
                  />

                  <!-- Data Points -->
                  <circle cx="20" cy="160" r="4" fill="#3b82f6" />
                  <circle cx="60" cy="140" r="4" fill="#3b82f6" />
                  <circle cx="100" cy="100" r="4" fill="#3b82f6" />
                  <circle cx="140" cy="120" r="4" fill="#3b82f6" />
                  <circle cx="180" cy="80" r="4" fill="#3b82f6" />
                  <circle cx="220" cy="60" r="4" fill="#3b82f6" />
                  <circle cx="260" cy="40" r="4" fill="#3b82f6" />
                  <circle cx="300" cy="60" r="4" fill="#3b82f6" />
                  <circle cx="340" cy="20" r="4" fill="#3b82f6" />
                  <circle cx="380" cy="40" r="4" fill="#3b82f6" />

                  <!-- Gradient Definition -->
                  <defs>
                    <linearGradient id="blue-gradient" x1="0%" y1="0%" x2="0%" y2="100%">
                      <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.8" />
                      <stop offset="100%" stop-color="#3b82f6" stop-opacity="0.1" />
                    </linearGradient>
                  </defs>
                </svg>
              </div>

              <!-- X-axis Labels -->
              <div class="absolute bottom-0 left-0 right-0 flex justify-between text-xs text-gray-500 dark:text-gray-400 px-4">
                <span>Jan</span>
                <span>Feb</span>
                <span>Mar</span>
                <span>Apr</span>
                <span>May</span>
                <span>Jun</span>
                <span>Jul</span>
                <span>Aug</span>
                <span>Sep</span>
                <span>Oct</span>
              </div>
            </div>

            <div class="grid grid-cols-3 gap-4 mt-2">
              <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-3 text-center">
                <p class="text-xs text-gray-500 dark:text-gray-400">Total Sales</p>
                <p class="text-lg font-bold text-blue-600 dark:text-blue-400">₵124,500</p>
              </div>
              <div class="bg-green-50 dark:bg-green-900/20 rounded-lg p-3 text-center">
                <p class="text-xs text-gray-500 dark:text-gray-400">Growth</p>
                <p class="text-lg font-bold text-green-600 dark:text-green-400">+12.5%</p>
              </div>
              <div class="bg-purple-50 dark:bg-purple-900/20 rounded-lg p-3 text-center">
                <p class="text-xs text-gray-500 dark:text-gray-400">Customers</p>
                <p class="text-lg font-bold text-purple-600 dark:text-purple-400">45</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Inventory Status -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
          <div class="bg-gradient-to-r from-purple-600 to-purple-700 px-5 py-4 flex justify-between items-center">
            <h2 class="text-lg font-semibold text-white flex items-center">
              <i class="fas fa-boxes mr-2"></i> Inventory Status
            </h2>
            <button class="text-white bg-white/20 hover:bg-white/30 rounded-lg px-3 py-1 text-xs font-medium transition-colors duration-200">
              <i class="fas fa-sync-alt mr-1"></i> Refresh
            </button>
          </div>
          <div class="p-5">
            <div class="flex items-center justify-between mb-6">
              <div>
                <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">Stock Level Overview</h3>
                <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1">1,254 Items</p>
              </div>
              <div class="flex space-x-2">
                <div class="flex items-center">
                  <div class="w-3 h-3 rounded-full bg-green-500 mr-1"></div>
                  <span class="text-xs text-gray-500 dark:text-gray-400">In Stock</span>
                </div>
                <div class="flex items-center">
                  <div class="w-3 h-3 rounded-full bg-yellow-500 mr-1"></div>
                  <span class="text-xs text-gray-500 dark:text-gray-400">Low Stock</span>
                </div>
                <div class="flex items-center">
                  <div class="w-3 h-3 rounded-full bg-red-500 mr-1"></div>
                  <span class="text-xs text-gray-500 dark:text-gray-400">Out of Stock</span>
                </div>
              </div>
            </div>

            <!-- Donut Chart Placeholder -->
            <div class="flex justify-center mb-6">
              <div class="relative w-48 h-48">
                <svg viewBox="0 0 100 100" class="w-full h-full">
                  <!-- Background Circle -->
                  <circle cx="50" cy="50" r="40" fill="none" stroke="#e5e7eb" stroke-width="10" />

                  <!-- Green Segment (70%) -->
                  <circle cx="50" cy="50" r="40" fill="none" stroke="#10b981" stroke-width="10" stroke-dasharray="175.9 251.3" stroke-dashoffset="0" transform="rotate(-90 50 50)" />

                  <!-- Yellow Segment (20%) -->
                  <circle cx="50" cy="50" r="40" fill="none" stroke="#f59e0b" stroke-width="10" stroke-dasharray="50.3 251.3" stroke-dashoffset="-175.9" transform="rotate(-90 50 50)" />

                  <!-- Red Segment (10%) -->
                  <circle cx="50" cy="50" r="40" fill="none" stroke="#ef4444" stroke-width="10" stroke-dasharray="25.1 251.3" stroke-dashoffset="-226.2" transform="rotate(-90 50 50)" />
                </svg>

                <!-- Center Text -->
                <div class="absolute inset-0 flex flex-col items-center justify-center">
                  <span class="text-3xl font-bold text-gray-900 dark:text-white">70%</span>
                  <span class="text-xs text-gray-500 dark:text-gray-400">In Stock</span>
                </div>
              </div>
            </div>

            <!-- Inventory Table -->
            <div class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                <thead class="bg-gray-50 dark:bg-gray-700">
                  <tr>
                    <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Product</th>
                    <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
                    <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Quantity</th>
                  </tr>
                </thead>
                <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                  <tr>
                    <td class="px-4 py-2 whitespace-nowrap text-sm text-gray-900 dark:text-white">Product A</td>
                    <td class="px-4 py-2 whitespace-nowrap">
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 dark:bg-green-900/50 text-green-800 dark:text-green-200">
                        In Stock
                      </span>
                    </td>
                    <td class="px-4 py-2 whitespace-nowrap text-sm text-gray-900 dark:text-white">245</td>
                  </tr>
                  <tr>
                    <td class="px-4 py-2 whitespace-nowrap text-sm text-gray-900 dark:text-white">Product B</td>
                    <td class="px-4 py-2 whitespace-nowrap">
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 dark:bg-yellow-900/50 text-yellow-800 dark:text-yellow-200">
                        Low Stock
                      </span>
                    </td>
                    <td class="px-4 py-2 whitespace-nowrap text-sm text-gray-900 dark:text-white">12</td>
                  </tr>
                  <tr>
                    <td class="px-4 py-2 whitespace-nowrap text-sm text-gray-900 dark:text-white">Product C</td>
                    <td class="px-4 py-2 whitespace-nowrap">
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 dark:bg-red-900/50 text-red-800 dark:text-red-200">
                        Out of Stock
                      </span>
                    </td>
                    <td class="px-4 py-2 whitespace-nowrap text-sm text-gray-900 dark:text-white">0</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div class="mt-4 text-center">
              <a href="#" class="text-purple-600 dark:text-purple-400 hover:text-purple-800 dark:hover:text-purple-300 text-sm font-medium">
                View All Inventory
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Actions and Account Info -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 px-6 pb-6">
      <!-- Account Info -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
        <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-5 py-4">
          <h2 class="text-lg font-semibold text-white flex items-center">
            <i class="fas fa-user-circle mr-2"></i> Your Account
          </h2>
        </div>
        <div class="p-5">
          <div class="flex items-center mb-4">
            <div class="h-12 w-12 rounded-full bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center text-blue-600 dark:text-blue-400 font-bold text-xl">
              <%= current_user.name.split.map(&:first).join("")[0..1].upcase %>
            </div>
            <div class="ml-4">
              <h3 class="font-medium text-gray-900 dark:text-white"><%= current_user.name %></h3>
              <p class="text-sm text-gray-500 dark:text-gray-400"><%= current_user.role.titleize %></p>
            </div>
          </div>
          <div class="space-y-3 text-sm">
            <div class="flex">
              <div class="w-24 flex-shrink-0 text-gray-500 dark:text-gray-400">Organization:</div>
              <div class="text-gray-900 dark:text-white font-medium"><%= current_user.organization.name %></div>
            </div>
            <div class="flex">
              <div class="w-24 flex-shrink-0 text-gray-500 dark:text-gray-400">Email:</div>
              <div class="text-gray-900 dark:text-white font-medium"><%= current_user.email %></div>
            </div>
            <div class="flex">
              <div class="w-24 flex-shrink-0 text-gray-500 dark:text-gray-400">Last Login:</div>
              <div class="text-gray-900 dark:text-white font-medium"><%= current_user.last_sign_in_at&.strftime("%b %d, %Y at %I:%M %p") || "Never" %></div>
            </div>
          </div>
          <div class="mt-5 pt-4 border-t border-gray-200 dark:border-gray-700">
            <a href="#" class="text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 text-sm font-medium">
              Edit Profile
            </a>
          </div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
        <div class="bg-gradient-to-r from-indigo-600 to-indigo-700 px-5 py-4">
          <h2 class="text-lg font-semibold text-white flex items-center">
            <i class="fas fa-bolt mr-2"></i> Quick Actions
          </h2>
        </div>
        <div class="p-5">
          <div class="grid grid-cols-2 gap-3">
            <%= link_to locations_path, class: "flex flex-col items-center justify-center p-4 bg-gray-50 dark:bg-gray-700 rounded-lg hover:bg-indigo-50 dark:hover:bg-indigo-900/30 transition-colors duration-200 group" do %>
              <div class="h-10 w-10 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mb-2 group-hover:bg-indigo-200 dark:group-hover:bg-indigo-800/50 transition-colors duration-200">
                <i class="fas fa-map-marker-alt"></i>
              </div>
              <span class="text-sm font-medium text-gray-700 dark:text-gray-300 group-hover:text-indigo-700 dark:group-hover:text-indigo-300 transition-colors duration-200">Locations</span>
            <% end %>
            <a href="#" class="flex flex-col items-center justify-center p-4 bg-gray-50 dark:bg-gray-700 rounded-lg hover:bg-indigo-50 dark:hover:bg-indigo-900/30 transition-colors duration-200 group">
              <div class="h-10 w-10 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mb-2 group-hover:bg-indigo-200 dark:group-hover:bg-indigo-800/50 transition-colors duration-200">
                <i class="fas fa-shopping-cart"></i>
              </div>
              <span class="text-sm font-medium text-gray-700 dark:text-gray-300 group-hover:text-indigo-700 dark:group-hover:text-indigo-300 transition-colors duration-200">Orders</span>
            </a>
            <a href="#" class="flex flex-col items-center justify-center p-4 bg-gray-50 dark:bg-gray-700 rounded-lg hover:bg-indigo-50 dark:hover:bg-indigo-900/30 transition-colors duration-200 group">
