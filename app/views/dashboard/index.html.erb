<div class="container mx-auto px-4 py-6">
  <!-- Dashboard Header -->
  <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-6">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-indigo-600">Dashboard</span>
      </h1>
      <p class="text-gray-600 dark:text-gray-400 mt-1">Welcome back, <%= current_user.name.split.first %>! Here's what's happening today.</p>
    </div>

    <div class="mt-4 md:mt-0 flex space-x-3">
      <button class="flex items-center px-4 py-2 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors duration-200">
        <i class="fas fa-download text-gray-500 dark:text-gray-400 mr-2"></i>
        <span class="text-gray-700 dark:text-gray-300 text-sm font-medium">Export</span>
      </button>
      <button class="flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg shadow-sm transition-colors duration-200">
        <i class="fas fa-plus mr-2"></i>
        <span class="text-sm font-medium">New Order</span>
      </button>
    </div>
  </div>

  <!-- Main Content -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl overflow-hidden border border-gray-200 dark:border-gray-700">
    <!-- Welcome Banner -->
    <div class="relative bg-gradient-to-r from-blue-500 to-indigo-600 px-6 py-8 md:py-12">
      <div class="absolute inset-0 opacity-10">
        <svg class="h-full w-full" viewBox="0 0 800 800">
          <path d="M435.5,160.5Q432,321,271.5,321.5Q111,322,110.5,481Q110,640,275,640.5Q440,641,518.5,480.5Q597,320,435.5,160.5Z" fill="white"></path>
        </svg>
      </div>
      <div class="relative z-10 max-w-3xl">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">Welcome to SupplyFlow</h2>
        <p class="text-blue-100 text-lg mb-6">Your comprehensive inventory management solution for growing businesses.</p>
        <div class="flex flex-wrap gap-3">
          <a href="https://www.youtube.com/results?search_query=inventory+management+software+tutorial" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-4 py-2 bg-white text-blue-600 rounded-lg shadow-md hover:bg-blue-50 transition-colors duration-200 text-sm font-medium">
            <i class="fas fa-play-circle mr-2"></i> Watch Tutorial
          </a>
          <a href="<%= setup_guide_path %>" class="inline-flex items-center px-4 py-2 bg-blue-700 text-white rounded-lg shadow-md hover:bg-blue-800 transition-colors duration-200 text-sm font-medium">
            <i class="fas fa-rocket mr-2"></i> Quick Setup Guide
          </a>
        </div>
      </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 p-6">
      <!-- Inventory Card -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-shadow duration-300">
        <div class="p-5">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Total Units in Stock</p>
              <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= number_with_delimiter(@analytics[:total_units_in_stock].to_i) %></h3>
            </div>
            <div class="h-12 w-12 bg-blue-100 dark:bg-blue-900/50 rounded-lg flex items-center justify-center">
              <i class="fas fa-box text-blue-600 dark:text-blue-400 text-xl"></i>
            </div>
          </div>
          <div class="mt-4 flex items-center">
            <span class="text-green-500 dark:text-green-400 flex items-center text-sm font-medium">
              <i class="fas fa-arrow-up mr-1"></i> 12.5%
            </span>
            <span class="text-gray-500 dark:text-gray-400 text-sm ml-2">from last month</span>
          </div>
        </div>
        <div class="bg-gray-50 dark:bg-gray-700/50 px-5 py-2">
          <%= link_to inventory_path, class: "text-sm text-blue-600 dark:text-blue-400 font-medium hover:text-blue-800 dark:hover:text-blue-300 flex items-center" do %>
            View Details <i class="fas fa-chevron-right ml-1 text-xs"></i>
          <% end %>
        </div>
      </div>

      <!-- Orders Card -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-shadow duration-300">
        <div class="p-5">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Pending Orders</p>
              <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-1">25</h3>
            </div>
            <div class="h-12 w-12 bg-purple-100 dark:bg-purple-900/50 rounded-lg flex items-center justify-center">
              <i class="fas fa-shopping-cart text-purple-600 dark:text-purple-400 text-xl"></i>
            </div>
          </div>
          <div class="mt-4 flex items-center">
            <span class="text-red-500 dark:text-red-400 flex items-center text-sm font-medium">
              <i class="fas fa-arrow-down mr-1"></i> 3.2%
            </span>
            <span class="text-gray-500 dark:text-gray-400 text-sm ml-2">from last month</span>
          </div>
        </div>
        <div class="bg-gray-50 dark:bg-gray-700/50 px-5 py-2">
          <%= link_to pending_orders_path, class: "text-sm text-purple-600 dark:text-purple-400 font-medium hover:text-purple-800 dark:hover:text-purple-300 flex items-center" do %>
            View Orders <i class="fas fa-chevron-right ml-1 text-xs"></i>
          <% end %>
        </div>
      </div>

      <!-- Revenue Card -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-shadow duration-300">
        <div class="p-5">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Monthly Revenue</p>
              <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-1">₵24,500</h3>
            </div>
            <div class="h-12 w-12 bg-green-100 dark:bg-green-900/50 rounded-lg flex items-center justify-center">
              <i class="fas fa-chart-line text-green-600 dark:text-green-400 text-xl"></i>
            </div>
          </div>
          <div class="mt-4 flex items-center">
            <span class="text-green-500 dark:text-green-400 flex items-center text-sm font-medium">
              <i class="fas fa-arrow-up mr-1"></i> 8.1%
            </span>
            <span class="text-gray-500 dark:text-gray-400 text-sm ml-2">from last month</span>
          </div>
        </div>
        <div class="bg-gray-50 dark:bg-gray-700/50 px-5 py-2">
          <%= link_to inventory_report_path, class: "text-sm text-green-600 dark:text-green-400 font-medium hover:text-green-800 dark:hover:text-green-300 flex items-center" do %>
            View Reports <i class="fas fa-chevron-right ml-1 text-xs"></i>
          <% end %>
        </div>
      </div>

      <!-- User Card -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-shadow duration-300">
        <div class="p-5">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Team Members</p>
              <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-1">8</h3>
            </div>
            <div class="h-12 w-12 bg-amber-100 dark:bg-amber-900/50 rounded-lg flex items-center justify-center">
              <i class="fas fa-users text-amber-600 dark:text-amber-400 text-xl"></i>
            </div>
          </div>
          <div class="mt-4 flex items-center">
            <span class="text-green-500 dark:text-green-400 flex items-center text-sm font-medium">
              <i class="fas fa-plus mr-1"></i> 2 new
            </span>
            <span class="text-gray-500 dark:text-gray-400 text-sm ml-2">this month</span>
          </div>
        </div>
        <div class="bg-gray-50 dark:bg-gray-700/50 px-5 py-2">
          <%= link_to settings_users_path, class: "text-sm text-amber-600 dark:text-amber-400 font-medium hover:text-amber-800 dark:hover:text-amber-300 flex items-center" do %>
            Manage Team <i class="fas fa-chevron-right ml-1 text-xs"></i>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Analytics Dashboard Section -->
    <div data-controller="analytics" class="px-6 pb-6">
      <!-- Dashboard Filters -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700 mb-6">
        <div class="p-4">
          <div class="flex flex-wrap justify-between items-center">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white flex items-center mb-4 md:mb-0">
              <i class="fas fa-chart-pie mr-2 text-blue-600 dark:text-blue-400"></i> Analytics Dashboard
            </h2>

            <div class="flex flex-wrap gap-2">
              <button
                data-action="analytics#filterDateRange"
                data-range="week"
                class="bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-blue-200 dark:hover:bg-blue-900/50 transition-colors duration-200"
              >
                Last 7 Days
              </button>
              <button
                data-action="analytics#filterDateRange"
                data-range="month"
                class="bg-blue-500 text-white px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-blue-600 transition-colors duration-200"
              >
                Last 30 Days
              </button>
              <button
                data-action="analytics#filterDateRange"
                data-range="quarter"
                class="bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-blue-200 dark:hover:bg-blue-900/50 transition-colors duration-200"
              >
                Last 90 Days
              </button>
              <button
                data-action="analytics#filterDateRange"
                data-range="year"
                class="bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 px-3 py-1.5 rounded-lg text-sm font-medium hover:bg-blue-200 dark:hover:bg-blue-900/50 transition-colors duration-200"
              >
                Last Year
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Key Performance Indicators -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
        <!-- Total Inventory KPI -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-shadow duration-300">
          <div class="p-5">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Total Inventory Value</p>
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-1">₵<%= number_with_delimiter(@analytics[:total_stock_value].to_i) %></h3>
              </div>
              <div class="h-12 w-12 bg-blue-100 dark:bg-blue-900/50 rounded-lg flex items-center justify-center">
                <i class="fas fa-coins text-blue-600 dark:text-blue-400 text-xl"></i>
              </div>
            </div>
            <div class="mt-4 flex items-center">
              <span class="text-green-500 dark:text-green-400 flex items-center text-sm font-medium">
                <i class="fas fa-arrow-up mr-1"></i> <%= rand(5..15) %>%
              </span>
              <span class="text-gray-500 dark:text-gray-400 text-sm ml-2">from last month</span>
            </div>
          </div>
        </div>

        <!-- Stock Status KPI -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-shadow duration-300">
          <div class="p-5">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Low Stock SKUs</p>
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= @analytics[:low_stock_count] %> <span class="text-sm text-gray-500 dark:text-gray-400 font-normal">/ <%= @analytics[:total_product_skus] %></span></h3>
              </div>
              <div class="h-12 w-12 bg-yellow-100 dark:bg-yellow-900/50 rounded-lg flex items-center justify-center">
                <i class="fas fa-exclamation-triangle text-yellow-600 dark:text-yellow-400 text-xl"></i>
              </div>
            </div>
            <div class="mt-4">
              <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2.5">
                <%
                  # Handle low_stock_count if it's a hash (product_id => count)
                  low_stock_count = if @analytics[:low_stock_count].is_a?(Hash)
                                     @analytics[:low_stock_count].values.sum
                                   elsif @analytics[:low_stock_count].is_a?(Numeric)
                                     @analytics[:low_stock_count]
                                   else
                                     0
                                   end

                  total_product_skus_for_calc = @analytics[:total_product_skus].is_a?(Numeric) ? @analytics[:total_product_skus] : 1
                  percentage = total_product_skus_for_calc > 0 ? ((low_stock_count.to_f / total_product_skus_for_calc) * 100).round : 0
                %>
                <div class="bg-yellow-500 h-2.5 rounded-full" style="width: <%= percentage %>%"></div>
              </div>
              <div class="flex justify-between mt-1">
                <span class="text-xs text-gray-500 dark:text-gray-400"><%= percentage %>% of total SKUs</span>
                <span class="text-xs text-yellow-600 dark:text-yellow-400 font-medium">Needs attention</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Transaction Activity KPI -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-shadow duration-300">
          <div class="p-5">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Transactions (Today)</p>
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= @analytics[:transactions_today] %></h3>
              </div>
              <div class="h-12 w-12 bg-purple-100 dark:bg-purple-900/50 rounded-lg flex items-center justify-center">
                <i class="fas fa-exchange-alt text-purple-600 dark:text-purple-400 text-xl"></i>
              </div>
            </div>
            <div class="mt-4 flex items-center">
              <% if @analytics[:transactions_today] > 0 %>
                <span class="text-green-500 dark:text-green-400 flex items-center text-sm font-medium">
                  <i class="fas fa-arrow-up mr-1"></i> <%= @analytics[:transactions_today] %> new
                </span>
              <% else %>
                <span class="text-gray-500 dark:text-gray-400 flex items-center text-sm font-medium">
                  <i class="fas fa-minus mr-1"></i> No activity today
                </span>
              <% end %>
              <span class="text-gray-500 dark:text-gray-400 text-sm ml-2">Weekly total: <%= @analytics[:transactions_this_week] %></span>
            </div>
          </div>
        </div>

        <!-- Locations KPI -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700 hover:shadow-lg transition-shadow duration-300">
          <div class="p-5">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Active Locations</p>
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= @analytics[:active_locations] %> <span class="text-sm text-gray-500 dark:text-gray-400 font-normal">/ <%= @analytics[:total_locations] %></span></h3>
              </div>
              <div class="h-12 w-12 bg-green-100 dark:bg-green-900/50 rounded-lg flex items-center justify-center">
                <i class="fas fa-map-marker-alt text-green-600 dark:text-green-400 text-xl"></i>
              </div>
            </div>
            <div class="mt-4 flex flex-col">
              <% total_loc = @analytics[:total_locations].to_i %>
              <% active_loc = @analytics[:active_locations].to_f %>
              <% active_locations_percentage = total_loc > 0 ? (active_loc / total_loc * 100).round : 0 %>
              <div class="flex items-center space-x-4">
                <div class="w-full h-2 bg-gray-200 dark:bg-gray-700 rounded-full">
                  <div class="h-2 bg-green-500 rounded-full" style="width: <%= active_locations_percentage %>%"></div>
                </div>
                <span class="text-xs font-medium text-gray-700 dark:text-gray-300 whitespace-nowrap"><%= active_locations_percentage %>%</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Charts Row 1 -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
        <!-- Inventory Trend Chart -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
          <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-5 py-4 flex justify-between items-center">
            <h2 class="text-lg font-semibold text-white flex items-center">
              <i class="fas fa-chart-line mr-2"></i> Inventory Trend
            </h2>
            <div class="flex space-x-2">
              <button data-action="analytics#filterDateRange" data-range="quarter" class="text-white bg-white/20 hover:bg-white/30 rounded-lg px-2 py-1 text-xs font-medium transition-colors duration-200">
                3 Months
              </button>
              <button data-action="analytics#filterDateRange" data-range="half_year" class="text-white bg-white/30 hover:bg-white/40 rounded-lg px-2 py-1 text-xs font-medium transition-colors duration-200">
                6 Months
              </button>
              <button data-action="analytics#filterDateRange" data-range="year" class="text-white bg-white/10 hover:bg-white/30 rounded-lg px-2 py-1 text-xs font-medium transition-colors duration-200">
                1 Year
              </button>
            </div>
          </div>
          <div class="p-5">
            <div
              class="h-80"
              data-analytics-target="inventoryTrendChart"
              data-chart="<%= @chart_data[:inventory_trend].to_json %>"
            ></div>
          </div>
        </div>

        <!-- Transaction Type Chart -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
          <div class="bg-gradient-to-r from-purple-600 to-purple-700 px-5 py-4 flex justify-between items-center">
            <h2 class="text-lg font-semibold text-white flex items-center">
              <i class="fas fa-chart-pie mr-2"></i> Transaction Types
            </h2>
            <button class="text-white bg-white/20 hover:bg-white/30 rounded-lg px-3 py-1 text-xs font-medium transition-colors duration-200">
              <i class="fas fa-sync-alt mr-1"></i> Refresh
            </button>
          </div>
          <div class="p-5">
            <div
              class="h-80 flex items-center justify-center"
              data-analytics-target="transactionTypeChart"
              data-chart="<%= @chart_data[:transactions_by_type].to_json %>"
            ></div>
          </div>
        </div>
      </div>

      <!-- Charts Row 2 -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Inventory by Location Chart -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
          <div class="bg-gradient-to-r from-green-600 to-green-700 px-5 py-4">
            <h2 class="text-lg font-semibold text-white flex items-center">
              <i class="fas fa-map-marker-alt mr-2"></i> Inventory by Location
            </h2>
          </div>
          <div class="p-5">
            <div
              class="h-80 flex items-center justify-center"
              data-analytics-target="inventoryLocationChart"
              data-chart="<%= @chart_data[:inventory_by_location].to_json %>"
            ></div>
            <div class="text-center mt-4">
              <%= link_to locations_path, class: "text-green-600 dark:text-green-400 hover:text-green-800 dark:hover:text-green-300 text-sm font-medium" do %>
                View All Locations
              <% end %>
            </div>
          </div>
        </div>

        <!-- Inventory Status Chart -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
          <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-5 py-4">
            <h2 class="text-lg font-semibold text-white flex items-center">
              <i class="fas fa-boxes mr-2"></i> Inventory Status
            </h2>
          </div>
          <div class="p-5">
            <div
              class="h-80 flex items-center justify-center"
              data-analytics-target="inventoryStatusChart"
              data-chart="<%= @analytics[:inventory_by_status].to_json %>"
            ></div>
            <div class="text-center mt-4">
              <%= link_to inventory_path, class: "text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 text-sm font-medium" do %>
                View Inventory Details
              <% end %>
            </div>
          </div>
        </div>

        <!-- Category Value Chart -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
          <div class="bg-gradient-to-r from-indigo-600 to-indigo-700 px-5 py-4">
            <h2 class="text-lg font-semibold text-white flex items-center">
              <i class="fas fa-tags mr-2"></i> Value by Category
            </h2>
          </div>
          <div class="p-5">
            <div
              class="h-80 flex items-center justify-center"
              data-analytics-target="categoryValueChart"
              data-chart="<%= @chart_data[:inventory_value_by_category].to_json %>"
            ></div>
            <div class="text-center mt-4">
              <%= link_to products_path, class: "text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 text-sm font-medium" do %>
                View Categories
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Transactions -->
      <div class="mt-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
          <div class="bg-gradient-to-r from-amber-500 to-amber-600 px-5 py-4 flex justify-between items-center">
            <h2 class="text-lg font-semibold text-white flex items-center">
              <i class="fas fa-history mr-2"></i> Recent Transactions
            </h2>
            <%= link_to inventory_transactions_path, class: "text-white bg-white/20 hover:bg-white/30 rounded-lg px-3 py-1 text-xs font-medium transition-colors duration-200" do %>
              View All
            <% end %>
          </div>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
              <thead class="bg-gray-50 dark:bg-gray-700">
                <tr>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Product</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Type</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Location</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Quantity</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Date</th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">User</th>
                </tr>
              </thead>
              <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                <% @analytics[:recent_transactions].each do |transaction| %>
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors duration-150">
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
                    <%= transaction.product.name %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% badge_color = case transaction.transaction_type
                         when 'purchase', 'receipt', 'return', 'stock_addition' then 'green'
                         when 'sale', 'shipment', 'damage', 'expiry', 'stock_removal' then 'red'
                         when 'transfer' then 'blue'
                         else 'gray'
                       end
                    %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-<%= badge_color %>-100 dark:bg-<%= badge_color %>-900/50 text-<%= badge_color %>-800 dark:text-<%= badge_color %>-200">
                      <%= transaction.transaction_type_name %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700 dark:text-gray-300">
                    <%= transaction.location_summary %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">
                    <%= transaction.quantity %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                    <%= transaction.created_at.strftime("%b %d, %Y %H:%M") %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700 dark:text-gray-300">
                    <%= transaction.user.name %>
                  </td>
                </tr>
                <% end %>
              </tbody>
            </table>
          </div>
          <div class="p-4 border-t border-gray-200 dark:border-gray-700 text-center">
            <%= link_to inventory_transactions_path, class: "text-amber-600 dark:text-amber-400 hover:text-amber-800 dark:hover:text-amber-300 text-sm font-medium" do %>
              View All Transactions
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Actions and Account Info -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 px-6 pb-6">
      <!-- Account Info -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
        <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-5 py-4">
          <h2 class="text-lg font-semibold text-white flex items-center">
            <i class="fas fa-user-circle mr-2"></i> Your Account
          </h2>
        </div>
        <div class="p-5">
          <div class="flex items-center mb-4">
            <div class="h-12 w-12 rounded-full bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center text-blue-600 dark:text-blue-400 font-bold text-xl">
              <%= current_user.name.split.map(&:first).join("")[0..1].upcase %>
            </div>
            <div class="ml-4">
              <h3 class="font-medium text-gray-900 dark:text-white"><%= current_user.name %></h3>
              <p class="text-sm text-gray-500 dark:text-gray-400"><%= current_user.role.titleize %></p>
            </div>
          </div>
          <div class="space-y-3 text-sm">
            <div class="flex">
              <div class="w-24 flex-shrink-0 text-gray-500 dark:text-gray-400">Organization:</div>
              <div class="text-gray-900 dark:text-white font-medium"><%= current_user.organization.name %></div>
            </div>
            <div class="flex">
              <div class="w-24 flex-shrink-0 text-gray-500 dark:text-gray-400">Email:</div>
              <div class="text-gray-900 dark:text-white font-medium"><%= current_user.email %></div>
            </div>
            <div class="flex">
              <div class="w-24 flex-shrink-0 text-gray-500 dark:text-gray-400">Last Login:</div>
              <div class="text-gray-900 dark:text-white font-medium"><%= current_user.last_sign_in_at&.strftime("%b %d, %Y at %I:%M %p") || "Never" %></div>
            </div>
          </div>
          <div class="mt-5 pt-4 border-t border-gray-200 dark:border-gray-700">
            <%= link_to settings_profile_path, class: "text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 text-sm font-medium" do %>
              Edit Profile
            <% end %>
          </div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
        <div class="bg-gradient-to-r from-indigo-600 to-indigo-700 px-5 py-4">
          <h2 class="text-lg font-semibold text-white flex items-center">
            <i class="fas fa-bolt mr-2"></i> Quick Actions
          </h2>
        </div>
        <div class="p-5">
          <div class="grid grid-cols-2 gap-3">
            <%= link_to locations_path, class: "flex flex-col items-center justify-center p-4 bg-gray-50 dark:bg-gray-700 rounded-lg hover:bg-indigo-50 dark:hover:bg-indigo-900/30 transition-colors duration-200 group" do %>
              <div class="h-10 w-10 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mb-2 group-hover:bg-indigo-200 dark:group-hover:bg-indigo-800/50 transition-colors duration-200">
                <i class="fas fa-map-marker-alt"></i>
              </div>
              <span class="text-sm font-medium text-gray-700 dark:text-gray-300 group-hover:text-indigo-700 dark:group-hover:text-indigo-300 transition-colors duration-200">Locations</span>
            <% end %>
            <%= link_to products_path, class: "flex flex-col items-center justify-center p-4 bg-gray-50 dark:bg-gray-700 rounded-lg hover:bg-indigo-50 dark:hover:bg-indigo-900/30 transition-colors duration-200 group" do %>
              <div class="h-10 w-10 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mb-2 group-hover:bg-indigo-200 dark:group-hover:bg-indigo-800/50 transition-colors duration-200">
                <i class="fas fa-boxes"></i>
              </div>
              <span class="text-sm font-medium text-gray-700 dark:text-gray-300 group-hover:text-indigo-700 dark:group-hover:text-indigo-300 transition-colors duration-200">Products</span>
            <% end %>
            <%= link_to inventory_path, class: "flex flex-col items-center justify-center p-4 bg-gray-50 dark:bg-gray-700 rounded-lg hover:bg-indigo-50 dark:hover:bg-indigo-900/30 transition-colors duration-200 group" do %>
              <div class="h-10 w-10 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mb-2 group-hover:bg-indigo-200 dark:group-hover:bg-indigo-800/50 transition-colors duration-200">
                <i class="fas fa-boxes"></i>
              </div>
              <span class="text-sm font-medium text-gray-700 dark:text-gray-300 group-hover:text-indigo-700 dark:group-hover:text-indigo-300 transition-colors duration-200">Inventory</span>
            <% end %>
            <%= link_to inventory_report_path, class: "flex flex-col items-center justify-center p-4 bg-gray-50 dark:bg-gray-700 rounded-lg hover:bg-indigo-50 dark:hover:bg-indigo-900/30 transition-colors duration-200 group" do %>
              <div class="h-10 w-10 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mb-2 group-hover:bg-indigo-200 dark:group-hover:bg-indigo-800/50 transition-colors duration-200">
                <i class="fas fa-chart-bar"></i>
              </div>
              <span class="text-sm font-medium text-gray-700 dark:text-gray-300 group-hover:text-indigo-700 dark:group-hover:text-indigo-300 transition-colors duration-200">Reports</span>
            <% end %>
          </div>
          <div class="mt-5">
            <button class="w-full py-2 px-4 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg shadow-sm transition-colors duration-200 flex items-center justify-center">
              <i class="fas fa-plus mr-2"></i> Create New Order
            </button>
          </div>
        </div>
      </div>

      <!-- Recent Activity -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
        <div class="bg-gradient-to-r from-green-600 to-green-700 px-5 py-4">
          <h2 class="text-lg font-semibold text-white flex items-center">
            <i class="fas fa-history mr-2"></i> Recent Activity
          </h2>
        </div>
        <div class="p-5">
          <div class="space-y-4">
            <div class="flex items-start">
              <div class="h-8 w-8 rounded-full bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center text-blue-600 dark:text-blue-400 flex-shrink-0">
                <i class="fas fa-box-open text-sm"></i>
              </div>
              <div class="ml-3">
                <p class="text-sm text-gray-900 dark:text-white">New inventory added: <span class="font-medium">25 units of Product X</span></p>
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">2 hours ago</p>
              </div>
            </div>
            <div class="flex items-start">
              <div class="h-8 w-8 rounded-full bg-green-100 dark:bg-green-900/50 flex items-center justify-center text-green-600 dark:text-green-400 flex-shrink-0">
                <i class="fas fa-check text-sm"></i>
              </div>
              <div class="ml-3">
                <p class="text-sm text-gray-900 dark:text-white">Order <span class="font-medium">#12345</span> has been completed</p>
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Yesterday at 3:45 PM</p>
              </div>
            </div>
            <div class="flex items-start">
              <div class="h-8 w-8 rounded-full bg-amber-100 dark:bg-amber-900/50 flex items-center justify-center text-amber-600 dark:text-amber-400 flex-shrink-0">
                <i class="fas fa-user text-sm"></i>
              </div>
              <div class="ml-3">
                <p class="text-sm text-gray-900 dark:text-white">New team member <span class="font-medium">John Doe</span> joined</p>
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">2 days ago</p>
              </div>
            </div>
          </div>
          <div class="mt-5 pt-4 border-t border-gray-200 dark:border-gray-700 text-center">
            <%# TODO: Create a dedicated User Activities page and link here %>
            <a href="#" class="text-green-600 dark:text-green-400 hover:text-green-800 dark:hover:text-green-300 text-sm font-medium">
              View All Activity
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Getting Started Guide -->
    <div class="px-6 pb-6">
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
        <div class="bg-gradient-to-r from-blue-500 to-indigo-600 px-6 py-4 flex justify-between items-center">
          <h2 class="text-xl font-semibold text-white flex items-center">
            <i class="fas fa-rocket mr-2"></i> Getting Started with SupplyFlow
          </h2>
          <button class="text-white bg-white/20 hover:bg-white/30 rounded-lg px-3 py-1 text-sm font-medium transition-colors duration-200">
            View All Guides
          </button>
        </div>

        <div class="p-6">
          <p class="text-gray-600 dark:text-gray-300 mb-6">
            Complete these steps to set up your inventory management system and start optimizing your supply chain:
          </p>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="relative bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 p-6 rounded-xl border border-blue-100 dark:border-blue-800 overflow-hidden group hover:shadow-md transition-shadow duration-300">
              <div class="absolute top-0 right-0 w-24 h-24 -mt-8 -mr-8 bg-blue-200 dark:bg-blue-800/30 rounded-full opacity-50 group-hover:scale-110 transition-transform duration-500"></div>

              <div class="relative">
                <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/50 rounded-xl flex items-center justify-center text-blue-600 dark:text-blue-400 mb-4 group-hover:scale-110 transition-transform duration-300">
                  <i class="fas fa-warehouse text-xl"></i>
                </div>

                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2 flex items-center">
                  <span class="flex items-center justify-center w-6 h-6 rounded-full bg-blue-600 text-white text-xs mr-2">1</span>
                  Set Up Locations
                </h3>

                <p class="text-gray-600 dark:text-gray-400">Create warehouses, stores, and other locations to track your inventory across multiple sites.</p>

                <div class="mt-4 pt-4 border-t border-blue-100 dark:border-blue-800/50">
                  <%= link_to locations_path, class: "text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 text-sm font-medium flex items-center" do %>
                    Set Up Now <i class="fas fa-arrow-right ml-1"></i>
                  <% end %>
                </div>
              </div>
            </div>

            <div class="relative bg-gradient-to-br from-purple-50 to-indigo-50 dark:from-purple-900/20 dark:to-indigo-900/20 p-6 rounded-xl border border-purple-100 dark:border-purple-800 overflow-hidden group hover:shadow-md transition-shadow duration-300">
              <div class="absolute top-0 right-0 w-24 h-24 -mt-8 -mr-8 bg-purple-200 dark:bg-purple-800/30 rounded-full opacity-50 group-hover:scale-110 transition-transform duration-500"></div>

              <div class="relative">
                <div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/50 rounded-xl flex items-center justify-center text-purple-600 dark:text-purple-400 mb-4 group-hover:scale-110 transition-transform duration-300">
                  <i class="fas fa-boxes text-xl"></i>
                </div>

                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2 flex items-center">
                  <span class="flex items-center justify-center w-6 h-6 rounded-full bg-purple-600 text-white text-xs mr-2">2</span>
                  Add Products
                </h3>

                <p class="text-gray-600 dark:text-gray-400">Add your products with details like SKU, price, descriptions, and set up inventory tracking.</p>

                <div class="mt-4 pt-4 border-t border-purple-100 dark:border-purple-800/50">
                  <%= link_to products_path, class: "text-purple-600 dark:text-purple-400 hover:text-purple-800 dark:hover:text-purple-300 text-sm font-medium flex items-center" do %>
                    Add Products <i class="fas fa-arrow-right ml-1"></i>
                  <% end %>
                </div>
              </div>
            </div>

            <div class="relative bg-gradient-to-br from-green-50 to-teal-50 dark:from-green-900/20 dark:to-teal-900/20 p-6 rounded-xl border border-green-100 dark:border-green-800 overflow-hidden group hover:shadow-md transition-shadow duration-300">
              <div class="absolute top-0 right-0 w-24 h-24 -mt-8 -mr-8 bg-green-200 dark:bg-green-800/30 rounded-full opacity-50 group-hover:scale-110 transition-transform duration-500"></div>

              <div class="relative">
                <div class="w-12 h-12 bg-green-100 dark:bg-green-900/50 rounded-xl flex items-center justify-center text-green-600 dark:text-green-400 mb-4 group-hover:scale-110 transition-transform duration-300">
                  <i class="fas fa-users text-xl"></i>
                </div>

                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2 flex items-center">
                  <span class="flex items-center justify-center w-6 h-6 rounded-full bg-green-600 text-white text-xs mr-2">3</span>
                  Invite Team
                </h3>

                <p class="text-gray-600 dark:text-gray-400">Add your team members and assign appropriate roles and permissions for collaboration.</p>

                <div class="mt-4 pt-4 border-t border-green-100 dark:border-green-800/50">
                  <%= link_to settings_users_path, class: "text-green-600 dark:text-green-400 hover:text-green-800 dark:hover:text-green-300 text-sm font-medium flex items-center" do %>
                    Invite Users <i class="fas fa-arrow-right ml-1"></i>
                  <% end %>
                </div>
              </div>
            </div>
          </div>

          <div class="mt-6 bg-blue-50 dark:bg-blue-900/20 rounded-lg p-4 flex items-center border border-blue-100 dark:border-blue-800">
            <div class="flex-shrink-0 w-10 h-10 bg-blue-100 dark:bg-blue-800/50 rounded-full flex items-center justify-center text-blue-600 dark:text-blue-400">
              <i class="fas fa-lightbulb"></i>
            </div>
            <div class="ml-4">
              <p class="text-sm text-gray-700 dark:text-gray-300">
                <span class="font-medium text-blue-700 dark:text-blue-300">Pro Tip:</span>
                Need help getting started? Schedule a free onboarding call with our support team to get personalized guidance.
              </p>
            </div>
            <div class="ml-auto">
              <button class="px-3 py-1 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors duration-200">
                Schedule Call
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="px-6 pb-6">
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
        <div class="p-5 flex flex-col md:flex-row items-center justify-between">
          <div class="flex items-center mb-4 md:mb-0">
            <div class="flex-shrink-0">
              <img src="/icon.svg" alt="SupplyFlow Logo" class="h-8 w-8" onerror="this.src='https://placehold.co/32x32?text=SF';this.onerror='';">
            </div>
            <div class="ml-3">
              <h3 class="text-lg font-medium text-gray-900 dark:text-white">SupplyFlow</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">Version 1.0.0</p>
            </div>
          </div>

          <div class="flex flex-wrap gap-4 justify-center">
            <%# TODO: Update with actual links if available %>
            <a href="#" class="text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 text-sm">
              Documentation
            </a>
            <%= link_to "Support", support_path, class: "text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 text-sm" %>
            <a href="#" class="text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 text-sm">
              API
            </a>
            <a href="#" class="text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 text-sm">
              Community
            </a>
          </div>

          <div class="mt-4 md:mt-0">
            <%= link_to contact_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-blue-700 dark:text-blue-400 bg-blue-100 dark:bg-blue-900/30 hover:bg-blue-200 dark:hover:bg-blue-900/50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors duration-200" do %>
              <i class="fas fa-headset mr-2"></i> Contact Support
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
