<div class="container mx-auto px-4 py-8 max-w-7xl">
  <!-- Page Header -->
    <div class="mb-8 animate-fade-in-up">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between mb-6">
        <div>
            <h1 class="text-4xl font-bold text-gray-900 dark:text-white flex items-center">
            <span class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-gradient-to-r from-purple-600 to-pink-600 text-white mr-4 shadow-lg">
                <i class="fas fa-shopping-cart text-xl"></i>
            </span>
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-purple-600 to-pink-600">
                Purchase Orders
            </span>
            </h1>
            <p class="text-gray-600 dark:text-gray-400 mt-2 text-lg">
            Manage your supplier orders and track incoming inventory
            </p>
        </div>
        <div class="flex items-center gap-3 mt-4 lg:mt-0">
            <%= link_to new_purchase_order_path, class: "btn-gradient flex items-center gap-2 hover:scale-105 transition-all duration-300" do %>
            <i class="fas fa-plus-circle"></i> New Purchase Order
            <% end %>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6 rounded-md">
      <div class="card-theme-glass p-4 hover:transform hover:scale-105 transition-all duration-300 bg-blue-300 rounded-md">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-blue-600 dark:text-blue-200">Total Orders</p>
            <p class="text-2xl font-bold text-blue-600 dark:text-blue-200"><%= @purchase_orders.count %></p>
          </div>
          <div class="icon-container-glass text-blue-600 dark:text-blue-200">
            <i class="fas fa-clipboard-list text-xl"></i>
          </div>
        </div>
      </div>
      
      <div class="card-theme-glass p-4 hover:transform hover:scale-105 transition-all duration-300 bg-amber-300 rounded-md">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-amber-600 dark:text-amber-400">Pending Orders</p>
            <p class="text-2xl font-bold text-amber-600 dark:text-amber-400"><%= @purchase_orders.pending.count %></p>
          </div>
          <div class="icon-container-glass text-amber-600 dark:text-amber-400">
            <i class="fas fa-hourglass-half text-xl"></i>
          </div>
        </div>
      </div>
      
      <div class="card-theme-glass p-4 hover:transform hover:scale-105 transition-all duration-300 bg-green-300 rounded-md">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-green-600 dark:text-green-400">Total Amount</p>
            <p class="text-2xl font-bold text-green-600 dark:text-green-400">
              <%= number_to_currency(@purchase_orders.sum(:total_amount), unit: "GHS ") %>
            </p>
          </div>
          <div class="icon-container-glass text-green-600">
            <i class="fas fa-coins text-xl"></i>
          </div>
        </div>
      </div>
      
      <div class="card-theme-glass p-4 hover:transform hover:scale-105 transition-all duration-300 bg-red-300 rounded-md">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-red-600 dark:text-red-400">Outstanding Amount</p>
            <p class="text-2xl font-bold text-red-600 dark:text-red-400">
              <%= number_to_currency(@purchase_orders.where(status: ['pending', 'approved']).sum(:total_amount), unit: "GHS ") %>
            </p>
          </div>
          <div class="icon-container-glass text-red-600 dark:text-red-400">
            <i class="fas fa-exclamation-triangle text-xl"></i>
          </div>
        </div>
      </div>
    </div>

    <!-- Search and Filters -->
    <div class="card-theme rounded-2xl shadow-lg p-6 mb-6">
      <%= form_with url: purchase_orders_path, method: :get, class: "grid grid-cols-1 lg:grid-cols-3 gap-4", data: { turbo_frame: "purchase_orders_table" } do |f| %>
        <!-- Search Input -->
        <div class="lg:col-span-2">
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <i class="fas fa-search text-gray-400"></i>
            </div>
            <%= f.text_field :search, 
                value: params[:search],
                placeholder: "Search by order number, supplier name...",
                class: "w-full pl-10 pr-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-[#00A86B]" %>
          </div>
        </div>

        <!-- Status Filter -->
        <div>
          <%= f.select :status, 
              options_for_select(
                [["All Statuses", ""]] + PurchaseOrder.statuses_for_select.to_a,
                params[:status]
              ),
              {},
              class: "w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-[#00A86B] appearance-none" %>
        </div>

        <!-- Date Range Filter -->
        <div class="flex items-center gap-2">
          <%= f.date_field :from_date, 
              value: params[:from_date],
              placeholder: "From",
              class: "w-full px-3 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-[#00A86B]" %>
          <span class="text-gray-500">to</span>
          <%= f.date_field :to_date, 
              value: params[:to_date],
              placeholder: "To",
              class: "w-full px-3 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-[#00A86B]" %>
        </div>

        <!-- Filter Button -->
        <div class="lg:col-span-4 flex justify-end gap-3">
          <%= link_to "Clear Filters", purchase_orders_path, 
              class: "btn-theme-ghost" %>
          <%= f.submit "Apply Filters", 
              class: "btn-theme-primary flex items-center gap-2" %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Purchase Orders Table -->
  <div id="purchase_orders_table" class="card-theme rounded-2xl shadow-xl overflow-hidden animate-fade-in-up animate-delay-200">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="bg-gradient-to-r from-gray-50 to-gray-100 dark:from-gray-800 dark:to-gray-900">
            <th class="px-6 py-4 text-left text-xs font-medium text-gray-600 dark:text-gray-400 uppercase tracking-wider">
              Order #
            </th>
            <th class="px-6 py-4 text-left text-xs font-medium text-gray-600 dark:text-gray-400 uppercase tracking-wider">
              Supplier
            </th>
            <th class="px-6 py-4 text-left text-xs font-medium text-gray-600 dark:text-gray-400 uppercase tracking-wider">
              Order Date
            </th>
            <th class="px-6 py-4 text-left text-xs font-medium text-gray-600 dark:text-gray-400 uppercase tracking-wider">
              Expected Delivery
            </th>
            <th class="px-6 py-4 text-left text-xs font-medium text-gray-600 dark:text-gray-400 uppercase tracking-wider">
              Status
            </th>
            <th class="px-6 py-4 text-right text-xs font-medium text-gray-600 dark:text-gray-400 uppercase tracking-wider">
              Total
            </th>
            <th class="px-6 py-4 text-center text-xs font-medium text-gray-600 dark:text-gray-400 uppercase tracking-wider">
              Actions
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
          <% @purchase_orders.each do |order| %>
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div class="flex-shrink-0 h-10 w-10 rounded-full bg-purple-100 dark:bg-purple-900 flex items-center justify-center">
                    <i class="fas fa-receipt text-purple-600 dark:text-purple-400"></i>
                  </div>
                  <div class="ml-4">
                    <div class="text-sm font-medium text-gray-900 dark:text-white">
                      <%= order.order_number %>
                    </div>
                    <div class="text-xs text-gray-500 dark:text-gray-400">
                      <%= order.purchase_order_items.count %> items
                    </div>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-900 dark:text-white"><%= order.supplier.name %></div>
                <div class="text-xs text-gray-500 dark:text-gray-400"><%= order.supplier.email %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-900 dark:text-white">
                  <%= order.order_date.strftime("%b %d, %Y") %>
                </div>
                <div class="text-xs text-gray-500 dark:text-gray-400">
                  <%= time_ago_in_words(order.created_at) %> ago
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% if order.expected_delivery_date %>
                  <div class="text-sm text-gray-900 dark:text-white">
                    <%= order.expected_delivery_date.strftime("%b %d, %Y") %>
                  </div>
                  <div class="text-xs text-gray-500 dark:text-gray-400">
                    <%= distance_of_time_in_words_to_now(order.expected_delivery_date) %>
                  </div>
                <% else %>
                  <span class="text-sm text-gray-500 dark:text-gray-400 italic">Not set</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="px-3 py-1 rounded-full text-xs font-semibold
                  <%= case order.status
                      when 'draft' then 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300'
                      when 'pending' then 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300'
                      when 'approved' then 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300'
                      when 'received' then 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300'
                      when 'canceled' then 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300'
                      else 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300'
                      end %>">
                  <%= order.status.titleize %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right">
                <div class="text-sm font-semibold text-gray-900 dark:text-white">
                  <%= number_to_currency(order.total_amount, unit: "GHS ") %>
                </div>
                <% if order.balance_due > 0 %>
                  <div class="text-xs text-red-600 dark:text-red-400">
                    Due: <%= number_to_currency(order.balance_due, unit: "GHS ") %>
                  </div>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-center">
                <div class="flex items-center justify-center gap-2">
                  <%= link_to order, 
                      class: "text-blue-600 hover:text-blue-900 dark:text-blue-400 dark:hover:text-blue-300 action-button",
                      title: "View",
                      data: { action: "hover->tooltip#show" } do %>
                    <i class="fas fa-eye"></i>
                  <% end %>
                  <%= link_to edit_purchase_order_path(order), 
                      class: "text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300 action-button",
                      title: "Edit",
                      data: { action: "hover->tooltip#show" } do %>
                    <i class="fas fa-edit"></i>
                  <% end %>
                  <% if order.status == 'approved' %>
                    <%= link_to receive_items_purchase_order_path(order), 
                        method: :post,
                        class: "text-green-600 hover:text-green-900 dark:text-green-400 dark:hover:text-green-300 action-button",
                        title: "Receive Items",
                        data: { action: "hover->tooltip#show" } do %>
                      <i class="fas fa-check-circle"></i>
                    <% end %>
                  <% end %>
                  <%= link_to order, 
                      method: :delete,
                      data: { 
                        confirm: "Are you sure you want to delete this purchase order?",
                        action: "hover->tooltip#show"
                      },
                      class: "text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300 action-button",
                      title: "Delete" do %>
                    <i class="fas fa-trash"></i>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @purchase_orders.empty? %>
      <div class="text-center py-12">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-100 dark:bg-gray-800 mb-4">
          <i class="fas fa-inbox text-2xl text-gray-400"></i>
        </div>
        <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No purchase orders found</h3>
        <p class="text-gray-500 dark:text-gray-400 mb-4">Get started by creating your first purchase order.</p>
        <%= link_to new_purchase_order_path, class: "btn-gradient inline-flex items-center gap-2" do %>
          <i class="fas fa-plus-circle"></i> Create Purchase Order
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Pagination -->
  <% if @purchase_orders.respond_to?(:current_page) %>
    <div class="mt-6 flex justify-center">
      <%= paginate @purchase_orders, theme: 'tailwind' %>
    </div>
  <% end %>
</div>