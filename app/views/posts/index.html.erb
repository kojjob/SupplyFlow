            <div class="flex items-center space-x-2">
              <div class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center text-white">
                <i class="fas fa-check text-sm"></i>
              </div>
              <div class="text-sm font-medium text-gray-800">Stock updated!</div>
            </div>
          </div>
        </div>

        <div class="absolute bottom-1/4 -right-8 transform translate-y-1/2 -rotate-3 z-20 animate-float" style="animation-delay: 2s;">
          <div class="bg-white p-3 rounded-xl shadow-lg">
            <div class="flex items-center space-x-2">
              <div class="w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center text-white">
                <i class="fas fa-sync-alt text-sm"></i>
              </div>
              <div class="text-sm font-medium text-gray-800">Syncing data...</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

