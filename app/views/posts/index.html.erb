<%# Set page title %>
<% content_for :title, "Home" %>

<div class="container mx-auto px-4 py-8">
  <div class="max-w-7xl mx-auto">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl overflow-hidden mb-8">
      <div class="p-6">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-6">Welcome to SupplyFlow</h1>

        <p class="text-lg text-gray-700 dark:text-gray-300 mb-8">
          Your comprehensive inventory management solution for growing businesses.
        </p>

        <% unless user_signed_in? %>
          <div class="flex flex-wrap gap-4">
            <%= link_to new_user_session_path, class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
              <i class="fas fa-sign-in-alt mr-2"></i> Sign In
            <% end %>
            <%= link_to new_user_registration_path, class: "inline-flex items-center px-6 py-3 border border-gray-300 dark:border-gray-600 text-base font-medium rounded-md shadow-sm text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
              <i class="fas fa-user-plus mr-2"></i> Sign Up
            <% end %>
          </div>
        <% else %>
          <div class="flex flex-wrap gap-4">
            <%= link_to dashboard_path, class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" do %>
              <i class="fas fa-tachometer-alt mr-2"></i> Go to Dashboard
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Hero Section -->
<section class="bg-gradient-to-r from-[#0055A4] to-[#004080] text-white py-20 md:py-28 relative overflow-hidden">
  <!-- Decorative Elements -->
  <div class="absolute inset-0 opacity-10 bg-pattern"></div>
  <div class="absolute top-0 right-0 w-96 h-96 bg-[#00A86B] rounded-full opacity-10 blur-xl"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="flex flex-col md:flex-row items-center">
      <div class="md:w-1/2 mb-10 md:mb-0">
        <div class="animate-fade-in-up">
          <span class="badge inline-block mb-4 bg-[#FFD700] text-[#0055A4] px-4 py-2 rounded-full font-bold shadow-lg">Made for Ghanaian SMEs</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight animate-fade-in-up animate-delay-200">
          <span>Simplified Inventory</span>
          <span class="block mt-2 text-[#FFD700]">For Your Business</span>
        </h1>
        <p class="text-xl mb-8 text-white/90 animate-fade-in-up animate-delay-300">Affordable inventory management designed specifically for small and medium businesses in Ghana. Works online and offline.</p>
        <div class="flex flex-col sm:flex-row space-y-4 sm:space-y-0 sm:space-x-4 animate-fade-in-up animate-delay-400">
          <a href="#" class="bg-[#00A86B] hover:bg-[#00965F] text-white font-bold py-3 px-6 rounded-lg transition-all duration-300 flex items-center justify-center shadow-lg">
            <i class="fas fa-rocket mr-2"></i>Start Free Trial
          </a>
          <a href="#" class="bg-white/10 backdrop-blur-sm border border-white/30 hover:bg-white/20 text-white font-bold py-3 px-6 rounded-lg transition-all duration-300 flex items-center justify-center">
            <i class="fas fa-play-circle mr-2"></i>See How It Works
          </a>
        </div>
      </div>
      <div class="md:w-1/2 animate-fade-in-up animate-delay-500">
        <div class="relative">
          <div class="p-2 bg-white/10 backdrop-blur-sm rounded-2xl shadow-lg">
            <%= image_tag "supplyflow-user.png", alt:"Ghanaian business using SupplyFlow", class:"rounded-xl z-10 relative"%>
          </div>

          <!-- Floating elements -->
          <div class="absolute top-1/4 right-0 transform translate-x-1/2 animate-float">
            <div class="w-16 h-16 rounded-full bg-[#00A86B] text-white flex items-center justify-center shadow-lg">
              <i class="fas fa-mobile-alt text-xl"></i>
            </div>
          </div>
          <div class="absolute bottom-1/4 left-0 transform -translate-x-1/2 animate-float" style="animation-delay: 1s;">
            <div class="w-16 h-16 rounded-full bg-[#FFD700] text-[#0055A4] flex items-center justify-center shadow-lg">
              <i class="fas fa-store text-xl"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Wave decoration at bottom -->
  <div class="absolute bottom-0 left-0 w-full overflow-hidden">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none" class="w-full h-16 md:h-24">
      <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" fill="#f7fafc" opacity="0.1"></path>
    </svg>
  </div>
</section>

<!-- Features Section -->
<section class="py-20 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <span class="text-[#00A86B] font-semibold text-sm uppercase tracking-wider">Designed for Ghana</span>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mt-2 mb-4">Features That Matter to Your Business</h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">Simple yet powerful tools to help you manage inventory, track sales, and grow your business.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Feature 1: Inventory Management -->
      <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
        <div class="w-16 h-16 rounded-full bg-[#0055A4]/10 flex items-center justify-center mb-6">
          <i class="fas fa-boxes text-[#0055A4] text-2xl"></i>
        </div>
        <h3 class="text-xl font-bold text-gray-800 mb-3">Simple Inventory Tracking</h3>
        <p class="text-gray-600">Easily manage your stock levels, receive low inventory alerts, and track product movement.</p>
        <ul class="mt-4 space-y-2">
          <li class="flex items-start">
            <i class="fas fa-check-circle text-[#00A86B] mt-1 mr-2"></i>
            <span class="text-gray-600">Works offline during internet outages</span>
          </li>
          <li class="flex items-start">
            <i class="fas fa-check-circle text-[#00A86B] mt-1 mr-2"></i>
            <span class="text-gray-600">Barcode scanning with your phone</span>
          </li>
        </ul>
      </div>

      <!-- Feature 2: Sales & Payments -->
      <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
        <div class="w-16 h-16 rounded-full bg-[#00A86B]/10 flex items-center justify-center mb-6">
          <i class="fas fa-hand-holding-usd text-[#00A86B] text-2xl"></i>
        </div>
        <h3 class="text-xl font-bold text-gray-800 mb-3">Local Payment Integration</h3>
        <p class="text-gray-600">Accept and track payments through popular Ghanaian payment platforms.</p>
        <ul class="mt-4 space-y-2">
          <li class="flex items-start">
            <i class="fas fa-check-circle text-[#00A86B] mt-1 mr-2"></i>
            <span class="text-gray-600">MTN Mobile Money integration</span>
          </li>
          <li class="flex items-start">
            <i class="fas fa-check-circle text-[#00A86B] mt-1 mr-2"></i>
            <span class="text-gray-600">Hubtel payment processing</span>
          </li>
        </ul>
      </div>

      <!-- Feature 3: Reports -->
      <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
        <div class="w-16 h-16 rounded-full bg-[#FFD700]/10 flex items-center justify-center mb-6">
          <i class="fas fa-chart-pie text-[#FFD700] text-2xl"></i>
        </div>
        <h3 class="text-xl font-bold text-gray-800 mb-3">Simple Business Insights</h3>
        <p class="text-gray-600">Easy-to-understand reports that help you make better business decisions.</p>
        <ul class="mt-4 space-y-2">
          <li class="flex items-start">
            <i class="fas fa-check-circle text-[#00A86B] mt-1 mr-2"></i>
            <span class="text-gray-600">Visual sales and inventory dashboards</span>
          </li>
          <li class="flex items-start">
            <i class="fas fa-check-circle text-[#00A86B] mt-1 mr-2"></i>
            <span class="text-gray-600">Export reports for bank loans or investors</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- Mobile App Section -->
<section class="py-20 bg-gradient-to-r from-[#0055A4]/5 to-[#00A86B]/5">
