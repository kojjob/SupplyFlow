        <p class="text-xl text-gray-600 mb-8">SupplyFlow works seamlessly on your smartphone, even when internet connection is unstable.</p>

        <div class="space-y-6">
          <div class="flex items-start">
            <div class="bg-[#0055A4]/10 p-3 rounded-full mr-4 flex-shrink-0">
              <i class="fas fa-wifi-slash text-[#0055A4]"></i>
