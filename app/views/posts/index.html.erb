            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-800">Low Data Usage</h3>
              <p class="text-gray-600 mt-1">Designed to use minimal data when syncing, saving you money on mobile data costs.</p>
            </div>
          </div>
        </div>

        <div class="mt-10 flex space-x-4">
          <a href="#" class="flex items-center bg-black text-white px-5 py-3 rounded-lg hover:bg-gray-900 transition-colors duration-300">
            <i class="fab fa-google-play text-2xl mr-3"></i>
            <div>
              <div class="text-xs">Get it on</div>
              <div class="text-sm font-bold">Google Play</div>
            </div>
