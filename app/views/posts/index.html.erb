<% content_for :title, "Blog | SupplyFlow - Knowledge, Tips & Updates" %>
<% content_for :meta_description, "Explore SupplyFlow's knowledge base for inventory management tips, supply chain insights, and platform updates." %>

<div class="relative">
  <%# Decorative background elements %>
  <div class="absolute inset-0 bg-gradient-to-b from-blue-50 to-white dark:from-gray-900 dark:to-gray-800 -z-10"></div>
  <div class="absolute top-0 right-0 w-1/3 h-64 bg-primary/10 rounded-bl-full blur-3xl -z-10"></div>
  <div class="absolute bottom-0 left-0 w-1/3 h-64 bg-secondary/10 rounded-tr-full blur-3xl -z-10"></div>
  
  <%# Hero section %>
  <section class="relative overflow-hidden py-12 sm:py-16 lg:py-20 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl text-center">
      <h1 class="animate-fade-in text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 dark:text-white leading-tight">
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-primary to-secondary">
          SupplyFlow Insights
        </span>
      </h1>
      <p class="mt-4 text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto animate-fade-in animation-delay-150">
        Expert advice, industry trends, and best practices for optimizing your inventory and supply chain management.
      </p>
      
      <%# Search form %>
      <div class="mt-8 max-w-2xl mx-auto animate-fade-in animation-delay-300">
        <form class="relative flex items-center">
          <div class="relative w-full">
            <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
              <i class="fas fa-search text-gray-400"></i>
            </div>
            <input type="search" name="q" class="block w-full pl-10 pr-20 py-3 text-sm text-gray-900 border border-gray-300 rounded-lg bg-white focus:ring-primary focus:border-primary dark:bg-gray-800 dark:border-gray-700 dark:placeholder-gray-400 dark:text-white" placeholder="Search articles..." required>
            <button type="submit" class="absolute right-2 bottom-2 top-2 px-4 bg-gradient-to-r from-primary to-secondary text-white font-medium rounded-md hover:opacity-90 transition-opacity">
              Search
            </button>
          </div>
        </form>
      </div>
      
      <%# Category pills %>
      <div class="mt-8 flex flex-wrap justify-center gap-2 animate-fade-in animation-delay-450">
        <a href="#" class="inline-flex items-center px-4 py-2 rounded-full bg-primary text-white font-medium text-sm hover:bg-primary/90 transition-colors">
          <i class="fas fa-layer-group mr-2"></i> All Topics
        </a>
        <a href="#" class="inline-flex items-center px-4 py-2 rounded-full bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-700 font-medium text-sm hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
          <i class="fas fa-box mr-2"></i> Inventory Tips
        </a>
        <a href="#" class="inline-flex items-center px-4 py-2 rounded-full bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-700 font-medium text-sm hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
          <i class="fas fa-chart-line mr-2"></i> Analytics
        </a>
        <a href="#" class="inline-flex items-center px-4 py-2 rounded-full bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-700 font-medium text-sm hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
          <i class="fas fa-truck mr-2"></i> Supply Chain
        </a>
        <a href="#" class="inline-flex items-center px-4 py-2 rounded-full bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-700 font-medium text-sm hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
          <i class="fas fa-bullhorn mr-2"></i> Announcements
        </a>
      </div>
    </div>
  </section>
  
  <%# Featured post %>
  <% if @posts.exists? && @featured_post = @posts.first %>
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-6 relative z-10">
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-xl overflow-hidden transform transition-all hover:shadow-2xl hover:-translate-y-1 duration-300">
        <div class="md:flex">
          <div class="md:w-1/2 lg:w-3/5">
            <div class="aspect-w-16 aspect-h-9 md:aspect-none md:h-full">
              <% if @featured_post.featured_image.attached? %>
                <%= image_tag @featured_post.featured_image.representation(resize_to_limit: [800, 450]), class: "object-cover w-full h-full", alt: @featured_post.title %>
              <% else %>
                <div class="w-full h-full bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center">
                  <i class="fas fa-newspaper text-6xl text-gray-300 dark:text-gray-600"></i>
                </div>
              <% end %>
            </div>
          </div>
          <div class="md:w-1/2 lg:w-2/5 p-6 md:p-8 flex flex-col">
            <div class="flex-1">
              <p class="text-sm font-medium text-primary">
                <i class="fas fa-star-of-life mr-1"></i> Featured Article
              </p>
              <h2 class="mt-2 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
                <%= link_to @featured_post.title, @featured_post, class: "hover:text-primary transition-colors" %>
              </h2>
              <div class="mt-3 text-base text-gray-500 dark:text-gray-400 line-clamp-3">
                <%= @featured_post.content.to_plain_text.truncate(200) %>
              </div>
            </div>
            <div class="mt-6 flex items-center">
              <div class="flex-shrink-0">
                <% if @featured_post.user.avatar.attached? %>
                  <%= image_tag @featured_post.user.avatar.variant(resize_to_fill: [40, 40]), class: "h-10 w-10 rounded-full", alt: @featured_post.user.name %>
                <% else %>
                  <div class="h-10 w-10 rounded-full bg-gradient-to-br from-primary to-secondary flex items-center justify-center text-white">
                    <%= @featured_post.user.name.first.upcase %>
                  </div>
                <% end %>
              </div>
              <div class="ml-3">
                <p class="text-sm font-medium text-gray-900 dark:text-white">
                  <%= @featured_post.user.name %>
                </p>
                <div class="flex space-x-1 text-sm text-gray-500 dark:text-gray-400">
                  <time datetime="<%= @featured_post.published_at.iso8601 %>">
                    <%= @featured_post.published_at.strftime('%b %d, %Y') %>
                  </time>
                  <span aria-hidden="true">&middot;</span>
                  <span><%= @featured_post.reading_time || "5 min read" %></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  <% end %>
  
  <%# Main posts grid %>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">
      <i class="fas fa-newspaper text-primary mr-2"></i> Latest Articles
    </h2>
    
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      <% @posts.each do |post| %>
        <article class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden transition-all duration-300 hover:shadow-lg hover:-translate-y-1 flex flex-col h-full">
          <%# Featured image %>
          <div class="relative aspect-w-16 aspect-h-9 group">
            <% if post.featured_image.attached? %>
              <%= image_tag post.featured_image.representation(resize_to_limit: [400, 225]), class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500", alt: post.title %>
            <% else %>
              <div class="w-full h-full bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center">
                <i class="fas fa-newspaper text-4xl text-gray-300 dark:text-gray-600"></i>
              </div>
            <% end %>
            
            <%# Overlay with category %>
            <div class="absolute top-0 left-0 w-full p-4 flex justify-between items-start">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-sm font-medium bg-primary text-white">
                <i class="fas fa-tag mr-1"></i> Category
              </span>
              
              <%# Reading time %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-sm font-medium bg-white/90 dark:bg-gray-800/90 text-gray-700 dark:text-gray-300">
                <i class="far fa-clock mr-1"></i> <%= post.reading_time || "5 min" %>
              </span>
            </div>
          </div>
          
          <%# Content %>
          <div class="p-5 flex-1 flex flex-col">
            <%# Media type indicator %>
            <% if post.media_type != 'article' %>
              <div class="flex items-center mb-2">
                <% case post.media_type %>
                <% when 'video' %>
                  <i class="fas fa-play-circle text-red-500 mr-2"></i>
                  <span class="text-xs font-medium text-red-600 uppercase tracking-wide">Video</span>
                <% when 'audio' %>
                  <i class="fas fa-volume-up text-blue-500 mr-2"></i>
                  <span class="text-xs font-medium text-blue-600 uppercase tracking-wide">Audio</span>
                <% when 'podcast' %>
                  <i class="fas fa-podcast text-purple-500 mr-2"></i>
                  <span class="text-xs font-medium text-purple-600 uppercase tracking-wide">Podcast</span>
                <% when 'infographic' %>
                  <i class="fas fa-chart-bar text-green-500 mr-2"></i>
                  <span class="text-xs font-medium text-green-600 uppercase tracking-wide">Infographic</span>
                <% when 'gallery' %>
                  <i class="fas fa-images text-indigo-500 mr-2"></i>
                  <span class="text-xs font-medium text-indigo-600 uppercase tracking-wide">Gallery</span>
                <% end %>
                <% if post.media_duration.present? %>
                  <span class="ml-auto text-xs bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400 px-2 py-1 rounded">
                    <%= post.media_duration_display %>
                  </span>
                <% end %>
              </div>
            <% end %>
            
            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2 line-clamp-2">
              <%= link_to post.title, post, class: "hover:text-primary transition-colors" %>
            </h3>
            
            <p class="text-gray-600 dark:text-gray-400 text-sm line-clamp-3 mb-4">
              <%= post.excerpt.presence || post.content.to_plain_text.truncate(120) %>
            </p>
            
            <%# Categories (if any) %>
            <% if post.categories.any? %>
              <div class="flex flex-wrap gap-1 mb-3">
                <% post.categories.limit(2).each do |category| %>
                  <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium bg-primary/10 text-primary">
                    <%= category.name %>
                  </span>
                <% end %>
                <% if post.categories.count > 2 %>
                  <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400">
                    +<%= post.categories.count - 2 %> more
                  </span>
                <% end %>
              </div>
            <% end %>
            
            <%# Author and date - at the bottom of the card %>
            <div class="mt-auto pt-4 border-t border-gray-100 dark:border-gray-700 flex items-center justify-between">
              <div class="flex items-center">
                <% if post.user.avatar.attached? %>
                  <%= image_tag post.user.avatar.variant(resize_to_fill: [32, 32]), class: "h-8 w-8 rounded-full", alt: post.user.name %>
                <% else %>
                  <div class="h-8 w-8 rounded-full bg-gradient-to-br from-primary to-secondary flex items-center justify-center text-white text-sm">
                    <%= post.user.name.first.upcase %>
                  </div>
                <% end %>
                <div class="ml-2">
                  <p class="text-xs font-medium text-gray-900 dark:text-white">
                    <%= post.user.name %>
                  </p>
                  <p class="text-xs text-gray-500 dark:text-gray-400">
                    <%= post.published_at.strftime('%b %d, %Y') %>
                  </p>
                </div>
              </div>
              
              <%# Rating stars %>
              <div class="flex items-center">
                <% avg_rating = post.reviews.average(:rating)&.round(1) || 0 %>
                <div class="flex items-center">
                  <% 5.times do |i| %>
                    <% if avg_rating >= i + 1 %>
                      <i class="fas fa-star text-yellow-400"></i>
                    <% elsif avg_rating > i && avg_rating < i + 1 %>
                      <i class="fas fa-star-half-alt text-yellow-400"></i>
                    <% else %>
                      <i class="far fa-star text-yellow-400"></i>
                    <% end %>
                  <% end %>
                </div>
                <span class="ml-1 text-xs text-gray-500 dark:text-gray-400">
                  (<%= post.reviews.count %>)
                </span>
              </div>
            </div>
          </div>
        </article>
      <% end %>
    </div>
    
    <%# Pagination %>
    <% if @pagy && @pagy.pages > 1 %>
      <div class="mt-12">
        <%= render 'shared/pagination', pagy: @pagy %>
      </div>
    <% end %>
    
    <%# Create new post button for admins/authors %>
    <% if policy(Post).new? %>
      <div class="mt-8 text-center">
        <%= link_to new_post_path, class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-gradient-to-r from-primary to-secondary hover:from-primary/90 hover:to-secondary/90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-all" do %>
          <i class="fas fa-plus-circle mr-2"></i> Create New Post
        <% end %>
      </div>
    <% end %>
  </section>
  
  <%# Newsletter section %>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="bg-gradient-to-r from-primary to-secondary rounded-2xl shadow-xl overflow-hidden">
      <div class="px-6 py-12 md:py-16 md:px-12 lg:px-16 text-center sm:text-left md:flex md:items-center md:justify-between">
        <div class="md:max-w-2xl">
          <h2 class="text-3xl font-extrabold tracking-tight text-white">
            <span class="block">Stay updated with SupplyFlow</span>
            <span class="block text-white/90">Get our latest articles & tips</span>
          </h2>
          <p class="mt-3 max-w-md mx-auto md:mx-0 text-lg text-blue-100">
            Join our newsletter to receive monthly updates on inventory management best practices, industry trends, and exclusive SupplyFlow tips.
          </p>
        </div>
        <div class="mt-8 md:mt-0">
          <form class="sm:flex">
            <label for="email-address" class="sr-only">Email address</label>
            <input id="email-address" name="email" type="email" autocomplete="email" required class="w-full px-5 py-3 placeholder-gray-500 focus:ring-white focus:border-white sm:max-w-xs border-white rounded-md" placeholder="Enter your email">
            <div class="mt-3 rounded-md shadow sm:mt-0 sm:ml-3 sm:flex-shrink-0">
              <button type="submit" class="w-full flex items-center justify-center px-5 py-3 border border-transparent text-base font-medium rounded-md text-primary bg-white hover:bg-blue-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-primary focus:ring-white">
                <i class="fas fa-paper-plane mr-2"></i> Subscribe
              </button>
            </div>
          </form>
          <p class="mt-3 text-sm text-blue-100">
            We care about your data. Read our <a href="#" class="font-medium text-white underline">Privacy Policy</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</div>
