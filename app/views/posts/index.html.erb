          <a href="#" class="flex items-center bg-black text-white px-5 py-3 rounded-lg hover:bg-gray-900 transition-colors duration-300">
            <i class="fab fa-apple text-2xl mr-3"></i>
            <div>
              <div class="text-xs">Download on the</div>
              <div class="text-sm font-bold">App Store</div>
            </div>
          </a>
        </div>
      </div>

      <div class="order-1 md:order-2 relative">
        <div class="relative z-10 transform rotate-3 hover:rotate-0 transition-transform duration-500">
          <img src="https://images.unsplash.com/photo-1555774698-0b77e0d5fac6?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1000&q=80" alt="SupplyFlow Mobile App" class="rounded-xl shadow-2xl">
          <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-[#00A86B] rounded-full -z-10 opacity-20 blur-lg"></div>
        </div>

        <div class="absolute top-1/4 -left-8 transform -translate-y-1/2 rotate-6 z-20 animate-float">
