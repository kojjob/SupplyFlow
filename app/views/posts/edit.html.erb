<div class="relative bg-gradient-to-b from-blue-50 to-white dark:from-gray-900 dark:to-gray-800 min-h-screen py-12 px-4 sm:px-6 lg:px-8">
  <%# Decorative background elements %>
  <div class="absolute top-0 right-0 w-1/3 h-64 bg-primary/10 rounded-bl-full blur-3xl -z-10"></div>
  <div class="absolute bottom-0 left-0 w-1/3 h-64 bg-secondary/10 rounded-tr-full blur-3xl -z-10"></div>
  
  <div class="max-w-4xl mx-auto">
    <%# Header %>
    <div class="text-center mb-8">
      <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white sm:text-4xl">
        <i class="fas fa-edit text-primary mr-2"></i>
        Edit Post
      </h1>
      <p class="mt-3 max-w-2xl mx-auto text-xl text-gray-500 dark:text-gray-400">
        Refine your content to deliver maximum value to readers.
      </p>
    </div>
    
    <%# Breadcrumb %>
    <nav class="flex mb-8" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <%= link_to root_path, class: "inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white" do %>
            <i class="fas fa-home mr-2"></i> Home
          <% end %>
        </li>
        <li>
          <div class="flex items-center">
            <i class="fas fa-chevron-right text-gray-400 text-xs mx-2"></i>
            <%= link_to posts_path, class: "ml-1 text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white" do %>
              Blog
            <% end %>
          </div>
        </li>
        <li>
          <div class="flex items-center">
            <i class="fas fa-chevron-right text-gray-400 text-xs mx-2"></i>
            <%= link_to @post.title, @post, class: "ml-1 text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white truncate max-w-[150px] md:max-w-xs" %>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <i class="fas fa-chevron-right text-gray-400 text-xs mx-2"></i>
            <span class="ml-1 text-sm font-medium text-gray-500 dark:text-gray-400">
              Edit
            </span>
          </div>
        </li>
      </ol>
    </nav>
    
    <%# Post Status Information %>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-4 mb-6 flex items-center justify-between">
      <div class="flex items-center">
        <% case @post.status %>
        <% when "draft" %>
          <span class="flex h-8 w-8 rounded-full bg-yellow-100 dark:bg-yellow-900 items-center justify-center mr-3">
            <i class="fas fa-pencil-alt text-yellow-600 dark:text-yellow-400"></i>
          </span>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Draft</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">This post is not yet visible to the public.</p>
          </div>
        <% when "published" %>
          <span class="flex h-8 w-8 rounded-full bg-green-100 dark:bg-green-900 items-center justify-center mr-3">
            <i class="fas fa-check text-green-600 dark:text-green-400"></i>
          </span>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Published</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">
              <% if @post.published_at.future? %>
                Scheduled for publication on <%= @post.published_at.strftime('%B %d, %Y at %H:%M') %>
              <% else %>
                Published on <%= @post.published_at.strftime('%B %d, %Y at %H:%M') %>
              <% end %>
            </p>
          </div>
        <% when "archived" %>
          <span class="flex h-8 w-8 rounded-full bg-gray-100 dark:bg-gray-700 items-center justify-center mr-3">
            <i class="fas fa-archive text-gray-600 dark:text-gray-400"></i>
          </span>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">Archived</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">This post is hidden from public view.</p>
          </div>
        <% end %>
      </div>
      
      <div class="flex space-x-2">
        <% if @post.published? %>
          <%= link_to @post, class: "inline-flex items-center px-3 py-1.5 border border-gray-300 dark:border-gray-600 shadow-sm text-sm font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary" do %>
            <i class="fas fa-eye mr-1"></i> View
          <% end %>
        <% end %>
        
        <%= link_to @post, method: :delete, data: { confirm: "Are you sure you want to delete this post? This action cannot be undone." }, class: "inline-flex items-center px-3 py-1.5 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" do %>
          <i class="fas fa-trash-alt mr-1"></i> Delete
        <% end %>
      </div>
    </div>
    
    <%# Render form %>
    <%= render 'form', post: @post %>
    
    <%# Post Analytics (if published) %>
    <% if @post.published? && @post.published_at.past? %>
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-6 mt-6">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">
          <i class="fas fa-chart-line text-primary mr-2"></i> Post Performance
        </h3>
        
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
          <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg text-center">
            <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Views</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1">1,254</p>
          </div>
          
          <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg text-center">
            <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Unique Visitors</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1">842</p>
          </div>
          
          <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg text-center">
            <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Avg. Time</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1">3:42</p>
          </div>
          
          <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg text-center">
            <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Reviews</p>
            <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1"><%= @post.reviews.count %></p>
          </div>
        </div>
        
        <div class="h-64 bg-gray-50 dark:bg-gray-700 rounded-lg flex items-center justify-center">
          <p class="text-gray-500 dark:text-gray-400 text-sm">Analytics graph would be displayed here</p>
        </div>
      </div>
    <% end %>
  </div>
</div>
