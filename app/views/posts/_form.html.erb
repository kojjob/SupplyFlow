<% content_for :title, "Create New Post" %>
<% content_for :meta_description, "Create a new blog post for SupplyFlow's knowledge base." %>
<div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-6 mb-8">
  <%= form_with(model: post, class: "space-y-6") do |form| %>
    <% if post.errors.any? %>
      <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-900/30 rounded-md p-4 mb-6">
        <div class="flex">
          <div class="flex-shrink-0">
            <i class="fas fa-exclamation-circle text-red-400 dark:text-red-500 text-lg"></i>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800 dark:text-red-400">
              <%= pluralize(post.errors.count, "error") %> prohibited this post from being saved:
            </h3>
            <div class="mt-2 text-sm text-red-700 dark:text-red-300">
              <ul class="list-disc pl-5 space-y-1">
                <% post.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="md:col-span-2">
        <div class="relative">
          <%= form.label :title, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <%= form.text_field :title, class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 shadow-sm py-3 px-4 focus:outline-none focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white text-lg", placeholder: "Enter a compelling title..." %>
          <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none top-6">
            <span id="title-counter" class="text-sm text-gray-500 dark:text-gray-400">0/100</span>
          </div>
        </div>
      </div>
      
      <div>
        <%= form.label :slug, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <div class="mt-1 flex rounded-md shadow-sm">
          <span class="inline-flex items-center px-3 rounded-l-md border border-r-0 border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-500 dark:text-gray-400 text-sm">
            /blog/
          </span>
          <%= form.text_field :slug, class: "focus:ring-primary focus:border-primary flex-1 block w-full rounded-none rounded-r-md border border-gray-300 dark:border-gray-700 shadow-sm py-2 px-3 dark:bg-gray-700 dark:text-white sm:text-sm", placeholder: "your-post-slug" %>
        </div>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
          Leave blank to auto-generate from title. Only lowercase letters, numbers, and hyphens.
        </p>
      </div>
      
      <div>
        <%= form.label :status, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= form.select :status, 
          Post.statuses.keys.map { |s| [s.titleize, s] }, 
          {}, 
          { class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 shadow-sm py-2 px-3 focus:outline-none focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white sm:text-sm" } 
        %>
      </div>
      
      <div>
        <%= form.label :published_at, "Publication Date", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= form.datetime_field :published_at, class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 shadow-sm py-2 px-3 focus:outline-none focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white sm:text-sm" %>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
          Leave blank to publish immediately when status is set to published.
        </p>
      </div>
      
      <div class="md:col-span-2">
        <%= form.label :featured_image, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        
        <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 dark:border-gray-700 border-dashed rounded-md"
             data-controller="image-preview">
          <div class="space-y-1 text-center">
            <div class="flex flex-col items-center">
              <% if form.object.featured_image.attached? %>
                <%= image_tag form.object.featured_image.representation(resize_to_limit: [300, 169]), 
                      class: "mb-3 max-h-48 object-contain",
                      data: { image_preview_target: "output" } %>
              <% else %>
                <i class="fas fa-image text-gray-400 text-5xl mb-3" data-image-preview-target="placeholder"></i>
                <img class="max-h-48 object-contain hidden" data-image-preview-target="output">
              <% end %>
              
              <div class="flex text-sm text-gray-600 dark:text-gray-400">
                <label for="post_featured_image" class="relative cursor-pointer bg-white dark:bg-gray-800 rounded-md font-medium text-primary hover:text-primary-dark focus-within:outline-none focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-primary">
                  <span>Upload a file</span>
                  <%= form.file_field :featured_image, 
                        class: "sr-only", 
                        data: { 
                          image_preview_target: "input", 
                          action: "change->image-preview#preview" 
                        },
                        accept: "image/png, image/jpeg, image/gif" %>
                </label>
                <p class="pl-1">or drag and drop</p>
              </div>
              <p class="text-xs text-gray-500 dark:text-gray-400">
                PNG, JPG, GIF up to 5MB
              </p>
            </div>
          </div>
        </div>
      </div>
      
      <div class="md:col-span-2">
        <%= form.label :content, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= form.rich_text_area :content, class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 shadow-sm focus:outline-none focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white" %>
      </div>
    </div>
    
    <%# Content Type Selection %>
    <div class="bg-gray-50 dark:bg-gray-700/30 px-4 py-3 rounded-md mb-6" data-controller="media-form">
      <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Content Type</h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-2">
        <% Post.media_types.each do |key, value| %>
          <label class="flex flex-col items-center p-2 border border-gray-300 dark:border-gray-600 rounded-lg cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-600 transition-colors <%= 'bg-primary/10 border-primary' if post.media_type == value %>">
            <%= form.radio_button :media_type, value, class: "sr-only", data: { action: "change->media-form#updateType" } %>
            <% case key %>
            <% when 'article' %>
              <i class="fas fa-file-alt text-xl mb-1 text-gray-600"></i>
            <% when 'video' %>
              <i class="fas fa-play-circle text-xl mb-1 text-red-500"></i>
            <% when 'audio' %>
              <i class="fas fa-volume-up text-xl mb-1 text-blue-500"></i>
            <% when 'podcast' %>
              <i class="fas fa-podcast text-xl mb-1 text-purple-500"></i>
            <% when 'infographic' %>
              <i class="fas fa-chart-bar text-xl mb-1 text-green-500"></i>
            <% when 'gallery' %>
              <i class="fas fa-images text-xl mb-1 text-indigo-500"></i>
            <% end %>
            <span class="text-xs font-medium text-center"><%= key.titleize %></span>
          </label>
        <% end %>
      </div>
      
      <%# Media-specific fields %>
      <div class="mt-4 space-y-4">
        <%# Video Fields %>
        <div data-media-form-target="videoFields" class="<%= 'hidden' unless post.media_type == 'video' %>">
          <h4 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Video Settings</h4>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <%= form.label :youtube_url, "YouTube URL", class: "block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1" %>
              <%= form.url_field :youtube_url, class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 shadow-sm py-1 px-2 focus:outline-none focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white text-sm", placeholder: "https://youtube.com/watch?v=..." %>
            </div>
            <div>
              <%= form.label :vimeo_url, "Vimeo URL", class: "block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1" %>
              <%= form.url_field :vimeo_url, class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 shadow-sm py-1 px-2 focus:outline-none focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white text-sm", placeholder: "https://vimeo.com/123456789" %>
            </div>
          </div>
        </div>
        
        <%# Audio Fields %>
        <div data-media-form-target="audioFields" class="<%= 'hidden' unless ['audio', 'podcast'].include?(post.media_type) %>">
          <h4 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Audio Settings</h4>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <%= form.label :audio_url, "Audio URL", class: "block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1" %>
              <%= form.url_field :audio_url, class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 shadow-sm py-1 px-2 focus:outline-none focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white text-sm", placeholder: "https://example.com/audio.mp3" %>
            </div>
            <div>
              <%= form.label :podcast_url, "Podcast URL", class: "block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1" %>
              <%= form.url_field :podcast_url, class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 shadow-sm py-1 px-2 focus:outline-none focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white text-sm", placeholder: "https://anchor.fm/podcast/..." %>
            </div>
          </div>
        </div>
        
        <%# Duration field for all media types %>
        <div data-media-form-target="durationField" class="<%= 'hidden' if post.media_type == 'article' %>">
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            <div>
              <%= form.label :media_duration, "Duration (seconds)", class: "block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1" %>
              <%= form.number_field :media_duration, class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 shadow-sm py-1 px-2 focus:outline-none focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white text-sm", placeholder: "3600" %>
            </div>
            <div>
              <%= form.label :media_thumbnail, "Custom Thumbnail", class: "block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1" %>
              <%= form.url_field :media_thumbnail, class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 shadow-sm py-1 px-2 focus:outline-none focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white text-sm", placeholder: "Thumbnail URL" %>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <%# Excerpt Field %>
    <div class="mb-6">
      <%= form.label :excerpt, "Excerpt", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= form.text_area :excerpt, rows: 2, class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 shadow-sm py-2 px-3 focus:outline-none focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white sm:text-sm", placeholder: "Brief summary for social media and search results..." %>
      <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
        Used for social media previews and search results. Keep it under 280 characters.
      </p>
    </div>
    
    <%# Categories and Tags %>
    <div class="bg-gray-50 dark:bg-gray-700/30 px-4 py-3 rounded-md mb-6">
      <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Categories & Tags</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= form.label :category_ids, "Categories", class: "block text-xs font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= form.collection_check_boxes :category_ids, Category.ordered, :id, :name do |b| %>
            <div class="flex items-center mb-1">
              <%= b.check_box(class: "rounded border-gray-300 text-primary focus:ring-primary") %>
              <%= b.label(class: "ml-2 text-sm text-gray-700 dark:text-gray-300") %>
            </div>
          <% end %>
          <% if Category.count == 0 %>
            <p class="text-xs text-gray-500 dark:text-gray-400 italic">No categories created yet</p>
          <% end %>
        </div>
        
        <div>
          <%= form.label :tag_ids, "Tags", class: "block text-xs font-medium text-gray-700 dark:text-gray-300 mb-2" %>
          <%= form.collection_check_boxes :tag_ids, Tag.alphabetical, :id, :name do |b| %>
            <div class="flex items-center mb-1">
              <%= b.check_box(class: "rounded border-gray-300 text-primary focus:ring-primary") %>
              <%= b.label(class: "ml-2 text-sm text-gray-700 dark:text-gray-300") %>
            </div>
          <% end %>
          <% if Tag.count == 0 %>
            <p class="text-xs text-gray-500 dark:text-gray-400 italic">No tags created yet</p>
          <% end %>
        </div>
      </div>
    </div>
    
    <%# Advanced SEO Settings %>
    <div class="bg-gray-50 dark:bg-gray-700/30 px-4 py-3 rounded-md">
      <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">
        <i class="fas fa-search mr-2 text-primary"></i>Advanced SEO Settings
      </h3>
      
      <div class="grid grid-cols-1 gap-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= form.label :meta_title, "SEO Title", class: "block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= form.text_field :meta_title, class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 shadow-sm py-2 px-3 focus:outline-none focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white sm:text-sm", placeholder: "Leave blank to use the post title", maxlength: 60 %>
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
              50-60 characters recommended for optimal SEO.
            </p>
          </div>
          
          <div>
            <%= form.label :focus_keyword, "Focus Keyword", class: "block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= form.text_field :focus_keyword, class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 shadow-sm py-2 px-3 focus:outline-none focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white sm:text-sm", placeholder: "main keyword" %>
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
              Primary keyword to rank for
            </p>
          </div>
        </div>
        
        <div>
          <%= form.label :meta_description, "SEO Description", class: "block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <%= form.text_area :meta_description, rows: 2, class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 shadow-sm py-2 px-3 focus:outline-none focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white sm:text-sm", placeholder: "Brief description for search engines", maxlength: 160 %>
          <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
            150-160 characters recommended for optimal SEO.
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= form.label :keywords, "Keywords", class: "block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= form.text_field :keywords, class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 shadow-sm py-2 px-3 focus:outline-none focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white sm:text-sm", placeholder: "keyword1, keyword2, keyword3" %>
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
              Separate with commas
            </p>
          </div>
          
          <div>
            <%= form.label :schema_type, "Schema Type", class: "block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= form.select :schema_type, 
              options_for_select(Post.schema_types.map { |key, value| [key, key] }, post.schema_type),
              {},
              class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 shadow-sm py-2 px-3 focus:outline-none focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white sm:text-sm" %>
          </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= form.label :canonical_url, "Canonical URL", class: "block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= form.url_field :canonical_url, class: "block w-full rounded-md border border-gray-300 dark:border-gray-700 shadow-sm py-2 px-3 focus:outline-none focus:ring-primary focus:border-primary dark:bg-gray-700 dark:text-white sm:text-sm", placeholder: "Leave blank for default URL" %>
          </div>
          
          <div class="flex items-center">
            <%= form.check_box :no_index, class: "rounded border-gray-300 text-primary focus:ring-primary" %>
            <%= form.label :no_index, "Hide from search engines", class: "ml-2 text-sm text-gray-700 dark:text-gray-300" %>
          </div>
        </div>
      </div>
    </div>
    
    <div class="flex items-center justify-end space-x-3">
      <% if form.object.persisted? %>
        <%= link_to "Cancel", post_path(form.object), class: "inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 shadow-sm text-sm font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary" %>
      <% else %>
        <%= link_to "Cancel", posts_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 shadow-sm text-sm font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary" %>
      <% end %>
      
      <%= form.button class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-gradient-to-r from-primary to-secondary hover:from-primary/90 hover:to-secondary/90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary" do %>
        <% if form.object.persisted? %>
          <i class="fas fa-save mr-2"></i> Update Post
        <% else %>
          <i class="fas fa-plus-circle mr-2"></i> Create Post
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>

<%# JavaScript for form enhancements %>
<script>
  document.addEventListener('turbo:load', function() {
    // Title character counter
    const titleInput = document.getElementById('post_title');
    const titleCounter = document.getElementById('title-counter');
    
    if (titleInput && titleCounter) {
      titleInput.addEventListener('input', function() {
        const count = this.value.length;
        titleCounter.textContent = `${count}/100`;
        
        if (count > 100) {
          titleCounter.classList.add('text-red-500');
          titleCounter.classList.remove('text-gray-500', 'dark:text-gray-400');
        } else {
          titleCounter.classList.remove('text-red-500');
          titleCounter.classList.add('text-gray-500', 'dark:text-gray-400');
        }
      });
      
      // Trigger on load to initialize counter
      titleInput.dispatchEvent(new Event('input'));
    }
    
    // Auto-generate slug from title
    if (titleInput) {
      const slugInput = document.getElementById('post_slug');
      
      if (slugInput && slugInput.value === '') {
        titleInput.addEventListener('blur', function() {
          if (slugInput.value === '') {
            slugInput.value = this.value
              .toLowerCase()
              .trim()
              .replace(/[^\w\s-]/g, '')
              .replace(/[\s_-]+/g, '-')
              .replace(/^-+|-+$/g, '');
          }
        });
      }
    }
  });
</script>