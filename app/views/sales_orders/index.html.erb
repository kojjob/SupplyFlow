<div class="container mx-auto px-4 py-8 max-w-7xl">
  <!-- Page Header -->
  <div class="mb-8 animate-fade-in-up">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between mb-6">
      <div>
        <h1 class="text-4xl font-bold text-gray-900 dark:text-white flex items-center">
          <span class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-gradient-to-r from-green-600 to-teal-600 text-white mr-4 shadow-lg">
            <i class="fas fa-file-invoice text-xl"></i>
          </span>
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-green-600 to-teal-600">
            Sales Orders
          </span>
        </h1>
        <p class="text-gray-600 dark:text-gray-400 mt-2 text-lg">
          Manage your sales orders and track customer purchases
        </p>
      </div>
      <div class="flex items-center gap-3 mt-4 lg:mt-0">
        <%= link_to new_sales_order_path, class: "btn-gradient flex items-center gap-2 hover:scale-105 transition-all duration-300" do %>
          <i class="fas fa-plus-circle"></i> New Sales Order
        <% end %>
      </div>
    </div>

    <!-- Quick Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
      <div class="card-theme-glass p-4 hover:transform hover:scale-105 transition-all duration-300 bg-sky-300 shadow-md rounded-md">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-sky-800 dark:text-sky-400">Total Orders</p>
            <p class="text-2xl font-bold text-sky-600 dark:text-sky-200"><%= @sales_orders.count %></p>
          </div>
          <div class="icon-container-glass text-sky-800 dark:text-sky-200">
            <i class="fas fa-shopping-cart text-xl"></i>
          </div>
        </div>
      </div>
      
      <div class="card-theme-glass p-4 hover:transform hover:scale-105 transition-all duration-300 bg-lime-300 shadow-md rounded-md">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-lime-800 dark:text-gray-400">Pending Orders</p>
            <p class="text-2xl font-bold text-warning text-lime-600 dark:text-lime-200"><%= @sales_orders.pending.count %></p>
          </div>
          <div class="icon-container-glass text-lime-600 dark:text-lime-200">
            <i class="fas fa-clock text-xl"></i>
          </div>
        </div>
      </div>
      
      <div class="card-theme-glass p-4 hover:transform hover:scale-105 transition-all duration-300 bg-green-300 shadow-md rounded-md">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-green-600 dark:text-green-800">Total Revenue</p>
            <p class="text-2xl font-bold text-success text-green-600 dark:text-green-200 ">
              <%= number_to_currency(@sales_orders.sum(:total_amount), unit: "GHS ") %>
            </p>
          </div>
          <div class="icon-container-glassn text-green-600 dark:text-green-200">
            <i class="fas fa-dollar-sign text-xl"></i>
          </div>
        </div>
      </div>
      
      <div class="card-theme-glass p-4 hover:transform hover:scale-105 transition-all duration-300 bg-orange-300 shadow-md rounded-md">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-orange-500 dark:text-gray-400">Unpaid Amount</p>
            <p class="text-2xl font-bold text-danger text-orange-600 dark:text-orange-200">
              <%= number_to_currency(@sales_orders.unpaid.sum(:total_amount), unit: "GHS ") %>
            </p>
          </div>
          <div class="icon-container-glass text-orange-600 dark:text-orange-200">
            <i class="fas fa-exclamation-triangle text-xl"></i>
          </div>
        </div>
      </div>
    </div>

    <!-- Search and Filters -->
    <div class="card-theme rounded-2xl shadow-lg p-6 mb-6">
      <%= form_with url: sales_orders_path, method: :get, class: "grid grid-cols-1 lg:grid-cols-3 gap-4", data: { turbo_frame: "sales_orders_table" } do |f| %>
        <!-- Search Input -->
        <div class="lg:col-span-2">
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <i class="fas fa-search text-gray-400"></i>
            </div>
            <%= f.text_field :search, 
                value: params[:search],
                placeholder: "Search by order number, customer name...",
                class: "w-full pl-10 pr-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-[#00A86B]" %>
          </div>
        </div>

        <!-- Status Filter -->
        <div>
          <%= f.select :status, 
              options_for_select(
                [["All Statuses", ""]] + SalesOrder.statuses_for_select.to_a,
                params[:status]
              ),
              {},
              class: "w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-[#00A86B] appearance-none" %>
        </div>

        <!-- Date Range Filter -->
        <div class="flex items-center gap-2">
          <%= f.date_field :from_date, 
              value: params[:from_date],
              placeholder: "From",
              class: "px-3 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-[#00A86B]" %>
          <span class="text-gray-500">to</span>
          <%= f.date_field :to_date, 
              value: params[:to_date],
              placeholder: "To",
              class: "px-3 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-[#00A86B]" %>
        </div>

        <!-- Filter Button -->
        <div class="lg:col-span-4 flex justify-end gap-3">
          <%= link_to "Clear Filters", sales_orders_path, 
              class: "btn-theme-ghost" %>
          <%= f.submit "Apply Filters", 
              class: "btn-theme-primary flex items-center gap-2" %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Orders Table -->
  <div class="card-theme rounded-2xl shadow-xl overflow-hidden animate-fade-in-up animate-delay-200">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="bg-gradient-to-r from-gray-50 to-gray-100 dark:from-gray-800 dark:to-gray-900">
            <th class="px-6 py-4 text-left text-xs font-medium text-gray-600 dark:text-gray-400 uppercase tracking-wider">
              Order #
            </th>
            <th class="px-6 py-4 text-left text-xs font-medium text-gray-600 dark:text-gray-400 uppercase tracking-wider">
              Customer
            </th>
            <th class="px-6 py-4 text-left text-xs font-medium text-gray-600 dark:text-gray-400 uppercase tracking-wider">
              Date
            </th>
            <th class="px-6 py-4 text-left text-xs font-medium text-gray-600 dark:text-gray-400 uppercase tracking-wider">
              Status
            </th>
            <th class="px-6 py-4 text-left text-xs font-medium text-gray-600 dark:text-gray-400 uppercase tracking-wider">
              Payment
            </th>
            <th class="px-6 py-4 text-right text-xs font-medium text-gray-600 dark:text-gray-400 uppercase tracking-wider">
              Total
            </th>
            <th class="px-6 py-4 text-center text-xs font-medium text-gray-600 dark:text-gray-400 uppercase tracking-wider">
              Actions
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
          <% @sales_orders.each do |order| %>
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div class="flex-shrink-0 h-10 w-10 rounded-full bg-blue-100 dark:bg-blue-900 flex items-center justify-center">
                    <i class="fas fa-file-invoice text-blue-600 dark:text-blue-400"></i>
                  </div>
                  <div class="ml-4">
                    <div class="text-sm font-medium text-gray-900 dark:text-white">
                      <%= order.order_number %>
                    </div>
                    <div class="text-xs text-gray-500 dark:text-gray-400">
                      <%= order.sales_order_items.count %> items
                    </div>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-900 dark:text-white"><%= order.customer.name %></div>
                <div class="text-xs text-gray-500 dark:text-gray-400"><%= order.customer.email %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm text-gray-900 dark:text-white">
                  <%= order.order_date.strftime("%b %d, %Y") %>
                </div>
                <div class="text-xs text-gray-500 dark:text-gray-400">
                  <%= time_ago_in_words(order.created_at) %> ago
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="px-3 py-1 rounded-full text-xs font-semibold
                  <%= case order.status
                      when 'draft' then 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300'
                      when 'pending' then 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300'
                      when 'confirmed' then 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300'
                      when 'processing' then 'bg-indigo-100 text-indigo-800 dark:bg-indigo-900 dark:text-indigo-300'
                      when 'shipped' then 'bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-300'
                      when 'delivered' then 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300'
                      when 'canceled' then 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300'
                      else 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300'
                      end %>">
                  <%= order.status.titleize %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="px-3 py-1 rounded-full text-xs font-semibold
                  <%= case order.payment_status
                      when 'unpaid' then 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300'
                      when 'partial' then 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300'
                      when 'paid' then 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300'
                      when 'refunded' then 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300'
                      else 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300'
                      end %>">
                  <%= order.payment_status.titleize %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right">
                <div class="text-sm font-semibold text-gray-900 dark:text-white">
                  <%= number_to_currency(order.total_amount, unit: "GHS ") %>
                </div>
                <% if order.balance_due > 0 %>
                  <div class="text-xs text-red-600 dark:text-red-400">
                    Due: <%= number_to_currency(order.balance_due, unit: "GHS ") %>
                  </div>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-center">
                <div class="flex items-center justify-center gap-2">
                  <%= link_to order, 
                      class: "text-blue-600 hover:text-blue-900 dark:text-blue-400 dark:hover:text-blue-300",
                      title: "View" do %>
                    <i class="fas fa-eye"></i>
                  <% end %>
                  <%= link_to edit_sales_order_path(order), 
                      class: "text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300",
                      title: "Edit" do %>
                    <i class="fas fa-edit"></i>
                  <% end %>
                  <%= link_to order, 
                      method: :delete,
                      data: { confirm: "Are you sure you want to delete this order?" },
                      class: "text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300",
                      title: "Delete" do %>
                    <i class="fas fa-trash"></i>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @sales_orders.empty? %>
      <div class="text-center py-12">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-100 dark:bg-gray-800 mb-4">
          <i class="fas fa-inbox text-2xl text-gray-400"></i>
        </div>
        <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No sales orders found</h3>
        <p class="text-gray-500 dark:text-gray-400 mb-4">Get started by creating your first sales order.</p>
        <%= link_to new_sales_order_path, class: "btn-gradient inline-flex items-center gap-2" do %>
          <i class="fas fa-plus-circle"></i> Create Sales Order
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Pagination -->
  <% if @sales_orders.respond_to?(:current_page) %>
    <div class="mt-6 flex justify-center">
      <%= paginate @sales_orders, theme: 'tailwind' %>
    </div>
  <% end %>
</div>
