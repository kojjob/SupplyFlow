<div class="sales-order-item-fields bg-gray-50 dark:bg-gray-800/50 rounded-lg p-4 mb-4" data-controller="sales-order-item">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 items-end">
    <!-- Product Selection -->
    <div class="lg:col-span-4">
      <%= f.label :product_id, "Product", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <div class="relative">
        <%= f.select :product_id, 
            options_from_collection_for_select(Product.active.order(:name), :id, :name, f.object.product_id),
            { prompt: "Select a product..." },
            { 
              class: "w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-[#00A86B] appearance-none pr-10",
              data: { 
                sales_order_item_target: "productSelect",
                action: "change->sales-order-item#updatePrice"
              }
            } %>
        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-gray-700 dark:text-gray-300">
          <i class="fas fa-chevron-down text-sm"></i>
        </div>
      </div>
    </div>

    <!-- Quantity -->
    <div class="lg:col-span-2">
      <%= f.label :quantity, "Quantity", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <i class="fas fa-cube text-gray-400"></i>
        </div>
        <%= f.number_field :quantity, 
            value: f.object.quantity || 1,
            min: 1,
            class: "w-full pl-10 pr-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-[#00A86B]",
            data: { 
              sales_order_item_target: "quantity",
              action: "input->sales-order-item#calculateTotal"
            } %>
      </div>
    </div>

    <!-- Unit Price -->
    <div class="lg:col-span-2">
      <%= f.label :unit_price, "Unit Price", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <span class="text-gray-400 text-sm">GHS</span>
        </div>
        <%= f.number_field :unit_price, 
            step: 0.01,
            min: 0,
            class: "w-full pl-12 pr-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-[#00A86B]",
            data: { 
              sales_order_item_target: "unitPrice",
              action: "input->sales-order-item#calculateTotal"
            } %>
      </div>
    </div>

    <!-- Tax Rate -->
    <div class="lg:col-span-1">
      <%= f.label :tax_rate, "Tax %", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <div class="relative">
        <%= f.number_field :tax_rate, 
            value: f.object.tax_rate || 0,
            step: 0.01,
            min: 0,
            max: 100,
            class: "w-full px-3 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-[#00A86B]",
            data: { 
              sales_order_item_target: "taxRate",
              action: "input->sales-order-item#calculateTotal"
            } %>
        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
          <span class="text-gray-400 text-sm">%</span>
        </div>
      </div>
    </div>

    <!-- Total -->
    <div class="lg:col-span-2">
      <%= f.label :total_amount, "Total", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <span class="text-gray-400 text-sm">GHS</span>
        </div>
        <%= f.number_field :total_amount, 
            step: 0.01,
            readonly: true,
            class: "w-full pl-12 pr-4 py-3 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-100 dark:bg-gray-800 text-gray-800 dark:text-gray-100 cursor-not-allowed",
            data: { sales_order_item_target: "total" } %>
      </div>
    </div>

    <!-- Remove Button -->
    <div class="lg:col-span-1 flex items-end">
      <button type="button" 
              data-action="click->sales-order-item#remove" 
              class="w-full h-12 bg-red-500 hover:bg-red-600 text-white rounded-lg transition-colors duration-200 flex items-center justify-center group">
        <i class="fas fa-trash-alt group-hover:scale-110 transition-transform"></i>
      </button>
    </div>
  </div>

  <!-- Destroy flag for existing items -->
  <%= f.hidden_field :_destroy, data: { sales_order_item_target: "destroy" } %>
  
  <!-- Stock Information (shown when product selected) -->
  <div class="mt-3 hidden" data-sales-order-item-target="stockInfo">
    <div class="bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-800 rounded-lg p-3">
      <div class="flex items-center justify-between">
        <div class="flex items-center text-blue-700 dark:text-blue-300">
          <i class="fas fa-info-circle mr-2"></i>
          <span class="text-sm">Available Stock: <span data-sales-order-item-target="stockLevel" class="font-semibold">0</span> units</span>
        </div>
        <div class="text-sm text-blue-600 dark:text-blue-400" data-sales-order-item-target="stockStatus">
          In Stock
        </div>
      </div>
    </div>
  </div>
</div>