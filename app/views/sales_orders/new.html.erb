<div class="container mx-auto px-4 py-8 max-w-7xl">
  <!-- Page Header with Advanced Animation -->
  <div class="mb-8 animate-fade-in-up">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between mb-4">
      <div>
        <h1 class="text-4xl font-bold text-gray-900 dark:text-white flex items-center">
          <span class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-gradient-to-r from-blue-600 to-indigo-600 text-white mr-4 shadow-lg">
            <i class="fas fa-file-invoice text-xl"></i>
          </span>
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-indigo-600">
            New Sales Order
          </span>
        </h1>
        <p class="text-gray-600 dark:text-gray-400 mt-2 text-lg">
          Create a sales order for your customers with intelligent inventory tracking
        </p>
      </div>
      <div class="flex items-center gap-3 mt-4 lg:mt-0">
        <%= link_to sales_orders_path, class: "btn-theme-glass hover:shadow-lg transition-all duration-300" do %>
          <i class="fas fa-arrow-left mr-2"></i> Back to Orders
        <% end %>
      </div>
    </div>
    
    <!-- Progress Indicator -->
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-2">
        <div class="flex items-center justify-center w-8 h-8 rounded-full bg-gradient-to-r from-blue-600 to-indigo-600 text-white text-sm font-bold">1</div>
        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Customer Details</span>
      </div>
      <div class="flex-1 h-1 mx-4 bg-gray-200 dark:bg-gray-700 rounded-full">
        <div class="h-1 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-full" style="width: 0%;"></div>
      </div>
      <div class="flex items-center gap-2 opacity-50">
        <div class="flex items-center justify-center w-8 h-8 rounded-full bg-gray-300 dark:bg-gray-700 text-gray-600 dark:text-gray-400 text-sm font-bold">2</div>
        <span class="text-sm font-medium text-gray-500 dark:text-gray-500">Order Items</span>
      </div>
      <div class="flex-1 h-1 mx-4 bg-gray-200 dark:bg-gray-700 rounded-full"></div>
      <div class="flex items-center gap-2 opacity-50">
        <div class="flex items-center justify-center w-8 h-8 rounded-full bg-gray-300 dark:bg-gray-700 text-gray-600 dark:text-gray-400 text-sm font-bold">3</div>
        <span class="text-sm font-medium text-gray-500 dark:text-gray-500">Review</span>
      </div>
    </div>
  </div>

  <!-- Order Form -->
  <%= render 'form', sales_order: @sales_order %>
</div>