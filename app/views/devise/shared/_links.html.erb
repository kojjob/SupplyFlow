<div class="flex flex-col space-y-3">
  <%- if controller_name != 'sessions' %>
    <%= link_to "Log in", new_session_path(resource_name), class: "text-blue-600 dark:text-blue-400 hover:underline font-medium" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Sign up", new_registration_path(resource_name), class: "text-blue-600 dark:text-blue-400 hover:underline font-medium" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-blue-600 dark:text-blue-400 hover:underline font-medium" %>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name), class: "text-blue-600 dark:text-blue-400 hover:underline font-medium" %>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to "Didn't receive unlock instructions?", new_unlock_path(resource_name), class: "text-blue-600 dark:text-blue-400 hover:underline font-medium" %>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <div class="mt-4">
      <div class="relative">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-gray-300 dark:border-gray-600"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="px-2 bg-white dark:bg-gray-800 text-gray-500 dark:text-gray-400">Or continue with</span>
        </div>
      </div>

      <div class="mt-4 grid grid-cols-<%= resource_class.omniauth_providers.count > 2 ? '3' : resource_class.omniauth_providers.count %> gap-3">
        <%- resource_class.omniauth_providers.each do |provider| %>
          <%= button_to omniauth_authorize_path(resource_name, provider),
              class: "w-full inline-flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm bg-white dark:bg-gray-700 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors duration-300",
              data: { turbo: false } do %>
            <% case provider.to_s %>
            <% when 'google_oauth2' %>
              <i class="fab fa-google text-red-500 mr-2"></i>
            <% when 'facebook' %>
              <i class="fab fa-facebook text-blue-600 mr-2"></i>
            <% when 'twitter' %>
              <i class="fab fa-twitter text-blue-400 mr-2"></i>
            <% when 'github' %>
              <i class="fab fa-github text-gray-800 dark:text-white mr-2"></i>
            <% when 'microsoft_graph' %>
              <i class="fab fa-microsoft text-blue-500 mr-2"></i>
            <% else %>
              <i class="fab fa-<%= provider.to_s.dasherize %> mr-2"></i>
            <% end %>
            <span><%= OmniAuth::Utils.camelize(provider) %></span>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
