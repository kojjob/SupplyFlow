<div class="max-w-3xl mx-auto my-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-800 dark:text-white">Account Settings</h1>
    <%= link_to "Back", :back, class: "text-[#0055A4] hover:text-[#004a8f] dark:text-[#1A6FBF] dark:hover:text-[#3A8FDF]" %>
  </div>

  <%= render partial: "shared/form_container", locals: {
    title: "PROFILE",
    subtitle: "Edit Your Account",
    container_class: "mb-8",
    accent_color: "#0055A4"
  } do %>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <%= render partial: "shared/form_input", locals: {
          form: f,
          field: :first_name,
          label: "First Name",
          type: "text",
          placeholder: "John",
          required: true,
          autofocus: true,
          wrapper_class: ""
        } %>

        <%= render partial: "shared/form_input", locals: {
          form: f,
          field: :last_name,
          label: "Last Name",
          type: "text",
          placeholder: "Doe",
          required: true,
          wrapper_class: ""
        } %>
      </div>

      <%= render partial: "shared/form_input", locals: {
        form: f,
        field: :email,
        label: "Email Address",
        type: "email",
        placeholder: "your.email@example.com",
        required: true,
        autocomplete: "email"
      } %>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="bg-yellow-50 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-200 p-4 rounded-lg mb-6">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-yellow-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <p>Currently waiting confirmation for: <%= resource.unconfirmed_email %></p>
            </div>
          </div>
        </div>
      <% end %>

      <div class="border-t border-gray-200 dark:border-gray-700 pt-6 mt-6">
        <h3 class="text-lg font-medium text-gray-800 dark:text-white mb-4">Change Password</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">Leave these fields blank if you don't want to change your password.</p>

        <%= render partial: "shared/form_input", locals: {
          form: f,
          field: :password,
          label: "New Password",
          type: "password",
          placeholder: "••••••••",
          required: false,
          autocomplete: "new-password",
          hint: @minimum_password_length ? "#{@minimum_password_length} characters minimum" : nil
        } %>

        <%= render partial: "shared/form_input", locals: {
          form: f,
          field: :password_confirmation,
          label: "Confirm New Password",
          type: "password",
          placeholder: "••••••••",
          required: false,
          autocomplete: "new-password"
        } %>
      </div>

      <div class="border-t border-gray-200 dark:border-gray-700 pt-6 mt-6">
        <%= render partial: "shared/form_input", locals: {
          form: f,
          field: :current_password,
          label: "Current Password",
          type: "password",
          placeholder: "••••••••",
          required: true,
          autocomplete: "current-password",
          hint: "We need your current password to confirm your changes"
        } %>
      </div>

      <div class="flex justify-end mt-6">
        <%= render partial: "shared/form_submit", locals: {
          form: f,
          text: "Update Account",
          color: "primary",
          size: "md"
        } %>
      </div>
    <% end %>
  <% end %>

  <%= render partial: "shared/form_container", locals: {
    title: "DANGER ZONE",
    subtitle: "Cancel Account",
    container_class: "mb-6",
    accent_color: "#DC2626"
  } do %>
    <p class="text-gray-600 dark:text-gray-300 mb-6">
      Once you cancel your account, all of your data will be permanently deleted. This action cannot be undone.
    </p>

    <div class="flex justify-end">
      <%= button_to "Cancel my account",
          registration_path(resource_name),
          data: { confirm: "Are you sure? This action cannot be undone.", turbo_confirm: "Are you sure? This action cannot be undone." },
          method: :delete,
          class: "bg-red-600 hover:bg-red-700 focus:ring-red-500/50 text-white py-3 px-6 rounded-lg font-medium shadow-sm focus:outline-none focus:ring-2 focus:ring-offset-2 transition-colors duration-200" %>
    </div>
  <% end %>
</div>
