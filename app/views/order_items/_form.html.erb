<%= form_with(model: order_item, class: "contents") do |form| %>
  <% if order_item.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(order_item.errors.count, "error") %> prohibited this order_item from being saved:</h2>

      <ul class="list-disc ml-6">
        <% order_item.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :order_id %>
    <%= form.text_field :order_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": order_item.errors[:order_id].none?, "border-red-400 focus:outline-red-600": order_item.errors[:order_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :product_id %>
    <%= form.text_field :product_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": order_item.errors[:product_id].none?, "border-red-400 focus:outline-red-600": order_item.errors[:product_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :quantity %>
    <%= form.number_field :quantity, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": order_item.errors[:quantity].none?, "border-red-400 focus:outline-red-600": order_item.errors[:quantity].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :unit_price %>
    <%= form.text_field :unit_price, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": order_item.errors[:unit_price].none?, "border-red-400 focus:outline-red-600": order_item.errors[:unit_price].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :tax_rate %>
    <%= form.text_field :tax_rate, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": order_item.errors[:tax_rate].none?, "border-red-400 focus:outline-red-600": order_item.errors[:tax_rate].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :tax_amount %>
    <%= form.text_field :tax_amount, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": order_item.errors[:tax_amount].none?, "border-red-400 focus:outline-red-600": order_item.errors[:tax_amount].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :discount_amount %>
    <%= form.text_field :discount_amount, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": order_item.errors[:discount_amount].none?, "border-red-400 focus:outline-red-600": order_item.errors[:discount_amount].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :total_amount %>
    <%= form.text_field :total_amount, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": order_item.errors[:total_amount].none?, "border-red-400 focus:outline-red-600": order_item.errors[:total_amount].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :shipped_quantity %>
    <%= form.number_field :shipped_quantity, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": order_item.errors[:shipped_quantity].none?, "border-red-400 focus:outline-red-600": order_item.errors[:shipped_quantity].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :notes %>
    <%= form.textarea :notes, rows: 4, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": order_item.errors[:notes].none?, "border-red-400 focus:outline-red-600": order_item.errors[:notes].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :metadata %>
    <%= form.text_field :metadata, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": order_item.errors[:metadata].none?, "border-red-400 focus:outline-red-600": order_item.errors[:metadata].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
