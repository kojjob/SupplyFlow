<div id="<%= dom_id order_item %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Order:</strong>
    <%= order_item.order_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Product:</strong>
    <%= order_item.product_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Quantity:</strong>
    <%= order_item.quantity %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Unit price:</strong>
    <%= order_item.unit_price %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Tax rate:</strong>
    <%= order_item.tax_rate %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Tax amount:</strong>
    <%= order_item.tax_amount %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Discount amount:</strong>
    <%= order_item.discount_amount %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Total amount:</strong>
    <%= order_item.total_amount %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Shipped quantity:</strong>
    <%= order_item.shipped_quantity %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Notes:</strong>
    <%= order_item.notes %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Metadata:</strong>
    <%= order_item.metadata %>
  </div>
</div>
