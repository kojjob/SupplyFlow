  <%# Stats Section %>
  <section class="mb-24 py-16 px-8 bg-gradient-to-r from-[#0055A4] to-[#00A86B] rounded-3xl relative overflow-hidden text-white">
    <%# Decorative elements %>
    <div class="absolute inset-0 bg-pattern opacity-10"></div>
    <div class="absolute top-0 right-0 w-64 h-64 bg-white rounded-full opacity-10 blur-xl"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-[#FFD700] rounded-full opacity-10 blur-xl"></div>

    <div class="relative z-10 max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">SupplyFlow by the Numbers</h2>
        <p class="text-xl text-white/80 max-w-3xl mx-auto">
          Our impact on Ghanaian businesses.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center bg-white/10 backdrop-blur-sm p-6 rounded-xl border border-white/20 hover:bg-white/20 transition-colors duration-300">
          <div class="text-5xl font-bold mb-2">250+</div>
          <div class="text-white/80">Ghanaian SMEs Served</div>
        </div>

        <div class="text-center bg-white/10 backdrop-blur-sm p-6 rounded-xl border border-white/20 hover:bg-white/20 transition-colors duration-300">
          <div class="text-5xl font-bold mb-2">8</div>
          <div class="text-white/80">Cities Across Ghana</div>
        </div>

        <div class="text-center bg-white/10 backdrop-blur-sm p-6 rounded-xl border border-white/20 hover:bg-white/20 transition-colors duration-300">
