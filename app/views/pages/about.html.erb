<%# About Page - Main Container %>
<div class="container mx-auto px-4 py-12 max-w-7xl">

  <%# Hero Section %>
  <section class="relative mb-24 overflow-hidden rounded-3xl">
    <%# Background with gradient overlay %>
    <div class="absolute inset-0 bg-gradient-to-r from-[#0055A4]/90 to-[#00A86B]/80 z-10"></div>
    <div class="absolute inset-0 bg-pattern opacity-10 z-10"></div>

    <%# Background image - Ghana marketplace %>
    <%= image_tag "marketplace.png", alt:"Ghanaian marketplace", class:"absolute inset-0 w-full h-full object-cover" %>

    <%# Content %>
    <div class="relative z-20 py-24 px-6 md:px-12 text-center text-white">
      <span class="inline-block px-4 py-2 rounded-full bg-[#FFD700] text-[#0055A4] text-sm font-semibold mb-6">Made in Ghana for Ghana</span>
      <h1 class="text-4xl md:text-6xl font-bold mb-6 leading-tight">About SupplyFlow</h1>
      <p class="text-xl md:text-2xl max-w-3xl mx-auto mb-8 text-white/90">
        Empowering Ghanaian SMEs with affordable inventory management solutions.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="#mission" class="bg-white/10 backdrop-blur-sm border border-white/30 hover:bg-white/20 text-white font-bold px-6 py-3 rounded-lg transition-all duration-300">
          Our Mission
        </a>
        <a href="#team" class="bg-white/10 backdrop-blur-sm border border-white/30 hover:bg-white/20 text-white font-bold px-6 py-3 rounded-lg transition-all duration-300">
          Meet Our Team
        </a>
      </div>
    </div>
  </section>

  <%# Company Overview Section %>
  <section class="mb-24">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <span class="text-[#00A86B] font-semibold text-sm uppercase tracking-wider">Our Journey</span>
        <h2 class="text-3xl font-bold mt-2 mb-6 text-gray-800 dark:text-white">Our Story</h2>
        <p class="text-lg text-gray-600 dark:text-gray-300 mb-6">
          Founded in 2022, SupplyFlow was born from a deep understanding of the challenges faced by small and medium-sized businesses in Ghana's retail and distribution sectors.
        </p>
        <p class="text-lg text-gray-600 dark:text-gray-300 mb-6">
          Our founders, who grew up in Ghana and experienced firsthand the inventory management struggles of local businesses, recognized that existing solutions were either too expensive, overly complex, or failed to address the unique needs of Ghanaian SMEs.
        </p>
        <p class="text-lg text-gray-600 dark:text-gray-300">
          Today, SupplyFlow serves hundreds of businesses across Ghana, from small shops in Kumasi to growing distributors in Accra, all benefiting from our affordable, user-friendly approach to inventory management that works even with unstable internet connections.
        </p>
      </div>
      <div class="relative">
        <div class="absolute -top-6 -left-6 w-24 h-24 bg-[#0055A4]/10 rounded-lg z-0"></div>
        <div class="absolute -bottom-6 -right-6 w-24 h-24 bg-[#00A86B]/10 rounded-lg z-0"></div>
        <%= image_tag "bizz_man.png", alt:"Ghanaian business owner", class:"relative rounded-xl shadow-xl z-10" %>
      </div>
    </div>
  </section>

  <%# Mission and Vision Section %>
  <section id="mission" class="mb-24 py-16 px-8 bg-gradient-to-br from-[#0055A4]/5 to-[#00A86B]/5 rounded-3xl relative overflow-hidden">
    <%# Decorative elements %>
    <div class="absolute top-0 right-0 w-64 h-64 bg-[#0055A4]/10 rounded-full -translate-y-1/2 translate-x-1/2 z-0"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-[#00A86B]/10 rounded-full translate-y-1/2 -translate-x-1/2 z-0"></div>

    <div class="relative z-10 max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <span class="inline-block px-4 py-2 rounded-full bg-[#FFD700]/20 text-[#0055A4] text-sm font-semibold mb-4">Our Purpose</span>
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-gray-800 dark:text-white">Mission & Vision</h2>
        <div class="w-24 h-1 bg-gradient-to-r from-[#0055A4] to-[#00A86B] mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300">
          <div class="w-16 h-16 bg-[#0055A4]/10 rounded-full flex items-center justify-center mb-6">
            <i class="fas fa-rocket text-[#0055A4] text-2xl"></i>
          </div>
          <h3 class="text-2xl font-bold mb-4 text-gray-800 dark:text-white">Our Mission</h3>
          <p class="text-gray-600 dark:text-gray-300">
            To empower small and medium-sized businesses in Ghana with affordable, user-friendly inventory management solutions that work reliably even with unstable internet connections. We're committed to helping Ghanaian SMEs grow through better inventory control and supply chain visibility.
          </p>
        </div>

        <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300">
          <div class="w-16 h-16 bg-[#00A86B]/10 rounded-full flex items-center justify-center mb-6">
            <i class="fas fa-eye text-[#00A86B] text-2xl"></i>
          </div>
          <h3 class="text-2xl font-bold mb-4 text-gray-800 dark:text-white">Our Vision</h3>
          <p class="text-gray-600 dark:text-gray-300">
            To create a future where every Ghanaian business, regardless of size, has access to powerful inventory management tools that were previously only available to large enterprises. We envision a Ghana where SMEs can compete effectively through efficient operations and data-driven decision making.
          </p>
        </div>
      </div>
    </div>
  </section>

  <%# Core Values Section %>
  <section class="mb-24">
    <div class="text-center mb-16">
      <span class="text-[#0055A4] font-semibold text-sm uppercase tracking-wider">What We Stand For</span>
      <h2 class="text-3xl md:text-4xl font-bold mt-2 mb-6 text-gray-800 dark:text-white">Our Core Values</h2>
      <p class="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto">
        These principles guide everything we do, from product development to customer support.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-lg border-t-4 border-[#0055A4] hover:shadow-xl transform hover:-translate-y-2 transition-all duration-300">
        <div class="w-16 h-16 bg-[#0055A4]/10 rounded-full flex items-center justify-center mb-6">
          <i class="fas fa-hand-holding-usd text-[#0055A4] text-2xl"></i>
        </div>
        <h3 class="text-xl font-bold mb-4 text-gray-800 dark:text-white">Affordability</h3>
        <p class="text-gray-600 dark:text-gray-300">
          We believe that powerful inventory management tools should be accessible to businesses of all sizes. Our pricing is designed specifically for the Ghanaian market, ensuring SMEs can afford our solutions without compromising on quality.
        </p>
      </div>

      <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-lg border-t-4 border-[#00A86B] hover:shadow-xl transform hover:-translate-y-2 transition-all duration-300">
        <div class="w-16 h-16 bg-[#00A86B]/10 rounded-full flex items-center justify-center mb-6">
          <i class="fas fa-users text-[#00A86B] text-2xl"></i>
        </div>
        <h3 class="text-xl font-bold mb-4 text-gray-800 dark:text-white">Accessibility</h3>
        <p class="text-gray-600 dark:text-gray-300">
          We design our products to be intuitive and easy to use for everyone, regardless of technical expertise or digital literacy. Our interfaces use clear visual cues and simple language that anyone can understand.
        </p>
      </div>

      <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-lg border-t-4 border-[#FFD700] hover:shadow-xl transform hover:-translate-y-2 transition-all duration-300">
        <div class="w-16 h-16 bg-[#FFD700]/10 rounded-full flex items-center justify-center mb-6">
          <i class="fas fa-wifi-slash text-[#FFD700] text-2xl"></i>
        </div>
        <h3 class="text-xl font-bold mb-4 text-gray-800 dark:text-white">Reliability</h3>
        <p class="text-gray-600 dark:text-gray-300">
          We understand the challenges of unstable internet connectivity in many parts of Ghana. That's why we've built our system to work offline, ensuring your business operations continue smoothly regardless of connection status.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8">
      <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-lg border-t-4 border-[#0055A4] hover:shadow-xl transform hover:-translate-y-2 transition-all duration-300">
        <div class="w-16 h-16 bg-[#0055A4]/10 rounded-full flex items-center justify-center mb-6">
          <i class="fas fa-globe-africa text-[#0055A4] text-2xl"></i>
        </div>
        <h3 class="text-xl font-bold mb-4 text-gray-800 dark:text-white">Local Relevance</h3>
        <p class="text-gray-600 dark:text-gray-300">
          Our solutions are built specifically for the Ghanaian market, with integrations to local payment platforms and features that address the unique business practices of SMEs in Ghana's retail and distribution sectors.
        </p>
      </div>

      <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-lg border-t-4 border-[#00A86B] hover:shadow-xl transform hover:-translate-y-2 transition-all duration-300">
        <div class="w-16 h-16 bg-[#00A86B]/10 rounded-full flex items-center justify-center mb-6">
          <i class="fas fa-headset text-[#00A86B] text-2xl"></i>
        </div>
        <h3 class="text-xl font-bold mb-4 text-gray-800 dark:text-white">Local Support</h3>
        <p class="text-gray-600 dark:text-gray-300">
          We provide support in English and local languages through channels that are accessible to our customers, including WhatsApp and phone. Our support team understands the local business environment and is ready to help.
        </p>
      </div>
    </div>
  </section>

  <%# Team Section %>
  <section id="team" class="mb-24">
    <div class="text-center mb-16">
      <span class="text-[#00A86B] font-semibold text-sm uppercase tracking-wider">The People Behind SupplyFlow</span>
