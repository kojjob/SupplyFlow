<%# Offline Page %>
<% content_for :title, page_title("Offline") %>

<div class="min-h-screen flex items-center justify-center bg-gray-100 dark:bg-gray-900 px-4">
  <div class="max-w-md w-full text-center">
    <div class="mb-8">
      <div class="icon-container-neon mx-auto mb-6 w-24 h-24 text-3xl">
        <i class="fas fa-wifi-slash"></i>
      </div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">You're Offline</h1>
      <p class="text-gray-600 dark:text-gray-400 mb-8">
        It looks like you've lost your internet connection. Please check your connection and try again.
      </p>
      
      <div class="space-y-4">
        <button 
          onclick="window.location.reload()" 
          class="btn-gradient w-full flex items-center justify-center shadow-neon"
        >
          <i class="fas fa-sync-alt mr-2"></i>
          Retry Connection
        </button>
        
        <a href="/" class="btn-glass w-full flex items-center justify-center">
          <i class="fas fa-home mr-2"></i>
          Go to Homepage
        </a>
      </div>
    </div>
    
    <div class="text-sm text-gray-500 dark:text-gray-500">
      <p>Some features may be available offline.</p>
      <p class="mt-2">SupplyFlow &copy; <%= Date.today.year %></p>
    </div>
  </div>
</div>
