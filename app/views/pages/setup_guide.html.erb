<%= content_for :title, "Setup Guide" %>
<div class="min-h-screen bg-gradient-to-br from-blue-50 to-white">
  <%# Header Section %>
  <div class="bg-sky-900 shadow-md">
    <div class="container mx-auto px-4 py-6">
      <h1 class="text-3xl font-bold text-sky-200">Welcome to SupplyFlow</h1>
      <p class="text-blue-100 mt-2">Your comprehensive inventory management system for SMEs in Ghana</p>
    </div>
  </div>

  <%# Main Content Container %>
  <div class="container mx-auto px-4 py-8">
    
    <%# Progress Indicator %>
    <div class="mb-12">
      <div class="flex items-center justify-between max-w-3xl mx-auto">
        <% steps = ['Account Setup', 'Business Details', 'Inventory Setup', 'Connect Payments', 'Invite Team'] %>
        <% steps.each_with_index do |step, index| %>
          <div class="flex flex-col items-center">
            <div class="w-10 h-10 flex items-center justify-center rounded-full <%= index <= @current_step ? 'bg-primary text-white' : 'bg-gray-200 text-gray-500' %> font-bold">
              <%= index + 1 %>
            </div>
            <span class="text-xs mt-2 text-center <%= index <= @current_step ? 'text-primary font-medium' : 'text-gray-500' %>"><%= step %></span>
          </div>
          <% if index < steps.length - 1 %>
            <div class="w-16 h-1 <%= index < @current_step ? 'bg-primary' : 'bg-gray-200' %>"></div>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# Setup Cards Container %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
      
      <%# Account Setup Card %>
      <div class="bg-white rounded-lg shadow-md overflow-hidden border border-gray-100 transition-all hover:shadow-lg">
        <div class="bg-blue-600 p-4 flex items-center">
          <div class="bg-white rounded-full p-2 mr-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <h3 class="text-white text-lg font-semibold">1. Account Setup</h3>
        </div>
        <div class="p-5">
          <p class="text-gray-600 mb-4">Create your admin account to get started with SupplyFlow.</p>
          <ul class="space-y-3 mb-5">
            <li class="flex items-start">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-500 mr-2 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Set up your admin credentials</span>
            </li>
            <li class="flex items-start">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-500 mr-2 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700">Verify your email address</span>
            </li>
            <li class="flex items-start">
              <div class="h-5 w-5 bg-blue-100 rounded-full flex items-center justify-center mr-2 mt-0.5">
                <span class="text-blue-600 text-xs font-bold">3</span>
              </div>
              <span class="text-gray-700">Choose your subscription plan</span>
            </li>
          </ul>
          <a href="#" class="block text-center py-2 px-4 bg-primary hover:bg-blue-700 text-white font-medium rounded transition-colors">
            Complete Setup
          </a>
        </div>
      </div>
      
      <%# Business Details Card %>
      <div class="bg-white rounded-lg shadow-md overflow-hidden border border-gray-100 transition-all hover:shadow-lg">
        <div class="bg-blue-500 p-4 flex items-center">
          <div class="bg-white rounded-full p-2 mr-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="text-white text-lg font-semibold">2. Business Details</h3>
        </div>
        <div class="p-5">
          <p class="text-gray-600 mb-4">Tell us about your business to personalize your experience.</p>
          <ul class="space-y-3 mb-5">
            <li class="flex items-start">
              <div class="h-5 w-5 bg-blue-100 rounded-full flex items-center justify-center mr-2 mt-0.5">
                <span class="text-blue-600 text-xs font-bold">1</span>
              </div>
              <span class="text-gray-700">Enter your business name and details</span>
            </li>
            <li class="flex items-start">
              <div class="h-5 w-5 bg-blue-100 rounded-full flex items-center justify-center mr-2 mt-0.5">
                <span class="text-blue-600 text-xs font-bold">2</span>
              </div>
              <span class="text-gray-700">Set your business address</span>
            </li>
            <li class="flex items-start">
              <div class="h-5 w-5 bg-blue-100 rounded-full flex items-center justify-center mr-2 mt-0.5">
                <span class="text-blue-600 text-xs font-bold">3</span>
              </div>
              <span class="text-gray-700">Configure business hours</span>
            </li>
          </ul>
          <button class="w-full py-2 px-4 bg-gray-200 text-gray-500 font-medium rounded cursor-not-allowed">
            Locked
          </button>
        </div>
      </div>
      
      <%# Inventory Setup Card %>
      <div class="bg-white rounded-lg shadow-md overflow-hidden border border-gray-100 transition-all hover:shadow-lg">
        <div class="bg-gray-400 p-4 flex items-center">
          <div class="bg-white rounded-full p-2 mr-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
          </div>
          <h3 class="text-white text-lg font-semibold">3. Inventory Setup</h3>
        </div>
        <div class="p-5">
          <p class="text-gray-600 mb-4">Start managing your inventory by adding your products.</p>
          <ul class="space-y-3 mb-5">
            <li class="flex items-start">
              <div class="h-5 w-5 bg-gray-200 rounded-full flex items-center justify-center mr-2 mt-0.5">
                <span class="text-gray-500 text-xs font-bold">1</span>
              </div>
              <span class="text-gray-500">Add product categories</span>
            </li>
            <li class="flex items-start">
              <div class="h-5 w-5 bg-gray-200 rounded-full flex items-center justify-center mr-2 mt-0.5">
                <span class="text-gray-500 text-xs font-bold">2</span>
              </div>
              <span class="text-gray-500">Add your first products</span>
            </li>
            <li class="flex items-start">
              <div class="h-5 w-5 bg-gray-200 rounded-full flex items-center justify-center mr-2 mt-0.5">
                <span class="text-gray-500 text-xs font-bold">3</span>
              </div>
              <span class="text-gray-500">Set up inventory levels</span>
            </li>
          </ul>
          <button class="w-full py-2 px-4 bg-gray-200 text-gray-500 font-medium rounded cursor-not-allowed">
            Locked
          </button>
        </div>
      </div>

      <%# Connect Payments Card %>
      <div class="bg-white rounded-lg shadow-md overflow-hidden border border-gray-100 transition-all hover:shadow-lg">
        <div class="bg-gray-400 p-4 flex items-center">
          <div class="bg-white rounded-full p-2 mr-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
            </svg>
          </div>
          <h3 class="text-white text-lg font-semibold">4. Connect Payments</h3>
        </div>
        <div class="p-5">
          <p class="text-gray-600 mb-4">Set up payment options for your business transactions.</p>
          <ul class="space-y-3 mb-5">
            <li class="flex items-start">
              <div class="h-5 w-5 bg-gray-200 rounded-full flex items-center justify-center mr-2 mt-0.5">
                <span class="text-gray-500 text-xs font-bold">1</span>
              </div>
              <span class="text-gray-500">Connect MTN Mobile Money</span>
            </li>
            <li class="flex items-start">
              <div class="h-5 w-5 bg-gray-200 rounded-full flex items-center justify-center mr-2 mt-0.5">
                <span class="text-gray-500 text-xs font-bold">2</span>
              </div>
              <span class="text-gray-500">Set up Hubtel integration</span>
            </li>
            <li class="flex items-start">
              <div class="h-5 w-5 bg-gray-200 rounded-full flex items-center justify-center mr-2 mt-0.5">
                <span class="text-gray-500 text-xs font-bold">3</span>
              </div>
              <span class="text-gray-500">Configure payment notifications</span>
            </li>
          </ul>
          <button class="w-full py-2 px-4 bg-gray-200 text-gray-500 font-medium rounded cursor-not-allowed">
            Locked
          </button>
        </div>
      </div>

      <%# Invite Team Card %>
      <div class="bg-white rounded-lg shadow-md overflow-hidden border border-gray-100 transition-all hover:shadow-lg">
        <div class="bg-gray-400 p-4 flex items-center">
          <div class="bg-white rounded-full p-2 mr-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-white text-lg font-semibold">5. Invite Team</h3>
        </div>
        <div class="p-5">
          <p class="text-gray-600 mb-4">Add team members and set their access permissions.</p>
          <ul class="space-y-3 mb-5">
            <li class="flex items-start">
              <div class="h-5 w-5 bg-gray-200 rounded-full flex items-center justify-center mr-2 mt-0.5">
                <span class="text-gray-500 text-xs font-bold">1</span>
              </div>
              <span class="text-gray-500">Add team members</span>
            </li>
            <li class="flex items-start">
              <div class="h-5 w-5 bg-gray-200 rounded-full flex items-center justify-center mr-2 mt-0.5">
                <span class="text-gray-500 text-xs font-bold">2</span>
              </div>
              <span class="text-gray-500">Set user roles and permissions</span>
            </li>
            <li class="flex items-start">
              <div class="h-5 w-5 bg-gray-200 rounded-full flex items-center justify-center mr-2 mt-0.5">
                <span class="text-gray-500 text-xs font-bold">3</span>
              </div>
              <span class="text-gray-500">Configure notification preferences</span>
            </li>
          </ul>
          <button class="w-full py-2 px-4 bg-gray-200 text-gray-500 font-medium rounded cursor-not-allowed">
            Locked
          </button>
        </div>
      </div>

      <%# Help & Resources Card %>
      <div class="bg-gradient-to-br from-blue-500 to-blue-600 rounded-lg shadow-md overflow-hidden border border-blue-400 text-white transition-all hover:shadow-lg">
        <div class="p-5">
          <div class="flex items-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h3 class="text-xl font-bold">Help & Resources</h3>
          </div>
          <ul class="space-y-4 mb-4">
            <li class="flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <a href="#" class="hover:underline">Setup Documentation</a>
            </li>
            <li class="flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
              <a href="#" class="hover:underline">Video Tutorials</a>
            </li>
            <li class="flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
              </svg>
              <a href="#" class="hover:underline">Contact Support</a>
            </li>
          </ul>
          <a href="#" class="block text-center mt-6 py-2 px-4 bg-white text-blue-600 font-medium rounded transition-colors hover:bg-blue-50">
            Visit Help Center
          </a>
        </div>
      </div>
    </div>

    <%# Features Overview Section %>
    <div class="mt-16 mb-12">
      <h2 class="text-2xl font-bold text-gray-800 mb-6 text-center">Explore SupplyFlow's Key Features</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <%# Feature 1 %>
        <div class="bg-white p-6 rounded-lg shadow-md border border-gray-100">
          <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-800 mb-2">Real-time Inventory Tracking</h3>
          <p class="text-gray-600">Keep track of your stock levels in real-time with automatic updates as you make sales or receive new stock.</p>
        </div>
        
        <%# Feature 2 %>
        <div class="bg-white p-6 rounded-lg shadow-md border border-gray-100">
          <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-800 mb-2">Low Stock Alerts</h3>
          <p class="text-gray-600">Never run out of stock again with customizable alerts that notify you when products are running low.</p>
        </div>
        
        <%# Feature 3 %>
        <div class="bg-white p-6 rounded-lg shadow-md border border-gray-100">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-800 mb-2">Supplier Management</h3>
          <p class="text-gray-600">Streamline your ordering process with easy-to-use supplier management and automated purchase orders.</p>
        </div>
        
        <%# Feature 4 %>
        <div class="bg-white p-6 rounded-lg shadow-md border border-gray-100">
          <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-800 mb-2">Sales Forecasting</h3>
          <p class="text-gray-600">Make data-driven decisions with sales forecasting based on your historical data and trends.</p>
        </div>
        
        <%# Feature 5 %>
        <div class="bg-white p-6 rounded-lg shadow-md border border-gray-100">
          <div class="w-12 h-12 bg-yellow-100 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-800 mb-2">Payment Integration</h3>
          <p class="text-gray-600">Easily connect with popular Ghanaian payment platforms like MTN Mobile Money and Hubtel.</p>
        </div>
        
        <%# Feature 6 %>
        <div class="bg-white p-6 rounded-lg shadow-md border border-gray-100">
          <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-800 mb-2">Mobile Responsive</h3>
          <p class="text-gray-600">Access your inventory management system from anywhere, on any device, even with limited connectivity.</p>
        </div>
      </div>
    </div>

    <%# Testimonials Section %>
    <div class="mt-16 mb-12 bg-gray-50 rounded-xl p-8">
      <h2 class="text-2xl font-bold text-gray-800 mb-8 text-center">What Our Customers Say</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <%# Testimonial 1 %>
        <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mr-4 text-blue-600 font-bold">
              AO
            </div>
            <div>
              <h4 class="font-semibold text-gray-800">Abena Owusu</h4>
              <p class="text-gray-500 text-sm">Retail Shop Owner, Kumasi</p>
            </div>
          </div>
          <p class="text-gray-600 italic">"SupplyFlow has revolutionized how I manage my shop inventory. I no longer worry about running out of stock or overstocking items. The mobile access means I can check my inventory even when I'm away from the shop."</p>
          <div class="mt-4 flex text-yellow-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
