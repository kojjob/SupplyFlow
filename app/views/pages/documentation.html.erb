<%# Include Alpine.js for interactivity %>
<script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>

<%# Custom JavaScript for documentation Page %>
<% content_for :page_javascript do %>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Set initial active section based on URL hash or default to introduction
      const initialHash = window.location.hash.substring(1) || 'introduction';
      const targetSection = document.getElementById(initialHash);
      
      if (targetSection) {
        // Scroll to the section after a small delay to ensure Alpine has initialized
        setTimeout(() => {
          targetSection.scrollIntoView({ behavior: 'smooth' });
        }, 100);
      }
      
      // Handle internal documentation links
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
          const targetId = this.getAttribute('href').substring(1);
          const targetElement = document.getElementById(targetId);
          
          if (targetElement) {
            e.preventDefault();
            history.pushState(null, '', `#${targetId}`);
            targetElement.scrollIntoView({ behavior: 'smooth' });
            
            // This will trigger Alpine to update the active section
            window.dispatchEvent(new CustomEvent('hashchange'));
          }
        });
      });
    });
  </script>
<% end %>