<div id="<%= dom_id(review) %>" class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg shadow">
  <div class="flex items-start space-x-3">
    <% if review.user.avatar.attached? %>
      <%= image_tag review.user.avatar.variant(resize_to_fill: [40, 40]), class: "w-10 h-10 rounded-full" %>
    <% else %>
      <span class="inline-flex items-center justify-center h-10 w-10 rounded-full bg-gray-300 dark:bg-gray-600">
        <span class="text-sm font-medium leading-none text-gray-700 dark:text-gray-200"><%= review.user.name&.initials || '?' %></span>
      </span>
    <% end %>
    <div>
      <p class="text-sm font-semibold text-gray-900 dark:text-white"><%= review.user.name || "Anonymous" %></p>
      <p class="text-xs text-gray-500 dark:text-gray-400"><%= time_ago_in_words(review.created_at) %> ago</p>
    </div>
  </div>

  <div class="mt-2 flex items-center">
    <% (1..5).each do |star| %>
      <% if star <= review.rating %>
        <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
      <% else %>
        <svg class="w-5 h-5 text-gray-300 dark:text-gray-600 fill-current" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
      <% end %>
    <% end %>
    <span class="ml-2 text-sm text-gray-600 dark:text-gray-400">(<%= review.rating %>/5)</span>
  </div>

  <p class="mt-3 text-gray-700 dark:text-gray-300 whitespace-pre-wrap"><%= review.body %></p>

  <% if policy(review).update? || policy(review).destroy? %>
    <div class="mt-3 flex space-x-3">
      <% if policy(review).update? %>
        <%# Link to an edit form/modal - for simplicity, this might link to a separate page or trigger a Turbo Frame update %>
        <%# <%= link_to "Edit", edit_post_review_path(review.post, review), class: "text-xs text-blue-500 hover:text-blue-700" %>
      <% end %>
      <% if policy(review).destroy? %>
        <%= button_to "Delete", post_review_path(review.post, review), method: :delete, data: { confirm: "Are you sure?" }, class: "text-xs text-red-500 hover:text-red-700" %>
      <% end %>
    </div>
  <% end %>
</div>
