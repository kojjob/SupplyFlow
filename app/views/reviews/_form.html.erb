<%= form_with(model: [post, review], local: true, class: "space-y-4") do |form| %>
  <% if review.errors.any? %>
    <div id="error_explanation_review" class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative" role="alert">
      <strong class="font-bold"><%= pluralize(review.errors.count, "error") %> prohibited this review from being saved:</strong>
      <ul class="mt-2 list-disc list-inside">
        <% review.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :rating, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <div class="mt-1 flex">
      <% (1..5).each do |i| %>
        <%= form.radio_button :rating, i, class: "sr-only peer" %>
        <%= form.label "rating_#{i}", class: "w-8 h-8 flex items-center justify-center text-gray-400 peer-checked:text-yellow-400 cursor-pointer" do %>
          <svg class="w-6 h-6 fill-current" viewBox="0 0 20 20"><path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/></svg>
        <% end %>
      <% end %>
    </div>
    <% if review.errors[:rating].any? %>
      <p class="mt-1 text-xs text-red-600"><%= review.errors[:rating].to_sentence %></p>
    <% end %>
  </div>

  <div>
    <%= form.label :body, "Your Review", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <%= form.text_area :body, rows: 4, class: "mt-1 block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm dark:bg-gray-700 dark:text-white", placeholder: "Write your review here..." %>
    <% if review.errors[:body].any? %>
      <p class="mt-1 text-xs text-red-600"><%= review.errors[:body].to_sentence %></p>
    <% end %>
  </div>

  <div class="flex justify-end">
    <%= form.submit "Submit Review", class: "bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded cursor-pointer" %>
  </div>
<% end %>
