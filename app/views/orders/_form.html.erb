<%# app/views/orders/_form.html.erb %>

<%= form_with(model: order, class: "space-y-8", data: { controller: "nested-form" }) do |form| %>
  <% if order.errors.any? %>
    <div class="rounded-md bg-red-50 p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">There were <%= pluralize(order.errors.count, "error") %> with your submission</h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% order.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%# Customer & Order Information Section %>
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-4 py-5 sm:p-6">
      <h3 class="text-lg font-medium leading-6 text-gray-900 mb-4">Customer & Order Information</h3>
      
      <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
        <%# Customer Selection %>
        <div class="sm:col-span-3">
          <%= form.label :customer_id, "Customer", class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= form.collection_select :customer_id, @customers, :id, :name, 
                { include_blank: "Select a customer" }, 
                { class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", required: true,
                  data: { action: "change->form#fetchCustomerDetails" } } %>
          </div>
        </div>

        <%# Order Date %>
        <div class="sm:col-span-3">
          <%= form.label :order_date, class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= form.date_field :order_date, class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", required: true %>
          </div>
        </div>

        <%# Status - Only show for existing orders %>
        <% unless order.new_record? %>
          <div class="sm:col-span-3">
            <%= form.label :status, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.select :status, Order.statuses.map { |s| [s.humanize, s] }, 
                  {}, 
                  { class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" } %>
            </div>
          </div>

          <%# Payment Status %>
          <div class="sm:col-span-3">
            <%= form.label :payment_status, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.select :payment_status, Order.payment_statuses.map { |ps| [ps.humanize, ps] }, 
                  {}, 
                  { class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" } %>
            </div>
          </div>
        <% end %>

        <%# Shipping Method %>
        <div class="sm:col-span-3">
          <%= form.label :shipping_method, class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= form.select :shipping_method, [
                ["Standard Shipping", "standard"], 
                ["Express Shipping", "express"], 
                ["In-Store Pickup", "pickup"]
              ], 
              { include_blank: "Select shipping method" }, 
              { class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" } %>
          </div>
        </div>

        <%# Tracking Number - Only show for existing orders that are not draft %>
        <% if !order.new_record? && order.status != "draft" %>
          <div class="sm:col-span-3">
            <%= form.label :tracking_number, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_field :tracking_number, class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "Enter tracking number" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Shipping & Billing Address Section %>
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-4 py-5 sm:p-6">
      <h3 class="text-lg font-medium leading-6 text-gray-900 mb-4">Shipping & Billing Information</h3>
      
      <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
        <%# Shipping Address %>
        <div class="sm:col-span-3">
          <%= form.label :shipping_address, class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= form.text_area :shipping_address, rows: 4, class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "Enter shipping address" %>
          </div>
        </div>

        <%# Billing Address %>
        <div class="sm:col-span-3">
          <%= form.label :billing_address, class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= form.text_area :billing_address, rows: 4, class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "Enter billing address" %>
          </div>
          <div class="mt-2">
            <div class="flex items-start">
              <div class="flex h-5 items-center">
                <input type="checkbox" id="same_as_shipping" class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" data-action="change->form#copyShippingAddress">
              </div>
              <div class="ml-3 text-sm">
                <label for="same_as_shipping" class="font-medium text-gray-700">Same as shipping address</label>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Order Items Section %>
  <div class="bg-white shadow rounded-lg overflow-hidden" data-nested-form-target="items">
    <div class="px-4 py-5 sm:p-6">
      <div class="flex justify-between items-center mb-4">
        <h3 class="text-lg font-medium leading-6 text-gray-900">Order Items</h3>
        <button type="button" data-action="nested-form#add" class="inline-flex items-center rounded-md border border-transparent bg-indigo-100 px-4 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-200 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          Add Item
        </button>
      </div>
      
      <template data-nested-form-target="template">
        <%= form.fields_for :order_items, OrderItem.new, child_index: 'NEW_RECORD' do |item_form| %>
          <div class="nested-fields border border-gray-200 rounded-md p-4 mb-4" data-new-record="true">
            <div class="grid grid-cols-1 gap-y-4 gap-x-4 sm:grid-cols-12">
              <div class="sm:col-span-5">
                <%= item_form.label :product_id, "Product", class: "block text-sm font-medium text-gray-700" %>
                <div class="mt-1">
                  <%= item_form.collection_select :product_id, @products, :id, :name, 
                      { include_blank: "Select a product" }, 
                      { class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", required: true,
                        data: { action: "change->form#fetchProductDetails" } } %>
                </div>
              </div>
              
              <div class="sm:col-span-2">
                <%= item_form.label :quantity, class: "block text-sm font-medium text-gray-700" %>
                <div class="mt-1">
                  <%= item_form.number_field :quantity, min: 1, class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", required: true, data: { action: "change->form#updateItemTotal" } %>
                </div>
              </div>
              
              <div class="sm:col-span-2">
                <%= item_form.label :unit_price, class: "block text-sm font-medium text-gray-700" %>
                <div class="mt-1 relative rounded-md shadow-sm">
                  <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                    <span class="text-gray-500 sm:text-sm">₵</span>
                  </div>
                  <%= item_form.number_field :unit_price, min: 0, step: 0.01, class: "py-3 px-4 block w-full rounded-md border border-gray-300 pl-7 pr-12 focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", required: true, data: { action: "change->form#updateItemTotal" } %>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                    <span class="text-gray-500 sm:text-sm">GHS</span>
                  </div>
                </div>
              </div>
              
              <div class="sm:col-span-2">
                <%= item_form.label :tax_rate, class: "block text-sm font-medium text-gray-700" %>
                <div class="mt-1 relative rounded-md shadow-sm">
                  <%= item_form.number_field :tax_rate, min: 0, step: 0.01, class: "py-3 px-4 block w-full rounded-md border border-gray-300 pr-12 focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", data: { action: "change->form#updateItemTotal" } %>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                    <span class="text-gray-500 sm:text-sm">%</span>
                  </div>
                </div>
              </div>
              
              <div class="sm:col-span-1 flex items-end">
                <button type="button" data-action="nested-form#remove" class="inline-flex items-center justify-center rounded-md border border-transparent bg-red-100 px-4 py-2 text-sm font-medium text-red-700 hover:bg-red-200 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 h-10">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                  </svg>
                </button>
              </div>
            </div>
            
            <%= item_form.hidden_field :_destroy %>
          </div>
        <% end %>
      </template>

      <%= form.fields_for :order_items do |item_form| %>
        <div class="nested-fields border border-gray-200 rounded-md p-4 mb-4">
          <div class="grid grid-cols-1 gap-y-4 gap-x-4 sm:grid-cols-12">
            <div class="sm:col-span-5">
              <%= item_form.label :product_id, "Product", class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1">
                <%= item_form.collection_select :product_id, @products, :id, :name, 
                    { include_blank: "Select a product" }, 
                    { class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", required: true,
                      data: { action: "change->form#fetchProductDetails" } } %>
              </div>
            </div>
            
            <div class="sm:col-span-2">
              <%= item_form.label :quantity, class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1">
                <%= item_form.number_field :quantity, min: 1, class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", required: true, data: { action: "change->form#updateItemTotal" } %>
              </div>
            </div>
            
            <div class="sm:col-span-2">
              <%= item_form.label :unit_price, class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1 relative rounded-md shadow-sm">
                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                  <span class="text-gray-500 sm:text-sm">₵</span>
                </div>
                <%= item_form.number_field :unit_price, min: 0, step: 0.01, class: "py-3 px-4 block w-full rounded-md border border-gray-300 pl-7 pr-12 focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", required: true, data: { action: "change->form#updateItemTotal" } %>
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                  <span class="text-gray-500 sm:text-sm">GHS</span>
                </div>
              </div>
            </div>
            
            <div class="sm:col-span-2">
              <%= item_form.label :tax_rate, class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1 relative rounded-md shadow-sm">
                <%= item_form.number_field :tax_rate, min: 0, step: 0.01, class: "py-3 px-4 block w-full rounded-md border border-gray-300 pr-12 focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", data: { action: "change->form#updateItemTotal" } %>
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                  <span class="text-gray-500 sm:text-sm">%</span>
                </div>
              </div>
            </div>
            
            <div class="sm:col-span-1 flex items-end">
              <button type="button" data-action="nested-form#remove" class="inline-flex items-center justify-center rounded-md border border-transparent bg-red-100 px-4 py-2 text-sm font-medium text-red-700 hover:bg-red-200 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 h-10">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                </svg>
              </button>
            </div>
          </div>
          
          <%= item_form.hidden_field :_destroy %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Totals Section %>
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-4 py-5 sm:p-6">
      <h3 class="text-lg font-medium leading-6 text-gray-900 mb-4">Order Totals</h3>
      
      <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
        <%# Subtotal - Calculated from items, display only %>
        <div class="sm:col-span-2">
          <%= form.label :subtotal, class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1 relative rounded-md shadow-sm">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
              <span class="text-gray-500 sm:text-sm">₵</span>
            </div>
            <div id="subtotal_display" class="py-3 px-4 block w-full rounded-md border border-gray-300 bg-gray-50 pl-7 pr-12 py-2 text-sm text-gray-900"><%= order.subtotal || 0 %></div>
            <%= form.hidden_field :subtotal %>
          </div>
        </div>

        <%# Tax Amount %>
        <div class="sm:col-span-2">
          <%= form.label :tax_amount, class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1 relative rounded-md shadow-sm">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
              <span class="text-gray-500 sm:text-sm">₵</span>
            </div>
            <%= form.number_field :tax_amount, min: 0, step: 0.01, class: "py-3 px-4 block w-full rounded-md border border-gray-300 pl-7 pr-12 focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", data: { action: "change->form#updateOrderTotal" } %>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
              <span class="text-gray-500 sm:text-sm">GHS</span>
            </div>
          </div>
        </div>

        <%# Shipping Amount %>
        <div class="sm:col-span-2">
          <%= form.label :shipping_amount, class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1 relative rounded-md shadow-sm">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
              <span class="text-gray-500 sm:text-sm">₵</span>
            </div>
            <%= form.number_field :shipping_amount, min: 0, step: 0.01, class: "py-3 px-4 block w-full rounded-md border border-gray-300 pl-7 pr-12 focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", data: { action: "change->form#updateOrderTotal" } %>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
              <span class="text-gray-500 sm:text-sm">GHS</span>
            </div>
          </div>
        </div>

        <%# Discount Amount %>
        <div class="sm:col-span-2">
          <%= form.label :discount_amount, class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1 relative rounded-md shadow-sm">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
              <span class="text-gray-500 sm:text-sm">₵</span>
            </div>
            <%= form.number_field :discount_amount, min: 0, step: 0.01, class: "py-3 px-4 block w-full rounded-md border border-gray-300 pl-7 pr-12 focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", data: { action: "change->form#updateOrderTotal" } %>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
              <span class="text-gray-500 sm:text-sm">GHS</span>
            </div>
          </div>
        </div>

        <%# Total Amount - Calculated, display only %>
        <div class="sm:col-span-4">
          <%= form.label :total_amount, class: "block text-sm font-medium text-gray-900" %>
          <div class="mt-1 relative rounded-md shadow-sm">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
              <span class="text-gray-500 sm:text-sm">₵</span>
            </div>
            <div id="total_amount_display" class="py-3 px-4 block w-full rounded-md border border-gray-300 bg-gray-50 pl-7 pr-12 py-2 text-sm font-bold text-gray-900"><%= order.total_amount || 0 %></div>
            <%= form.hidden_field :total_amount %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Notes Section %>
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-4 py-5 sm:p-6">
      <h3 class="text-lg font-medium leading-6 text-gray-900 mb-4">Additional Information</h3>
      
      <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
        <%# Notes %>
        <div class="sm:col-span-6">
          <%= form.label :notes, class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1">
            <%= form.text_area :notes, rows: 4, class: "py-3 px-4 block w-full rounded-md border border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "Enter any additional notes about this order" %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Form Actions %>
  <div class="flex justify-end space-x-3 pt-5">
    <%= link_to "Cancel", @order.persisted? ? order_path(@order) : orders_path, class: "rounded-md border border-gray-300 bg-white py-2 px-4 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
    
    <%= form.submit @order.persisted? ? "Update Order" : "Create Order", class: "inline-flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
  </div>
<% end %>