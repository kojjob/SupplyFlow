<% content_for :title, "Orders | SupplyFlow" %>

<div class="container mx-auto px-4 py-8">
  <%# Page Header Section %>
  <div class="mb-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Orders</h1>
        <p class="mt-1 text-sm text-gray-500">Manage your customer orders</p>
      </div>
      <div class="mt-4 sm:mt-0 flex flex-wrap gap-2">
        <%= link_to new_order_path, class: "inline-flex items-center rounded-md border border-transparent bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          New Order
        <% end %>
      </div>
    </div>
  </div>

  <%# Filters Section %>
  <div class="bg-white shadow rounded-lg overflow-hidden mb-8">
    <div class="px-4 py-5 sm:p-6">
      <%= form_with url: orders_path, method: :get, data: { controller: "form", action: "submit->form#submit" }, class: "space-y-4" do |form| %>
        <div class="grid grid-cols-1 gap-y-4 gap-x-4 sm:grid-cols-6">
          <%# Status Filter %>
          <div class="sm:col-span-2">
            <%= form.label :status, "Status", class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.select :status, 
                  [["All Statuses", ""], 
                   ["Draft", "draft"], 
                   ["Pending", "pending"], 
                   ["Processing", "processing"], 
                   ["Shipped", "shipped"], 
                   ["Delivered", "delivered"], 
                   ["Canceled", "canceled"], 
                   ["Returned", "returned"]], 
                  { selected: params[:status] }, 
                  { class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" } %>
            </div>
          </div>

          <%# Payment Status Filter %>
          <div class="sm:col-span-2">
            <%= form.label :payment_status, "Payment Status", class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.select :payment_status, 
                  [["All Payment Statuses", ""], 
                   ["Unpaid", "unpaid"], 
                   ["Partially Paid", "partially_paid"], 
                   ["Paid", "paid"], 
                   ["Refunded", "refunded"]], 
                  { selected: params[:payment_status] }, 
                  { class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" } %>
            </div>
          </div>

          <%# Date Range Filters %>
          <div class="sm:col-span-2">
            <%= form.label :date_range, "Order Date Range", class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1 flex space-x-2">
              <%= form.date_field :start_date, value: params[:start_date], placeholder: "From", class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
              <%= form.date_field :end_date, value: params[:end_date], placeholder: "To", class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
          </div>

          <%# Search Query %>
          <div class="sm:col-span-4">
            <%= form.label :query, "Search", class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.text_field :query, value: params[:query], placeholder: "Search by order number or customer name", class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
          </div>

          <%# Sort Order %>
          <div class="sm:col-span-2">
            <%= form.label :sort, "Sort By", class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= form.select :sort, 
                  [["Newest First", "date_desc"], 
                   ["Oldest First", "date_asc"], 
                   ["Highest Amount", "total_desc"], 
                   ["Lowest Amount", "total_asc"]], 
                  { selected: params[:sort] || "date_desc" }, 
                  { class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" } %>
            </div>
          </div>
        </div>

        <div class="flex justify-end">
          <%= link_to "Clear Filters", orders_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 mr-2" %>
          <%= form.button type: "submit", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
            </svg>
            Apply Filters
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Orders Table %>
  <div class="bg-white shadow rounded-lg overflow-hidden mb-8">
    <div class="px-4 py-5 sm:p-6">
      <% if @orders.present? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-300">
            <thead class="bg-gray-50">
              <tr>
                <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900">Order #</th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Customer</th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Date</th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Status</th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Payment</th>
                <th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-gray-900">Total</th>
                <th scope="col" class="relative py-3.5 pl-3 pr-4">
                  <span class="sr-only">Actions</span>
                </th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white">
              <% @orders.each do |order| %>
                <tr class="hover:bg-gray-50">
                  <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-indigo-600">
                    <%= link_to order.order_number, order_path(order) %>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-900">
                    <%= link_to order.customer.name, customer_path(order.customer), class: "hover:text-indigo-600" %>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                    <%= order.order_date&.strftime("%b %d, %Y") || "Not set" %>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm">
                    <% case order.status %>
                    <% when "draft" %>
                      <span class="inline-flex rounded-full bg-gray-100 px-2 text-xs font-semibold leading-5 text-gray-800">Draft</span>
                    <% when "pending" %>
                      <span class="inline-flex rounded-full bg-yellow-100 px-2 text-xs font-semibold leading-5 text-yellow-800">Pending</span>
                    <% when "processing" %>
                      <span class="inline-flex rounded-full bg-blue-100 px-2 text-xs font-semibold leading-5 text-blue-800">Processing</span>
                    <% when "shipped" %>
                      <span class="inline-flex rounded-full bg-indigo-100 px-2 text-xs font-semibold leading-5 text-indigo-800">Shipped</span>
                    <% when "delivered" %>
                      <span class="inline-flex rounded-full bg-green-100 px-2 text-xs font-semibold leading-5 text-green-800">Delivered</span>
                    <% when "canceled" %>
                      <span class="inline-flex rounded-full bg-red-100 px-2 text-xs font-semibold leading-5 text-red-800">Canceled</span>
                    <% when "returned" %>
                      <span class="inline-flex rounded-full bg-purple-100 px-2 text-xs font-semibold leading-5 text-purple-800">Returned</span>
                    <% end %>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm">
                    <% case order.payment_status %>
                    <% when "unpaid" %>
                      <span class="inline-flex rounded-full bg-gray-100 px-2 text-xs font-semibold leading-5 text-gray-800">Unpaid</span>
                    <% when "partially_paid" %>
                      <span class="inline-flex rounded-full bg-yellow-100 px-2 text-xs font-semibold leading-5 text-yellow-800">Partial</span>
                    <% when "paid" %>
                      <span class="inline-flex rounded-full bg-green-100 px-2 text-xs font-semibold leading-5 text-green-800">Paid</span>
                    <% when "refunded" %>
                      <span class="inline-flex rounded-full bg-red-100 px-2 text-xs font-semibold leading-5 text-red-800">Refunded</span>
                    <% end %>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-right text-gray-900 font-medium">
                    <%= number_to_currency(order.total_amount, unit: "₵", precision: 2) %>
                  </td>
                  <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium">
                    <div class="relative" data-controller="dropdown">
                      <button type="button" data-action="dropdown#toggle click@window->dropdown#hide" class="inline-flex items-center text-gray-400 hover:text-gray-500 focus:outline-none">
                        <span class="sr-only">Open options</span>
                        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                          <path d="M10 3a1.5 1.5 0 110 3 1.5 1.5 0 010-3zM10 8.5a1.5 1.5 0 110 3 1.5 1.5 0 010-3zM11.5 15.5a1.5 1.5 0 10-3 0 1.5 1.5 0 003 0z" />
                        </svg>
                      </button>
                      <div data-dropdown-target="menu" class="hidden absolute right-0 z-10 mt-2 w-48 origin-top-right rounded-md bg-white py-1 shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none" role="menu">
                        <%= link_to "View Details", order_path(order), class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                        <% if order.status == "draft" %>
                          <%= link_to "Edit Order", edit_order_path(order), class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                        <% end %>
                        <%= link_to "View Invoice", invoice_order_path(order), class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
                        <% if order.status == "draft" %>
                          <%= button_to "Delete Order", order_path(order), method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-red-700 hover:bg-gray-100", data: { confirm: "Are you sure you want to delete this order? This action cannot be undone." } %>
                        <% end %>
                      </div>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        
        <%# Pagination %>
        <div class="flex items-center justify-between border-t border-gray-200 bg-white px-4 py-3 sm:px-6 mt-4">
          <div class="flex flex-1 justify-between sm:hidden">
            <%= link_to_unless params[:page].to_i <= 0, "Previous", orders_path(request.params.merge(page: params[:page].to_i - 1)), class: "relative inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
            <%= link_to_unless (params[:page].to_i + 1) * 25 >= @total_count, "Next", orders_path(request.params.merge(page: params[:page].to_i + 1)), class: "relative ml-3 inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
          </div>
          <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
            <div>
              <p class="text-sm text-gray-700">
                Showing <span class="font-medium"><%= [@orders.offset_value + 1, @total_count].min %></span> to <span class="font-medium"><%= [@orders.offset_value + @orders.count, @total_count].min %></span> of <span class="font-medium"><%= @total_count %></span> orders
              </p>
            </div>
            <div>
              <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm" aria-label="Pagination">
                <%= link_to_unless params[:page].to_i <= 0, "Previous", orders_path(request.params.merge(page: params[:page].to_i - 1)), class: "relative inline-flex items-center rounded-l-md px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-offset-0" %>
                
                <% pages = (@total_count.to_f / 25).ceil %>
                <% [pages, 10].min.times do |i| %>
                  <% if i == params[:page].to_i %>
                    <span class="relative z-10 inline-flex items-center bg-indigo-600 px-4 py-2 text-sm font-semibold text-white focus:z-20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600"><%= i+1 %></span>
                  <% else %>
                    <%= link_to i+1, orders_path(request.params.merge(page: i)), class: "relative inline-flex items-center px-4 py-2 text-sm font-semibold text-gray-900 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-offset-0" %>
                  <% end %>
                <% end %>
                
                <%= link_to_unless (params[:page].to_i + 1) * 25 >= @total_count, "Next", orders_path(request.params.merge(page: params[:page].to_i + 1)), class: "relative inline-flex items-center rounded-r-md px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-offset-0" %>
              </nav>
            </div>
          </div>
        </div>
      <% else %>
        <div class="text-center py-12">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900">No orders found</h3>
          <p class="mt-1 text-sm text-gray-500">
            <%= params[:query].present? || params[:status].present? || params[:payment_status].present? || params[:start_date].present? ? 
              "No orders match your current filters." : 
              "Get started by creating a new order." %>
          </p>
          <div class="mt-6">
            <%= link_to new_order_path, class: "inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" do %>
              <svg class="-ml-0.5 mr-1.5 h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z" />
              </svg>
              New Order
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>