<% content_for :title, "Order #{@order.order_number} | SupplyFlow" %>

<div class="container mx-auto px-4 py-8">
  <%# Page Header Section %>
  <div class="mb-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
      <div>
        <div class="flex items-center">
          <h1 class="text-2xl font-bold text-gray-900">Order #<%= @order.order_number %></h1>
          
          <%# Status Badge %>
          <div class="ml-4">
            <% case @order.status %>
            <% when "draft" %>
              <span class="inline-flex items-center rounded-md bg-gray-100 px-2.5 py-0.5 text-sm font-medium text-gray-800">Draft</span>
            <% when "pending" %>
              <span class="inline-flex items-center rounded-md bg-yellow-100 px-2.5 py-0.5 text-sm font-medium text-yellow-800">Pending</span>
            <% when "processing" %>
              <span class="inline-flex items-center rounded-md bg-blue-100 px-2.5 py-0.5 text-sm font-medium text-blue-800">Processing</span>
            <% when "shipped" %>
              <span class="inline-flex items-center rounded-md bg-indigo-100 px-2.5 py-0.5 text-sm font-medium text-indigo-800">Shipped</span>
            <% when "delivered" %>
              <span class="inline-flex items-center rounded-md bg-green-100 px-2.5 py-0.5 text-sm font-medium text-green-800">Delivered</span>
            <% when "canceled" %>
              <span class="inline-flex items-center rounded-md bg-red-100 px-2.5 py-0.5 text-sm font-medium text-red-800">Canceled</span>
            <% when "returned" %>
              <span class="inline-flex items-center rounded-md bg-purple-100 px-2.5 py-0.5 text-sm font-medium text-purple-800">Returned</span>
            <% end %>
            
            <%# Payment Status Badge %>
            <% case @order.payment_status %>
            <% when "unpaid" %>
              <span class="ml-2 inline-flex items-center rounded-md bg-gray-100 px-2.5 py-0.5 text-sm font-medium text-gray-800">Unpaid</span>
            <% when "partially_paid" %>
              <span class="ml-2 inline-flex items-center rounded-md bg-yellow-100 px-2.5 py-0.5 text-sm font-medium text-yellow-800">Partially Paid</span>
            <% when "paid" %>
              <span class="ml-2 inline-flex items-center rounded-md bg-green-100 px-2.5 py-0.5 text-sm font-medium text-green-800">Paid</span>
            <% when "refunded" %>
              <span class="ml-2 inline-flex items-center rounded-md bg-red-100 px-2.5 py-0.5 text-sm font-medium text-red-800">Refunded</span>
            <% end %>
          </div>
        </div>
        <p class="mt-1 text-sm text-gray-500">Created on <%= @order.created_at.strftime("%b %d, %Y at %I:%M %p") %> by <%= @order.user.name %></p>
      </div>
      <div class="mt-4 sm:mt-0 flex flex-wrap gap-2">
        <%= link_to orders_path, class: "inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" />
          </svg>
          Back to Orders
        <% end %>
        
        <%= link_to invoice_order_path(@order, format: :pdf), target: "_blank", class: "inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5zm-3 0h.008v.008H15V10.5z" />
          </svg>
          Print Invoice
        <% end %>
        
        <% if @order.status == 'draft' %>
          <%= link_to edit_order_path(@order), class: "inline-flex items-center rounded-md border border-transparent bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
            </svg>
            Edit Order
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <%# Main Content %>
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
    <%# Left Column - Order Details %>
    <div class="lg:col-span-2 space-y-6">
      <%# Order Summary %>
      <div class="bg-white shadow rounded-lg overflow-hidden">
        <div class="border-b border-gray-200 bg-gray-50 px-4 py-4 sm:px-6">
          <h3 class="text-base font-medium text-gray-900">Order Summary</h3>
        </div>
        <div class="px-4 py-5 sm:px-6">
          <div class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
            <div>
              <dt class="text-sm font-medium text-gray-500">Customer</dt>
              <dd class="mt-1 text-sm text-gray-900">
                <%= link_to @order.customer.name, customer_path(@order.customer), class: "text-indigo-600 hover:text-indigo-900" %>
              </dd>
            </div>
            
            <div>
              <dt class="text-sm font-medium text-gray-500">Order Date</dt>
              <dd class="mt-1 text-sm text-gray-900"><%= @order.order_date&.strftime("%b %d, %Y") || "Not set" %></dd>
            </div>
            
            <div>
              <dt class="text-sm font-medium text-gray-500">Shipping Method</dt>
              <dd class="mt-1 text-sm text-gray-900"><%= @order.shipping_method&.humanize || "Not specified" %></dd>
            </div>
            
            <div>
              <dt class="text-sm font-medium text-gray-500">Tracking Number</dt>
              <dd class="mt-1 text-sm text-gray-900"><%= @order.tracking_number.presence || "Not provided" %></dd>
            </div>
            
            <% if @order.shipping_date.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500">Shipping Date</dt>
              <dd class="mt-1 text-sm text-gray-900"><%= @order.shipping_date.strftime("%b %d, %Y") %></dd>
            </div>
            <% end %>
            
            <% if @order.delivery_date.present? %>
            <div>
              <dt class="text-sm font-medium text-gray-500">Delivery Date</dt>
              <dd class="mt-1 text-sm text-gray-900"><%= @order.delivery_date.strftime("%b %d, %Y") %></dd>
            </div>
            <% end %>
          </div>
        </div>
      </div>
      
      <%# Order Items %>
      <div class="bg-white shadow rounded-lg overflow-hidden">
        <div class="border-b border-gray-200 bg-gray-50 px-4 py-4 sm:px-6">
          <h3 class="text-base font-medium text-gray-900">Order Items</h3>
        </div>
        <div class="px-4 py-5 sm:px-6">
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-300">
              <thead>
                <tr>
                  <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900">Product</th>
                  <th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-gray-900">Quantity</th>
                  <th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-gray-900">Unit Price</th>
                  <th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-gray-900">Tax</th>
                  <th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-gray-900">Total</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 bg-white">
                <% @order_items.each do |item| %>
                  <tr>
                    <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900">
                      <%= link_to item.product.name, product_path(item.product), class: "text-indigo-600 hover:text-indigo-900" %>
                      <div class="text-xs text-gray-500">SKU: <%= item.product.sku %></div>
                    </td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-right text-gray-900">
                      <%= item.quantity %>
                      <% if item.shipped_quantity > 0 %>
                        <div class="text-xs text-gray-500">Shipped: <%= item.shipped_quantity %></div>
                      <% end %>
                    </td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-right text-gray-900">
                      <%= number_to_currency(item.unit_price, unit: "₵") %>
                    </td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-right text-gray-900">
                      <% if item.tax_rate.present? && item.tax_rate > 0 %>
                        <%= number_to_currency(item.tax_amount, unit: "₵") %>
                        <div class="text-xs text-gray-500">(<%= item.tax_rate %>%)</div>
                      <% else %>
                        -
                      <% end %>
                    </td>
                    <td class="whitespace-nowrap px-3 py-4 text-sm text-right font-medium text-gray-900">
                      <%= number_to_currency(item.total_amount, unit: "₵") %>
                    </td>
                  </tr>
                <% end %>
                
                <%# Order Totals %>
                <tr class="border-t border-gray-300">
                  <td colspan="4" class="py-4 pl-4 pr-3 text-sm font-medium text-gray-900 text-right">Subtotal:</td>
                  <td class="whitespace-nowrap px-3 py-4 text-sm text-right text-gray-900">
                    <%= number_to_currency(@order.subtotal, unit: "₵") %>
                  </td>
                </tr>
                <% if @order.tax_amount.present? && @order.tax_amount > 0 %>
                  <tr>
                    <td colspan="4" class="py-2 pl-4 pr-3 text-sm font-medium text-gray-900 text-right">Tax:</td>
                    <td class="whitespace-nowrap px-3 py-2 text-sm text-right text-gray-900">
                      <%= number_to_currency(@order.tax_amount, unit: "₵") %>
                    </td>
                  </tr>
                <% end %>
                <% if @order.shipping_amount.present? && @order.shipping_amount > 0 %>
                  <tr>
                    <td colspan="4" class="py-2 pl-4 pr-3 text-sm font-medium text-gray-900 text-right">Shipping:</td>
                    <td class="whitespace-nowrap px-3 py-2 text-sm text-right text-gray-900">
                      <%= number_to_currency(@order.shipping_amount, unit: "₵") %>
                    </td>
                  </tr>
                <% end %>
                <% if @order.discount_amount.present? && @order.discount_amount > 0 %>
                  <tr>
                    <td colspan="4" class="py-2 pl-4 pr-3 text-sm font-medium text-gray-900 text-right">Discount:</td>
                    <td class="whitespace-nowrap px-3 py-2 text-sm text-right text-gray-900">
                      -<%= number_to_currency(@order.discount_amount, unit: "₵") %>
                    </td>
                  </tr>
                <% end %>
                <tr class="border-t border-gray-300">
                  <td colspan="4" class="py-4 pl-4 pr-3 text-base font-bold text-gray-900 text-right">Grand Total:</td>
                  <td class="whitespace-nowrap px-3 py-4 text-base text-right font-bold text-gray-900">
                    <%= number_to_currency(@order.total_amount, unit: "₵") %>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      
      <%# Notes Section %>
      <% if @order.notes.present? %>
        <div class="bg-white shadow rounded-lg overflow-hidden">
          <div class="border-b border-gray-200 bg-gray-50 px-4 py-4 sm:px-6">
            <h3 class="text-base font-medium text-gray-900">Notes</h3>
          </div>
          <div class="px-4 py-5 sm:px-6">
            <p class="text-sm text-gray-900 whitespace-pre-line"><%= @order.notes %></p>
          </div>
        </div>
      <% end %>
    </div>
    
    <%# Right Column - Customer Info, Payments, Actions %>
    <div class="space-y-6">
      <%# Customer Information %>
      <div class="bg-white shadow rounded-lg overflow-hidden">
        <div class="border-b border-gray-200 bg-gray-50 px-4 py-4 sm:px-6">
          <h3 class="text-base font-medium text-gray-900">Customer Information</h3>
        </div>
        <div class="px-4 py-5 sm:px-6">
          <h4 class="text-sm font-medium text-gray-900"><%= @order.customer.name %></h4>
          <p class="mt-1 text-sm text-gray-500">
            <% if @order.customer.email.present? %>
              <%= mail_to @order.customer.email, class: "text-indigo-600 hover:text-indigo-900" %><br>
            <% end %>
            <% if @order.customer.phone.present? %>
              <%= @order.customer.phone %><br>
            <% end %>
            <% if @order.customer.contact_person.present? %>
              Contact: <%= @order.customer.contact_person %>
            <% end %>
          </p>
          
          <div class="mt-4 border-t border-gray-200 pt-4">
            <div class="grid grid-cols-1 gap-y-4">
              <div>
                <h4 class="text-sm font-medium text-gray-900">Shipping Address</h4>
                <p class="mt-1 text-sm text-gray-500 whitespace-pre-line"><%= @order.shipping_address.presence || "Not provided" %></p>
              </div>
              
              <div>
                <h4 class="text-sm font-medium text-gray-900">Billing Address</h4>
                <p class="mt-1 text-sm text-gray-500 whitespace-pre-line"><%= @order.billing_address.presence || "Not provided" %></p>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <%# Payments %>
      <div class="bg-white shadow rounded-lg overflow-hidden">
        <div class="border-b border-gray-200 bg-gray-50 px-4 py-4 sm:px-6 flex justify-between items-center">
          <h3 class="text-base font-medium text-gray-900">Payment Information</h3>
        </div>
        <div class="px-4 py-5 sm:px-6">
          <div class="mb-4">
            <div class="flex justify-between items-center text-sm">
              <span class="text-gray-500">Total Amount:</span>
              <span class="font-medium text-gray-900"><%= number_to_currency(@order.total_amount, unit: "₵") %></span>
            </div>
            <div class="flex justify-between items-center text-sm mt-1">
              <span class="text-gray-500">Paid Amount:</span>
              <span class="font-medium text-gray-900"><%= number_to_currency(@order.total_paid, unit: "₵") %></span>
            </div>
            <div class="flex justify-between items-center text-sm mt-1">
              <span class="text-gray-500">Balance Due:</span>
              <span class="font-medium <%= @order.balance_due > 0 ? 'text-red-600' : 'text-green-600' %>">
                <%= number_to_currency(@order.balance_due, unit: "₵") %>
              </span>
            </div>
          </div>
          
          <% if @payments.present? %>
            <div class="mt-4 border-t border-gray-200 pt-4">
              <h4 class="text-sm font-medium text-gray-900 mb-2">Payment History</h4>
              <ul class="divide-y divide-gray-200">
                <% @payments.each do |payment| %>
                  <li class="py-2">
                    <div class="flex justify-between text-sm">
                      <span class="text-gray-500">
                        <%= payment.payment_date.strftime("%b %d, %Y") %> - 
                        <%= payment.payment_method.humanize %>
                      </span>
                      <span class="font-medium text-gray-900"><%= number_to_currency(payment.amount, unit: "₵") %></span>
                    </div>
                    <% if payment.reference_number.present? %>
                      <div class="text-xs text-gray-500">Ref: <%= payment.reference_number %></div>
                    <% end %>
                  </li>
                <% end %>
              </ul>
            </div>
          <% else %>
            <div class="mt-4 border-t border-gray-200 pt-4 text-center">
              <p class="text-sm text-gray-500">No payments recorded yet.</p>
            </div>
          <% end %>
        </div>
      </div>
      
      <%# Order Actions %>
      <div class="bg-white shadow rounded-lg overflow-hidden">
        <div class="border-b border-gray-200 bg-gray-50 px-4 py-4 sm:px-6">
          <h3 class="text-base font-medium text-gray-900">Order Actions</h3>
        </div>
        <div class="px-4 py-5 sm:px-6">
          <div class="space-y-2">
            <% if @order.status == 'draft' %>
              <%= button_to edit_order_path(@order), method: :get, class: "w-full inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                </svg>
                Edit Order
              <% end %>
            <% end %>
            
            <% if @order.can_be_canceled? %>
              <%= button_to cancel_order_path(@order), method: :post, data: { confirm: "Are you sure you want to cancel this order?" }, class: "w-full inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-red-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2" do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
                Cancel Order
              <% end %>
            <% end %>
            
            <% if @order.status == 'pending' %>
              <%= button_to ship_order_path(@order), method: :post, class: "w-full inline-flex items-center justify-center rounded-md border border-transparent bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
                </svg>
                Mark as Shipped
              <% end %>
            <% end %>
            
            <% if @order.status == 'shipped' %>
              <%= button_to deliver_order_path(@order), method: :post, class: "w-full inline-flex items-center justify-center rounded-md border border-transparent bg-green-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2" do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
                </svg>
                Mark as Delivered
              <% end %>
            <% end %>
            
            <% if @order.can_be_returned? %>
              <%= button_to return_order_path(@order), method: :post, data: { confirm: "Are you sure you want to process a return for this order?" }, class: "w-full inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" />
                </svg>
                Process Return
              <% end %>
            <% end %>
            
            <% if @order.status == 'draft' %>
              <%= button_to order_path(@order), method: :delete, data: { confirm: "Are you sure you want to delete this order? This action cannot be undone." }, class: "w-full inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-red-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2" do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                </svg>
                Delete Order
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>