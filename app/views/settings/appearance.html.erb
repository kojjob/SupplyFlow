<% content_for :title, "Appearance Settings" %>

<div class="space-y-6">
  <!-- Page Header -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="bg-gradient-to-r from-indigo-600 to-purple-600 px-5 py-4">
      <h1 class="text-xl font-semibold text-white flex items-center">
        <i class="fas fa-paint-brush mr-2"></i> Appearance Settings
      </h1>
    </div>
    
    <div class="p-6">
      <p class="text-gray-600 dark:text-gray-300">
        Customize the look and feel of the application to suit your preferences.
      </p>
    </div>
  </div>
  
  <!-- Theme Settings -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="px-5 py-4 bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
      <h2 class="text-lg font-medium text-gray-900 dark:text-white">Theme</h2>
    </div>
    
    <div class="p-6">
      <p class="text-gray-600 dark:text-gray-300 mb-6">
        Choose between light and dark mode, or let the system decide based on your device settings.
      </p>
      
      <%= form_with model: @user, url: update_appearance_path, method: :patch, data: { controller: "theme" } do |f| %>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="relative">
            <label class="block">
              <%= f.radio_button "ui_preferences[theme]", "light", 
                               checked: @user.theme == "light", 
                               class: "sr-only peer",
                               data: { action: "change->theme#changeTheme", theme_target: "lightRadio" } %>
              <div class="h-40 bg-white border-2 rounded-lg shadow-sm peer-checked:border-indigo-500 peer-checked:ring-2 peer-checked:ring-indigo-500 overflow-hidden cursor-pointer">
                <div class="h-8 bg-gray-100 border-b flex items-center px-3">
                  <div class="w-3 h-3 rounded-full bg-red-500 mr-2"></div>
                  <div class="w-3 h-3 rounded-full bg-yellow-500 mr-2"></div>
                  <div class="w-3 h-3 rounded-full bg-green-500"></div>
                </div>
                <div class="p-3">
                  <div class="h-4 bg-gray-200 rounded mb-2"></div>
                  <div class="h-4 bg-gray-200 rounded mb-2 w-3/4"></div>
                  <div class="h-4 bg-gray-200 rounded w-1/2"></div>
                </div>
              </div>
              <div class="mt-2 text-center">
                <span class="text-sm font-medium text-gray-900 dark:text-white">Light Mode</span>
              </div>
            </label>
          </div>
          
          <div class="relative">
            <label class="block">
              <%= f.radio_button "ui_preferences[theme]", "dark", 
                               checked: @user.theme == "dark", 
                               class: "sr-only peer",
                               data: { action: "change->theme#changeTheme", theme_target: "darkRadio" } %>
              <div class="h-40 bg-gray-900 border-2 border-gray-700 rounded-lg shadow-sm peer-checked:border-indigo-500 peer-checked:ring-2 peer-checked:ring-indigo-500 overflow-hidden cursor-pointer">
                <div class="h-8 bg-gray-800 border-b border-gray-700 flex items-center px-3">
                  <div class="w-3 h-3 rounded-full bg-red-500 mr-2"></div>
                  <div class="w-3 h-3 rounded-full bg-yellow-500 mr-2"></div>
                  <div class="w-3 h-3 rounded-full bg-green-500"></div>
                </div>
                <div class="p-3">
                  <div class="h-4 bg-gray-700 rounded mb-2"></div>
                  <div class="h-4 bg-gray-700 rounded mb-2 w-3/4"></div>
                  <div class="h-4 bg-gray-700 rounded w-1/2"></div>
                </div>
              </div>
              <div class="mt-2 text-center">
                <span class="text-sm font-medium text-gray-900 dark:text-white">Dark Mode</span>
              </div>
            </label>
          </div>
          
          <div class="relative">
            <label class="block">
              <%= f.radio_button "ui_preferences[theme]", "system", 
                               checked: @user.theme == "system", 
                               class: "sr-only peer",
                               data: { action: "change->theme#changeTheme", theme_target: "systemRadio" } %>
              <div class="h-40 bg-gradient-to-r from-white to-gray-900 border-2 rounded-lg shadow-sm peer-checked:border-indigo-500 peer-checked:ring-2 peer-checked:ring-indigo-500 overflow-hidden cursor-pointer">
                <div class="h-8 bg-gradient-to-r from-gray-100 to-gray-800 border-b flex items-center px-3">
                  <div class="w-3 h-3 rounded-full bg-red-500 mr-2"></div>
                  <div class="w-3 h-3 rounded-full bg-yellow-500 mr-2"></div>
                  <div class="w-3 h-3 rounded-full bg-green-500"></div>
                </div>
                <div class="p-3 flex">
                  <div class="w-1/2 pr-1">
                    <div class="h-4 bg-gray-200 rounded mb-2"></div>
                    <div class="h-4 bg-gray-200 rounded mb-2 w-3/4"></div>
                    <div class="h-4 bg-gray-200 rounded w-1/2"></div>
                  </div>
                  <div class="w-1/2 pl-1">
                    <div class="h-4 bg-gray-700 rounded mb-2"></div>
                    <div class="h-4 bg-gray-700 rounded mb-2 w-3/4"></div>
                    <div class="h-4 bg-gray-700 rounded w-1/2"></div>
                  </div>
                </div>
              </div>
              <div class="mt-2 text-center">
                <span class="text-sm font-medium text-gray-900 dark:text-white">System Preference</span>
              </div>
            </label>
          </div>
        </div>
        
        <div class="mt-6 flex justify-end">
          <%= f.submit "Save Theme", class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg shadow-sm transition-colors duration-200" %>
        </div>
      <% end %>
    </div>
  </div>
  
  <!-- Color Scheme -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="px-5 py-4 bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
      <h2 class="text-lg font-medium text-gray-900 dark:text-white">Color Scheme</h2>
    </div>
    
    <div class="p-6">
      <p class="text-gray-600 dark:text-gray-300 mb-6">
        Choose your preferred accent color for buttons, links, and other UI elements.
      </p>
      
      <%= form_with model: @user, url: update_appearance_path, method: :patch do |f| %>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="relative">
            <label class="block">
              <%= f.radio_button "ui_preferences[color_scheme]", "blue", 
                               checked: @user.ui_preferences&.dig("color_scheme") == "blue", 
                               class: "sr-only peer" %>
              <div class="h-16 bg-blue-600 rounded-lg shadow-sm peer-checked:ring-2 peer-checked:ring-offset-2 peer-checked:ring-blue-500 cursor-pointer"></div>
              <div class="mt-2 text-center">
                <span class="text-sm font-medium text-gray-900 dark:text-white">Blue</span>
              </div>
            </label>
          </div>
          
          <div class="relative">
            <label class="block">
              <%= f.radio_button "ui_preferences[color_scheme]", "indigo", 
                               checked: @user.ui_preferences&.dig("color_scheme") == "indigo", 
                               class: "sr-only peer" %>
              <div class="h-16 bg-indigo-600 rounded-lg shadow-sm peer-checked:ring-2 peer-checked:ring-offset-2 peer-checked:ring-indigo-500 cursor-pointer"></div>
              <div class="mt-2 text-center">
                <span class="text-sm font-medium text-gray-900 dark:text-white">Indigo</span>
              </div>
            </label>
          </div>
          
          <div class="relative">
            <label class="block">
              <%= f.radio_button "ui_preferences[color_scheme]", "purple", 
                               checked: @user.ui_preferences&.dig("color_scheme") == "purple", 
                               class: "sr-only peer" %>
              <div class="h-16 bg-purple-600 rounded-lg shadow-sm peer-checked:ring-2 peer-checked:ring-offset-2 peer-checked:ring-purple-500 cursor-pointer"></div>
              <div class="mt-2 text-center">
                <span class="text-sm font-medium text-gray-900 dark:text-white">Purple</span>
              </div>
            </label>
          </div>
          
          <div class="relative">
            <label class="block">
              <%= f.radio_button "ui_preferences[color_scheme]", "green", 
                               checked: @user.ui_preferences&.dig("color_scheme") == "green", 
                               class: "sr-only peer" %>
              <div class="h-16 bg-green-600 rounded-lg shadow-sm peer-checked:ring-2 peer-checked:ring-offset-2 peer-checked:ring-green-500 cursor-pointer"></div>
              <div class="mt-2 text-center">
                <span class="text-sm font-medium text-gray-900 dark:text-white">Green</span>
              </div>
            </label>
          </div>
          
          <div class="relative">
            <label class="block">
              <%= f.radio_button "ui_preferences[color_scheme]", "red", 
                               checked: @user.ui_preferences&.dig("color_scheme") == "red", 
                               class: "sr-only peer" %>
              <div class="h-16 bg-red-600 rounded-lg shadow-sm peer-checked:ring-2 peer-checked:ring-offset-2 peer-checked:ring-red-500 cursor-pointer"></div>
              <div class="mt-2 text-center">
                <span class="text-sm font-medium text-gray-900 dark:text-white">Red</span>
              </div>
            </label>
          </div>
          
          <div class="relative">
            <label class="block">
              <%= f.radio_button "ui_preferences[color_scheme]", "orange", 
                               checked: @user.ui_preferences&.dig("color_scheme") == "orange", 
                               class: "sr-only peer" %>
              <div class="h-16 bg-orange-600 rounded-lg shadow-sm peer-checked:ring-2 peer-checked:ring-offset-2 peer-checked:ring-orange-500 cursor-pointer"></div>
              <div class="mt-2 text-center">
                <span class="text-sm font-medium text-gray-900 dark:text-white">Orange</span>
              </div>
            </label>
          </div>
          
          <div class="relative">
            <label class="block">
              <%= f.radio_button "ui_preferences[color_scheme]", "teal", 
                               checked: @user.ui_preferences&.dig("color_scheme") == "teal", 
                               class: "sr-only peer" %>
              <div class="h-16 bg-teal-600 rounded-lg shadow-sm peer-checked:ring-2 peer-checked:ring-offset-2 peer-checked:ring-teal-500 cursor-pointer"></div>
              <div class="mt-2 text-center">
                <span class="text-sm font-medium text-gray-900 dark:text-white">Teal</span>
              </div>
            </label>
          </div>
          
          <div class="relative">
            <label class="block">
              <%= f.radio_button "ui_preferences[color_scheme]", "pink", 
                               checked: @user.ui_preferences&.dig("color_scheme") == "pink", 
                               class: "sr-only peer" %>
              <div class="h-16 bg-pink-600 rounded-lg shadow-sm peer-checked:ring-2 peer-checked:ring-offset-2 peer-checked:ring-pink-500 cursor-pointer"></div>
              <div class="mt-2 text-center">
                <span class="text-sm font-medium text-gray-900 dark:text-white">Pink</span>
              </div>
            </label>
          </div>
        </div>
        
        <div class="mt-6 flex justify-end">
          <%= f.submit "Save Color Scheme", class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg shadow-sm transition-colors duration-200" %>
        </div>
      <% end %>
    </div>
  </div>
  
  <!-- Layout Density -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="px-5 py-4 bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
      <h2 class="text-lg font-medium text-gray-900 dark:text-white">Layout Density</h2>
    </div>
    
    <div class="p-6">
      <p class="text-gray-600 dark:text-gray-300 mb-6">
        Choose how compact or spacious you want the interface to be.
      </p>
      
      <%= form_with model: @user, url: update_appearance_path, method: :patch do |f| %>
        <div class="space-y-4">
          <div class="flex items-center">
            <%= f.radio_button "ui_preferences[layout_density]", "compact", 
                             checked: @user.ui_preferences&.dig("layout_density") == "compact", 
                             class: "h-5 w-5 text-indigo-600 border-gray-300 focus:ring-indigo-500" %>
            <div class="ml-3">
              <label for="user_ui_preferences_layout_density_compact" class="text-sm font-medium text-gray-900 dark:text-white">Compact</label>
              <p class="text-xs text-gray-500 dark:text-gray-400">Fit more content on the screen with less padding</p>
            </div>
          </div>
          
          <div class="flex items-center">
            <%= f.radio_button "ui_preferences[layout_density]", "comfortable", 
                             checked: @user.ui_preferences&.dig("layout_density") == "comfortable", 
                             class: "h-5 w-5 text-indigo-600 border-gray-300 focus:ring-indigo-500" %>
            <div class="ml-3">
              <label for="user_ui_preferences_layout_density_comfortable" class="text-sm font-medium text-gray-900 dark:text-white">Comfortable</label>
              <p class="text-xs text-gray-500 dark:text-gray-400">Balanced spacing for most screens</p>
            </div>
          </div>
          
          <div class="flex items-center">
            <%= f.radio_button "ui_preferences[layout_density]", "spacious", 
                             checked: @user.ui_preferences&.dig("layout_density") == "spacious", 
                             class: "h-5 w-5 text-indigo-600 border-gray-300 focus:ring-indigo-500" %>
            <div class="ml-3">
              <label for="user_ui_preferences_layout_density_spacious" class="text-sm font-medium text-gray-900 dark:text-white">Spacious</label>
              <p class="text-xs text-gray-500 dark:text-gray-400">More breathing room between elements</p>
            </div>
          </div>
        </div>
        
        <div class="mt-6 flex justify-end">
          <%= f.submit "Save Layout Density", class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg shadow-sm transition-colors duration-200" %>
        </div>
      <% end %>
    </div>
  </div>
  
  <!-- Font Size -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="px-5 py-4 bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
      <h2 class="text-lg font-medium text-gray-900 dark:text-white">Font Size</h2>
    </div>
    
    <div class="p-6">
      <p class="text-gray-600 dark:text-gray-300 mb-6">
        Adjust the text size to improve readability.
      </p>
      
      <%= form_with model: @user, url: update_appearance_path, method: :patch do |f| %>
        <div class="space-y-4">
          <div class="flex items-center">
            <%= f.radio_button "ui_preferences[font_size]", "small", 
                             checked: @user.ui_preferences&.dig("font_size") == "small", 
                             class: "h-5 w-5 text-indigo-600 border-gray-300 focus:ring-indigo-500" %>
            <div class="ml-3">
              <label for="user_ui_preferences_font_size_small" class="text-sm font-medium text-gray-900 dark:text-white">Small</label>
              <p class="text-xs text-gray-500 dark:text-gray-400">Smaller text size</p>
            </div>
          </div>
          
          <div class="flex items-center">
            <%= f.radio_button "ui_preferences[font_size]", "medium", 
                             checked: @user.ui_preferences&.dig("font_size") == "medium", 
                             class: "h-5 w-5 text-indigo-600 border-gray-300 focus:ring-indigo-500" %>
            <div class="ml-3">
              <label for="user_ui_preferences_font_size_medium" class="text-sm font-medium text-gray-900 dark:text-white">Medium</label>
              <p class="text-xs text-gray-500 dark:text-gray-400">Default text size</p>
            </div>
          </div>
          
          <div class="flex items-center">
            <%= f.radio_button "ui_preferences[font_size]", "large", 
                             checked: @user.ui_preferences&.dig("font_size") == "large", 
                             class: "h-5 w-5 text-indigo-600 border-gray-300 focus:ring-indigo-500" %>
            <div class="ml-3">
              <label for="user_ui_preferences_font_size_large" class="text-sm font-medium text-gray-900 dark:text-white">Large</label>
              <p class="text-xs text-gray-500 dark:text-gray-400">Larger text size for better readability</p>
            </div>
          </div>
        </div>
        
        <div class="mt-6 flex justify-end">
          <%= f.submit "Save Font Size", class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg shadow-sm transition-colors duration-200" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
