<% content_for :title, "Organization Settings" %>

<div class="space-y-6">
  <!-- Page Header -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="bg-gradient-to-r from-indigo-600 to-purple-600 px-5 py-4">
      <h1 class="text-xl font-semibold text-white flex items-center">
        <i class="fas fa-building mr-2"></i> Organisation Settings
      </h1>
    </div>
    
    <div class="p-6">
      <p class="text-gray-600 dark:text-gray-300">
        Manage your organisation's profile, settings, and preferences.
      </p>
    </div>
  </div>
  
  <!-- Organization Profile -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="px-5 py-4 bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
      <h2 class="text-lg font-medium text-gray-900 dark:text-white">Organisation Profile</h2>
    </div>
    
    <div class="p-6">
      <%= form_with model: @organization, url: update_organization_path, method: :patch, class: "space-y-6" do |f| %>
        <div class="flex flex-col md:flex-row items-center md:items-start gap-6 mb-6">
          <!-- Organization Logo -->
          <div class="flex-shrink-0">
            <div class="relative group">
              <div class="w-32 h-32 rounded-lg bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 overflow-hidden border-4 border-white dark:border-gray-700 shadow-lg">
                <% if @organization.logo.attached? %>
                  <%= image_tag @organization.logo.variant(resize_to_limit: [128, 128]), class: "w-full h-full object-cover" %>
                <% else %>
                  <span class="text-5xl"><%= @organization.name.first.upcase %></span>
                <% end %>
              </div>
              
              <label for="organization_logo" class="absolute inset-0 bg-black bg-opacity-50 rounded-lg flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200 cursor-pointer">
                <span class="text-white text-sm font-medium">Change Logo</span>
              </label>
            </div>
            
            <div class="mt-2">
              <%= f.label :logo, "Upload Logo", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
              <%= f.file_field :logo, id: "organization_logo", accept: "image/png,image/jpeg,image/jpg,image/gif", class: "w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 dark:file:bg-indigo-900/30 dark:file:text-indigo-300 hover:file:bg-indigo-100 dark:hover:file:bg-indigo-900/40" %>
            </div>
          </div>
          
          <!-- Organization Info -->
          <div class="flex-grow">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <%= f.label :name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
                <%= f.text_field :name, class: "py-3 px-4 w-full rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50" %>
              </div>
              
              <div>
                <%= f.label :email, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
                <%= f.email_field :email, class: "py-3 px-4 w-full rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50" %>
              </div>
              
              <div>
                <%= f.label :phone, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
                <%= f.telephone_field :phone, class: "py-3 px-4 w-full rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50" %>
              </div>
              
              <div>
                <%= f.label :website, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
                <%= f.url_field :website, class: "py-3 px-4 w-full rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50" %>
              </div>
            </div>
          </div>
        </div>
        
        <div>
          <%= f.label :address, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <%= f.text_area :address, rows: 3, class: "py-3 px-4 w-full rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50" %>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <%= f.label :city, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.text_field :city, class: "py-3 px-4 w-full rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50" %>
          </div>
          
          <div>
            <%= f.label :state, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.text_field :state, class: "py-3 px-4 w-full rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50" %>
          </div>
          
          <div>
            <%= f.label :postal_code, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.text_field :postal_code, class: "py-3 px-4 w-full rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50" %>
          </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= f.label :country, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.text_field :country, class: "py-3 px-4 w-full rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50" %>
          </div>
          
          <div>
            <%= f.label :tax_id, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.text_field :tax_id, class: "py-3 px-4 w-full rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50" %>
          </div>
        </div>
        
        <div class="flex justify-end">
          <%= f.submit "Save Organization Profile", class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg shadow-sm transition-colors duration-200" %>
        </div>
      <% end %>
    </div>
  </div>
  
  <!-- Business Settings -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="px-5 py-4 bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
      <h2 class="text-lg font-medium text-gray-900 dark:text-white">Business Settings</h2>
    </div>
    
    <div class="p-6">
      <%= form_with model: @organization, url: update_organization_path, method: :patch do |f| %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= f.fields_for :settings do |settings_form| %>
              <%= settings_form.label :currency, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
              <%= settings_form.select :currency, 
                                     [
                                       ["Ghana Cedi (GHS)", "GHS"],
                                       ["US Dollar (USD)", "USD"],
                                       ["Euro (EUR)", "EUR"],
                                       ["British Pound (GBP)", "GBP"],
                                       ["Nigerian Naira (NGN)", "NGN"]
                                     ],
                                     { selected: @organization.currency },
                                     { class: "py-3 px-4 w-full rounded-lg borderborder-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50" } %>
            <% end %>
          </div>
          
          <div>
            <%= f.label :fiscal_year_start, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
            <%= f.select :fiscal_year_start, 
                       [
                         ["January", "1"],
                         ["February", "2"],
                         ["March", "3"],
                         ["April", "4"],
                         ["May", "5"],
                         ["June", "6"],
                         ["July", "7"],
                         ["August", "8"],
                         ["September", "9"],
                         ["October", "10"],
                         ["November", "11"],
                         ["December", "12"]
                       ],
                       { selected: @organization.fiscal_year_start || "1" },
                       { class: "py-3 px-4 w-full rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50" } %>
          </div>
        </div>
        
        <div class="mt-6 flex justify-end">
          <%= f.submit "Save Business Settings", class: "px-4 py-3 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg shadow-sm transition-colors duration-200" %>
        </div>
      <% end %>
    </div>
  </div>
  
  <!-- Subscription & Billing -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="px-5 py-4 bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
      <h2 class="text-lg font-medium text-gray-900 dark:text-white">Subscription & Billing</h2>
    </div>
    
    <div class="p-6">
      <div class="bg-green-50 dark:bg-green-900/20 rounded-lg p-4 border border-green-100 dark:border-green-800 mb-6">
        <div class="flex">
          <div class="flex-shrink-0">
            <i class="fas fa-check-circle text-green-600 dark:text-green-400"></i>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-green-800 dark:text-green-300">Free Plan</h3>
            <p class="mt-2 text-sm text-green-700 dark:text-green-300">
              You are currently on the Free Plan. Upgrade to access more features and higher usage limits.
            </p>
          </div>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 shadow-sm overflow-hidden">
          <div class="p-6">
            <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">Free Plan</h3>
            <p class="text-gray-500 dark:text-gray-400 mb-4">For small businesses just getting started</p>
            <p class="text-3xl font-bold text-gray-900 dark:text-white mb-4">$0<span class="text-lg font-normal text-gray-500 dark:text-gray-400">/month</span></p>
            
            <ul class="space-y-3 mb-6">
              <li class="flex items-center">
                <i class="fas fa-check text-green-500 mr-2"></i>
                <span class="text-gray-700 dark:text-gray-300">Up to 100 products</span>
              </li>
              <li class="flex items-center">
                <i class="fas fa-check text-green-500 mr-2"></i>
                <span class="text-gray-700 dark:text-gray-300">Up to 3 users</span>
              </li>
              <li class="flex items-center">
                <i class="fas fa-check text-green-500 mr-2"></i>
                <span class="text-gray-700 dark:text-gray-300">Basic reporting</span>
              </li>
            </ul>
            
            <button disabled class="w-full px-4 py-2 bg-gray-300 dark:bg-gray-600 text-gray-700 dark:text-gray-300 rounded-lg shadow-sm cursor-not-allowed">
              Current Plan
            </button>
          </div>
        </div>
        
        <div class="bg-white dark:bg-gray-800 rounded-lg border border-indigo-200 dark:border-indigo-700 shadow-sm overflow-hidden relative">
          <div class="absolute top-0 right-0 bg-indigo-500 text-white text-xs font-bold px-3 py-1 rounded-bl-lg">
            POPULAR
          </div>
          
          <div class="p-6">
            <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">Pro Plan</h3>
            <p class="text-gray-500 dark:text-gray-400 mb-4">For growing businesses with more needs</p>
            <p class="text-3xl font-bold text-gray-900 dark:text-white mb-4">$49<span class="text-lg font-normal text-gray-500 dark:text-gray-400">/month</span></p>
            
            <ul class="space-y-3 mb-6">
              <li class="flex items-center">
                <i class="fas fa-check text-green-500 mr-2"></i>
                <span class="text-gray-700 dark:text-gray-300">Unlimited products</span>
              </li>
              <li class="flex items-center">
                <i class="fas fa-check text-green-500 mr-2"></i>
                <span class="text-gray-700 dark:text-gray-300">Up to 10 users</span>
              </li>
              <li class="flex items-center">
                <i class="fas fa-check text-green-500 mr-2"></i>
                <span class="text-gray-700 dark:text-gray-300">Advanced reporting</span>
              </li>
              <li class="flex items-center">
                <i class="fas fa-check text-green-500 mr-2"></i>
                <span class="text-gray-700 dark:text-gray-300">API access</span>
              </li>
            </ul>
            
            <button class="w-full px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg shadow-sm transition-colors duration-200">
              Upgrade to Pro
            </button>
          </div>
        </div>
        
        <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 shadow-sm overflow-hidden">
          <div class="p-6">
            <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">Enterprise Plan</h3>
            <p class="text-gray-500 dark:text-gray-400 mb-4">For large organizations with custom needs</p>
            <p class="text-3xl font-bold text-gray-900 dark:text-white mb-4">$199<span class="text-lg font-normal text-gray-500 dark:text-gray-400">/month</span></p>
            
            <ul class="space-y-3 mb-6">
              <li class="flex items-center">
                <i class="fas fa-check text-green-500 mr-2"></i>
                <span class="text-gray-700 dark:text-gray-300">Unlimited everything</span>
              </li>
              <li class="flex items-center">
                <i class="fas fa-check text-green-500 mr-2"></i>
                <span class="text-gray-700 dark:text-gray-300">Priority support</span>
              </li>
              <li class="flex items-center">
                <i class="fas fa-check text-green-500 mr-2"></i>
                <span class="text-gray-700 dark:text-gray-300">Custom integrations</span>
              </li>
              <li class="flex items-center">
                <i class="fas fa-check text-green-500 mr-2"></i>
                <span class="text-gray-700 dark:text-gray-300">Dedicated account manager</span>
              </li>
            </ul>
            
            <button class="w-full px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg shadow-sm transition-colors duration-200">
              Contact Sales
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
