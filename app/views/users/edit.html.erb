<% content_for :title, "Edit #{@user.name}" %>

<div class="space-y-6">
  <!-- Page Header -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="bg-gradient-to-r from-indigo-600 to-purple-600 px-5 py-4 flex justify-between items-center">
      <h1 class="text-xl font-semibold text-white flex items-center">
        <i class="fas fa-user-edit mr-2"></i> Edit Team Member
      </h1>
      
      <%= link_to users_path, class: "inline-flex items-center px-4 py-2 bg-white/20 hover:bg-white/30 text-white rounded-lg transition-colors duration-200" do %>
        <i class="fas fa-arrow-left mr-2"></i> Back to Team Members
      <% end %>
    </div>
    
    <div class="p-6">
      <p class="text-gray-600 dark:text-gray-300">
        Update team member information and permissions.
      </p>
    </div>
  </div>
  
  <!-- User Form -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="px-5 py-4 bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
      <h2 class="text-lg font-medium text-gray-900 dark:text-white">User Information</h2>
    </div>
    
    <div class="p-6">
      <%= form_with(model: @user, local: true, class: "space-y-6") do |form| %>
        <% if @user.errors.any? %>
          <div class="bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500 p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <i class="fas fa-exclamation-circle text-red-500 dark:text-red-400"></i>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-red-800 dark:text-red-300">
                  <%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:
                </h3>
                <div class="mt-2 text-sm text-red-700 dark:text-red-200">
                  <ul class="list-disc pl-5 space-y-1">
                    <% @user.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        <% end %>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= form.label :name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <%= form.text_field :name, class: "py-2 px-3 mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 dark:bg-gray-700 dark:text-white" %>
          </div>
          
          <div>
            <%= form.label :email, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <%= form.email_field :email, class: "py-2 px-3 mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 dark:bg-gray-700 dark:text-white" %>
          </div>
          
          <div>
            <%= form.label :phone_number, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <%= form.telephone_field :phone_number, class: "py-2 px-3 mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 dark:bg-gray-700 dark:text-white" %>
          </div>
          
          <div>
            <%= form.label :role, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <%= form.select :role, [
              ["Admin", "admin"],
              ["Manager", "manager"],
              ["Staff", "staff"],
              ["Viewer", "viewer"]
            ], {}, { 
              class: "py-2 px-3 mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 dark:bg-gray-700 dark:text-white",
              disabled: !policy(@user).change_role?
            } %>
          </div>
        </div>
        
        <div class="flex items-center">
          <%= form.check_box :active, class: "py-2 px-3 h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 dark:border-gray-600 rounded", disabled: !policy(@user).activate? && !policy(@user).deactivate? %>
          <%= form.label :active, "Active", class: "ml-2 block text-sm text-gray-700 dark:text-gray-300" %>
        </div>
        
        <div class="flex justify-end">
          <%= link_to "Cancel", users_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 shadow-sm text-sm font-medium rounded-md text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 mr-3" %>
          
          <%= form.submit "Update User", class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
        </div>
      <% end %>
    </div>
  </div>
  
  <% if policy(@user).reset_password? %>
  <!-- Reset Password -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="px-5 py-4 bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
      <h2 class="text-lg font-medium text-gray-900 dark:text-white">Reset Password</h2>
    </div>
    
    <div class="p-6">
      <p class="text-gray-600 dark:text-gray-300 mb-4">
        Reset the user's password. A new random password will be generated and displayed to you.
      </p>
      
      <%= button_to reset_password_user_path(@user), method: :post, data: { confirm: "Are you sure you want to reset the password for #{@user.name}?" }, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-yellow-600 hover:bg-yellow-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-yellow-500" do %>
        <i class="fas fa-key mr-2"></i> Reset Password
      <% end %>
    </div>
  </div>
  <% end %>
  
  <% if policy(@user).destroy? %>
  <!-- Danger Zone -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-red-200 dark:border-red-900">
    <div class="px-5 py-4 bg-red-50 dark:bg-red-900/20 border-b border-red-200 dark:border-red-900">
      <h2 class="text-lg font-medium text-red-800 dark:text-red-300">Danger Zone</h2>
    </div>
    
    <div class="p-6">
      <p class="text-gray-600 dark:text-gray-300 mb-4">
        Permanently delete this user and all associated data. This action cannot be undone.
      </p>
      
      <%= button_to user_path(@user), method: :delete, data: { confirm: "Are you sure you want to delete #{@user.name}? This action cannot be undone." }, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" do %>
        <i class="fas fa-trash-alt mr-2"></i> Delete User
      <% end %>
    </div>
  </div>
  <% end %>
</div>
