<% content_for :title, @user.name %>

<div class="space-y-6">
  <!-- Page Header -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="bg-gradient-to-r from-indigo-600 to-purple-600 px-5 py-4 flex justify-between items-center">
      <h1 class="text-xl font-semibold text-white flex items-center">
        <i class="fas fa-user mr-2"></i> Team Member Details
      </h1>
      
      <%= link_to users_path, class: "inline-flex items-center px-4 py-2 bg-white/20 hover:bg-white/30 text-white rounded-lg transition-colors duration-200" do %>
        <i class="fas fa-arrow-left mr-2"></i> Back to Team Members
      <% end %>
    </div>
  </div>
  
  <!-- User Profile -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- User Information -->
    <div class="lg:col-span-2">
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
        <div class="px-5 py-4 bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
          <h2 class="text-lg font-medium text-gray-900 dark:text-white">User Information</h2>
        </div>
        
        <div class="border-t border-gray-200 dark:border-gray-700 px-4 py-5 sm:p-0">
          <dl class="sm:divide-y sm:divide-gray-200 sm:dark:divide-gray-700">
            <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Full name</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white sm:mt-0 sm:col-span-2"><%= @user.name %></dd>
            </div>
            <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Email address</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white sm:mt-0 sm:col-span-2">
                <a href="mailto:<%= @user.email %>" class="text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300"><%= @user.email %></a>
              </dd>
            </div>
            <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Phone number</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white sm:mt-0 sm:col-span-2">
                <% if @user.phone_number.present? %>
                  <a href="tel:<%= @user.phone_number %>" class="text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300"><%= @user.phone_number %></a>
                <% else %>
                  —
                <% end %>
              </dd>
            </div>
            <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Role</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white sm:mt-0 sm:col-span-2">
                <span class="<%= role_badge_class(@user.role) %>">
                  <%= @user.role.titleize %>
                </span>
              </dd>
            </div>
            <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Status</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white sm:mt-0 sm:col-span-2">
                <% if @user.active? %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                    Active
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200">
                    Inactive
                  </span>
                <% end %>
              </dd>
            </div>
            <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Member since</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white sm:mt-0 sm:col-span-2">
                <%= @user.created_at.strftime("%B %d, %Y") %>
              </dd>
            </div>
            <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Last sign in</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-white sm:mt-0 sm:col-span-2">
                <% if @user.last_sign_in_at.present? %>
                  <%= @user.last_sign_in_at.strftime("%B %d, %Y at %I:%M %p") %>
                <% else %>
                  Never
                <% end %>
              </dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
    
    <!-- User Stats & Actions -->
    <div class="lg:col-span-1">
      <!-- User Avatar -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700 mb-6">
        <div class="px-5 py-4 bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
          <h2 class="text-lg font-medium text-gray-900 dark:text-white">Profile</h2>
        </div>
        
        <div class="p-6 flex flex-col items-center">
          <div class="h-32 w-32 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 overflow-hidden text-5xl mb-4">
            <% if @user.has_avatar? %>
              <%= image_tag @user.avatar_url, class: "h-32 w-32 rounded-full" %>
            <% else %>
              <span><%= @user.name.first.upcase %></span>
            <% end %>
          </div>
          
          <h3 class="text-lg font-medium text-gray-900 dark:text-white"><%= @user.name %></h3>
          <p class="text-sm text-gray-500 dark:text-gray-400"><%= @user.email %></p>
        </div>
      </div>
      
      <!-- Actions -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
        <div class="px-5 py-4 bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
          <h2 class="text-lg font-medium text-gray-900 dark:text-white">Actions</h2>
        </div>
        
        <div class="p-6 space-y-4">
          <% if policy(@user).update? %>
            <%= link_to edit_user_path(@user), class: "w-full inline-flex items-center justify-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
              <i class="fas fa-edit mr-2"></i> Edit User
            <% end %>
          <% end %>
          
          <% if policy(@user).reset_password? %>
            <%= button_to reset_password_user_path(@user), method: :post, data: { confirm: "Are you sure you want to reset the password for #{@user.name}?" }, class: "w-full inline-flex items-center justify-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-yellow-600 hover:bg-yellow-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-yellow-500" do %>
              <i class="fas fa-key mr-2"></i> Reset Password
            <% end %>
          <% end %>
          
          <% if policy(@user).activate? && !@user.active? %>
            <%= button_to activate_user_path(@user), method: :patch, class: "w-full inline-flex items-center justify-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" do %>
              <i class="fas fa-user-check mr-2"></i> Activate User
            <% end %>
          <% end %>
          
          <% if policy(@user).deactivate? && @user.active? %>
            <%= button_to deactivate_user_path(@user), method: :patch, data: { confirm: "Are you sure you want to deactivate #{@user.name}?" }, class: "w-full inline-flex items-center justify-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" do %>
              <i class="fas fa-user-slash mr-2"></i> Deactivate User
            <% end %>
          <% end %>
          
          <% if policy(@user).destroy? %>
            <%= button_to user_path(@user), method: :delete, data: { confirm: "Are you sure you want to delete #{@user.name}? This action cannot be undone." }, class: "w-full inline-flex items-center justify-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" do %>
              <i class="fas fa-trash-alt mr-2"></i> Delete User
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Recent Activity -->
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
    <div class="px-5 py-4 bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600">
      <h2 class="text-lg font-medium text-gray-900 dark:text-white">Recent Activity</h2>
    </div>
    
    <div class="p-6">
      <% if @user.user_activities.exists? %>
        <div class="flow-root">
          <ul role="list" class="-mb-8">
            <% @user.user_activities.order(created_at: :desc).limit(10).each_with_index do |activity, activity_idx| %>
              <li>
                <div class="relative pb-8">
                  <% if activity_idx != @user.user_activities.order(created_at: :desc).limit(10).size - 1 %>
                    <span class="absolute top-4 left-4 -ml-px h-full w-0.5 bg-gray-200 dark:bg-gray-700" aria-hidden="true"></span>
                  <% end %>
                  <div class="relative flex space-x-3">
                    <div>
                      <span class="h-8 w-8 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center ring-8 ring-white dark:ring-gray-800">
                        <i class="fas fa-history text-indigo-600 dark:text-indigo-400"></i>
                      </span>
                    </div>
                    <div class="min-w-0 flex-1 pt-1.5 flex justify-between space-x-4">
                      <div>
                        <p class="text-sm text-gray-500 dark:text-gray-400">
                          <%= activity.action.humanize %>
                          <% if activity.details.present? %>
                            <span class="font-medium text-gray-900 dark:text-white">
                              <%= activity.details.map { |k, v| "#{k.to_s.humanize}: #{v}" }.join(", ") %>
                            </span>
                          <% end %>
                        </p>
                      </div>
                      <div class="text-right text-sm whitespace-nowrap text-gray-500 dark:text-gray-400">
                        <time datetime="<%= activity.created_at.iso8601 %>"><%= time_ago_in_words(activity.created_at) %> ago</time>
                      </div>
                    </div>
                  </div>
                </div>
              </li>
            <% end %>
          </ul>
        </div>
      <% else %>
        <div class="text-center py-6">
          <i class="fas fa-history text-gray-400 text-4xl mb-3"></i>
          <p class="text-gray-500 dark:text-gray-400">No activity recorded yet.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
