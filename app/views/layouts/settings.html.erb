<% content_for :content do %>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      <!-- Settings Sidebar -->
      <div class="lg:col-span-1">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700 sticky top-24">
          <div class="bg-gradient-to-r from-indigo-600 to-purple-600 px-5 py-4">
            <h2 class="text-lg font-semibold text-white flex items-center">
              <i class="fas fa-cog mr-2"></i> Settings
            </h2>
          </div>

          <div class="p-1">
            <nav class="space-y-1">
              <%= link_to settings_profile_path, class: "flex items-center px-4 py-3 text-gray-700 dark:text-gray-200 #{current_page?(settings_profile_path) ? 'bg-indigo-50 dark:bg-indigo-900/20 text-indigo-600 dark:text-indigo-400' : 'hover:bg-gray-50 dark:hover:bg-gray-700/30'} rounded-lg transition-colors duration-200" do %>
                <div class="w-8 h-8 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mr-3">
                  <i class="fas fa-user"></i>
                </div>
                <span class="font-medium">Profile</span>
              <% end %>

              <%= link_to settings_account_path, class: "flex items-center px-4 py-3 text-gray-700 dark:text-gray-200 #{current_page?(settings_account_path) ? 'bg-indigo-50 dark:bg-indigo-900/20 text-indigo-600 dark:text-indigo-400' : 'hover:bg-gray-50 dark:hover:bg-gray-700/30'} rounded-lg transition-colors duration-200" do %>
                <div class="w-8 h-8 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mr-3">
                  <i class="fas fa-user-cog"></i>
                </div>
                <span class="font-medium">Account</span>
              <% end %>

              <%= link_to settings_notifications_path, class: "flex items-center px-4 py-3 text-gray-700 dark:text-gray-200 #{current_page?(settings_notifications_path) ? 'bg-indigo-50 dark:bg-indigo-900/20 text-indigo-600 dark:text-indigo-400' : 'hover:bg-gray-50 dark:hover:bg-gray-700/30'} rounded-lg transition-colors duration-200" do %>
                <div class="w-8 h-8 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mr-3">
                  <i class="fas fa-bell"></i>
                </div>
                <span class="font-medium">Notifications</span>
              <% end %>

              <%= link_to settings_appearance_path, class: "flex items-center px-4 py-3 text-gray-700 dark:text-gray-200 #{current_page?(settings_appearance_path) ? 'bg-indigo-50 dark:bg-indigo-900/20 text-indigo-600 dark:text-indigo-400' : 'hover:bg-gray-50 dark:hover:bg-gray-700/30'} rounded-lg transition-colors duration-200" do %>
                <div class="w-8 h-8 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mr-3">
                  <i class="fas fa-paint-brush"></i>
                </div>
                <span class="font-medium">Appearance</span>
              <% end %>

              <%= link_to settings_security_path, class: "flex items-center px-4 py-3 text-gray-700 dark:text-gray-200 #{current_page?(settings_security_path) ? 'bg-indigo-50 dark:bg-indigo-900/20 text-indigo-600 dark:text-indigo-400' : 'hover:bg-gray-50 dark:hover:bg-gray-700/30'} rounded-lg transition-colors duration-200" do %>
                <div class="w-8 h-8 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mr-3">
                  <i class="fas fa-shield-alt"></i>
                </div>
                <span class="font-medium">Security</span>
              <% end %>

              <% if current_user.admin? %>
                <div class="border-t border-gray-200 dark:border-gray-700 my-2 pt-2">
                  <h3 class="px-4 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">
                    Administration
                  </h3>

                  <%= link_to settings_organization_path, class: "flex items-center px-4 py-3 text-gray-700 dark:text-gray-200 #{current_page?(settings_organization_path) ? 'bg-indigo-50 dark:bg-indigo-900/20 text-indigo-600 dark:text-indigo-400' : 'hover:bg-gray-50 dark:hover:bg-gray-700/30'} rounded-lg transition-colors duration-200" do %>
                    <div class="w-8 h-8 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mr-3">
                      <i class="fas fa-building"></i>
                    </div>
                    <span class="font-medium">Organization</span>
                  <% end %>

                  <%= link_to settings_users_path, class: "flex items-center px-4 py-3 text-gray-700 dark:text-gray-200 #{current_page?(settings_users_path) ? 'bg-indigo-50 dark:bg-indigo-900/20 text-indigo-600 dark:text-indigo-400' : 'hover:bg-gray-50 dark:hover:bg-gray-700/30'} rounded-lg transition-colors duration-200" do %>
                    <div class="w-8 h-8 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mr-3">
                      <i class="fas fa-users-cog"></i>
                    </div>
                    <span class="font-medium">Users</span>
                  <% end %>

                  <%= link_to settings_integrations_path, class: "flex items-center px-4 py-3 text-gray-700 dark:text-gray-200 #{current_page?(settings_integrations_path) ? 'bg-indigo-50 dark:bg-indigo-900/20 text-indigo-600 dark:text-indigo-400' : 'hover:bg-gray-50 dark:hover:bg-gray-700/30'} rounded-lg transition-colors duration-200" do %>
                    <div class="w-8 h-8 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center text-indigo-600 dark:text-indigo-400 mr-3">
                      <i class="fas fa-plug"></i>
                    </div>
                    <span class="font-medium">Integrations</span>
                  <% end %>
                </div>
              <% end %>
            </nav>
          </div>
        </div>
      </div>

      <!-- Main Content -->
      <div class="lg:col-span-3">
        <!-- Flash Messages -->
        <% if flash[:notice] %>
          <div class="mb-6 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-4 flex items-start">
            <div class="flex-shrink-0 text-green-500 dark:text-green-400">
              <i class="fas fa-check-circle text-xl"></i>
            </div>
            <div class="ml-3">
              <p class="text-sm font-medium text-green-800 dark:text-green-200"><%= flash[:notice] %></p>
            </div>
            <div class="ml-auto pl-3">
              <div class="-mx-1.5 -my-1.5">
                <button type="button" class="inline-flex text-green-500 dark:text-green-400 hover:text-green-600 dark:hover:text-green-300 focus:outline-none" onclick="this.parentElement.parentElement.parentElement.remove()">
                  <span class="sr-only">Dismiss</span>
                  <i class="fas fa-times"></i>
                </button>
              </div>
            </div>
          </div>
        <% end %>

        <% if flash[:alert] %>
          <div class="mb-6 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4 flex items-start">
            <div class="flex-shrink-0 text-red-500 dark:text-red-400">
              <i class="fas fa-exclamation-circle text-xl"></i>
            </div>
            <div class="ml-3">
              <p class="text-sm font-medium text-red-800 dark:text-red-200"><%= flash[:alert] %></p>
              <% if @user && @user.errors.any? %>
                <ul class="mt-2 list-disc list-inside text-sm text-red-700 dark:text-red-300">
                  <% @user.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              <% end %>
            </div>
            <div class="ml-auto pl-3">
              <div class="-mx-1.5 -my-1.5">
                <button type="button" class="inline-flex text-red-500 dark:text-red-400 hover:text-red-600 dark:hover:text-red-300 focus:outline-none" onclick="this.parentElement.parentElement.parentElement.remove()">
                  <span class="sr-only">Dismiss</span>
                  <i class="fas fa-times"></i>
                </button>
              </div>
            </div>
          </div>
        <% end %>

        <%= yield %>
      </div>
    </div>
  </div>
<% end %>

<%= render template: "layouts/application" %>
